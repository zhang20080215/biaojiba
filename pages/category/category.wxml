<!--pages/category/category.wxml-->
<view class="page-root {{themeClass}}">

  <!-- Hero 区 -->
  <view class="hero-section" style="padding-top: {{headerPadTop}}px">
    <view class="header">
      <view class="header-left">
        <view class="header-top">
          <text class="app-name">标记吧</text>
          <view class="theme-toggle" bindtap="onToggleThemePicker"><view class="theme-toggle-dot"></view></view>
        </view>
        <text class="app-slogan">标记生活的仪式感，分享专属记录</text>
        <!-- 登录/用户卡片 -->
        <view wx:if="{{!userInfo}}" class="user-card" bindtap="onGetUserProfile">
          <view class="user-card-accent"></view>
          <view class="user-card-body">
            <text class="user-card-title">点击登录</text>
            <text class="user-card-sub">登录后开始你的标记旅程</text>
          </view>
          <text class="user-card-arrow">›</text>
        </view>
        <view wx:else class="user-card" bindtap="onLogout">
          <view class="user-card-accent"></view>
          <image class="user-card-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
          <view class="user-card-body">
            <text class="user-card-title">{{userInfo.nickName}}</text>
            <text class="user-card-sub">欢迎回来，继续标记吧</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 分类筛选 -->
  <view class="filter-bar">
    <view
      class="filter-chip {{activeTab === 'all' ? 'active' : ''}}"
      data-tab="all" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'all'}}"></view>
      <text>全部</text>
    </view>
    <view
      class="filter-chip {{activeTab === 'movie' ? 'active' : ''}}"
      data-tab="movie" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'movie'}}"></view>
      <text>电影</text>
    </view>
    <view
      class="filter-chip {{activeTab === 'parenting' ? 'active' : ''}}"
      data-tab="parenting" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'parenting'}}"></view>
      <text>育儿</text>
    </view>
  </view>

  <!-- 主题卡片网格（两列） -->
  <view class="card-grid">
    <navigator
      wx:for="{{filteredThemes}}"
      wx:key="id"
      class="theme-card"
      url="{{item.url}}"
      hover-class="none"
    >
      <!-- 封面 -->
      <view class="card-cover">
        <image wx:if="{{item.image}}" class="cover-img" src="{{item.image}}" mode="aspectFill"></image>
        <view wx:elif="{{item.id === 'child_growth'}}" class="cover-placeholder growth">
          <view class="ruler-icon"></view>
          <text class="placeholder-text">成长评估</text>
        </view>
        <view class="cover-mask"></view>
        <view class="tag-badge">
          <text>{{item.tag}}</text>
        </view>
        <image
          wx:if="{{item.id === 'oscar_movies'}}"
          class="oscar-icon"
          src="/images/oscar-icon.svg"
          mode="aspectFit"
        ></image>
      </view>

      <!-- 信息区 -->
      <view class="card-body">
        <text class="card-title">{{item.title}}</text>
        <text class="card-desc">{{item.description}}</text>
        <view class="card-meta">
          <view wx:if="{{item.userCount > 0}}" class="meta-count">
            <text class="meta-count-number">{{item.userCountText}}</text>
            <text class="meta-count-label">人参与</text>
          </view>
          <view class="meta-arrow">
            <text>›</text>
          </view>
        </view>
      </view>
    </navigator>
  </view>

  <!-- 广告 -->
  <view class="ad-zone" wx:if="{{showNativeAd}}">
    <ad-custom unit-id="{{adUnitIds.category_native}}" bindload="onNativeAdLoad" binderror="onNativeAdError"></ad-custom>
  </view>
  <view class="ad-zone" wx:if="{{showBannerAd}}">
    <ad unit-id="{{adUnitIds.category_banner}}" ad-type="banner" bindload="onBannerAdLoad" binderror="onBannerAdError"></ad>
  </view>

  <!-- 授权弹窗 -->
  <view class="modal-overlay" hidden="{{!showAuthModal}}">
    <view class="modal-mask" bindtap="onCancelAuth"></view>
    <view class="modal-card">
      <text class="modal-title">完善个人资料</text>
      <text class="modal-hint">设置头像和昵称，开始你的标记旅程</text>

      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="picker-img" src="{{tempAvatar || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <text class="picker-tip">点击选择头像</text>
      </button>

      <view class="input-row">
        <text class="input-label">昵称</text>
        <input
          type="nickname"
          class="input-field"
          placeholder="请输入昵称"
          placeholder-class="input-placeholder"
          bindinput="onNicknameInput"
          value="{{tempNickname}}"
        />
      </view>

      <view class="modal-actions">
        <button class="action-btn secondary" bindtap="onCancelAuth">取消</button>
        <button class="action-btn primary" bindtap="onConfirmAuth">保存</button>
      </view>
    </view>
  </view>

  <!-- 主题选择面板 -->
  <view class="theme-sheet" hidden="{{!showThemePicker}}">
    <view class="theme-sheet-mask" bindtap="onToggleThemePicker"></view>
    <view class="theme-sheet-body">
      <text class="theme-sheet-title">选择主题色</text>
      <view class="theme-sheet-options">
        <view
          class="theme-option {{themeClass === '' ? 'active' : ''}}"
          data-theme="" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#FAE0E4"></view>
          <text class="theme-option-label">樱花粉</text>
        </view>
        <view
          class="theme-option {{themeClass === 'theme-gold' ? 'active' : ''}}"
          data-theme="theme-gold" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#F7D66E"></view>
          <text class="theme-option-label">暖金</text>
        </view>
        <view
          class="theme-option {{themeClass === 'theme-green' ? 'active' : ''}}"
          data-theme="theme-green" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#9AAB65"></view>
          <text class="theme-option-label">橄榄绿</text>
        </view>
        <view
          class="theme-option {{themeClass === 'theme-sand' ? 'active' : ''}}"
          data-theme="theme-sand" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#F8F3E7; border: 2rpx solid #EDE7DA"></view>
          <text class="theme-option-label">暖沙</text>
        </view>
      </view>
    </view>
  </view>

</view>

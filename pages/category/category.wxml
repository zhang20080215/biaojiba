<!--pages/category/category.wxml-->
<view class="page-root {{themeClass}}">

  <!-- Hero 区 -->
  <view class="hero-section" style="padding-top: {{headerPadTop}}px">
    <view class="header">
      <view class="header-left">
        <view class="header-top">
          <text class="app-name">标记吧</text>
          <view class="theme-toggle" bindtap="onToggleThemePicker"><view class="theme-toggle-dot"></view></view>
        </view>
        <text class="app-slogan">标记生活的仪式感，分享专属记录</text>
        <!-- 登录/用户卡片 + 意见反馈卡片（横向并列） -->
        <view class="user-row">
          <view wx:if="{{!userInfo}}" class="user-card user-card-main" bindtap="onGetUserProfile">
            <view class="user-card-accent"></view>
            <view class="user-card-body">
              <text class="user-card-title">点击登录</text>
              <text class="user-card-sub">登录后开始你的标记旅程</text>
            </view>
            <text class="user-card-arrow">›</text>
          </view>
          <view wx:else class="user-card user-card-main" bindtap="onLogout">
            <view class="user-card-accent"></view>
            <image class="user-card-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
            <view class="user-card-body">
              <text class="user-card-title">{{userInfo.nickName}}</text>
              <text class="user-card-sub">欢迎回来，继续标记吧</text>
            </view>
          </view>
          <button class="user-card feedback-card-side" open-type="feedback" hover-class="feedback-card-hover">
            <text class="feedback-side-icon">✉</text>
            <text class="feedback-side-label">反馈</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 每日标记 -->
  <view class="section-head">每日标记</view>

  <!-- 每日主题：横排 4 个独立块（电影/读书/运动/喝水；不足 4 个时补敬请期待） -->
  <view class="daily-section">
    <view class="daily-row">
      <block wx:for="{{dailyBlocks}}" wx:key="key">
        <navigator
          wx:if="{{!item.placeholder}}"
          class="daily-block"
          style="background:{{item.color}}"
          url="{{item.url}}"
          hover-class="daily-block-hover"
        >
          <view class="daily-icon"><text class="daily-emoji">{{item.emoji}}</text></view>
          <text class="daily-label" style="color:{{item.label}}">{{item.title}}</text>
        </navigator>
        <view wx:else class="daily-block daily-block-soon" style="background:{{item.color}}">
          <view class="daily-icon"><text class="daily-emoji">{{item.emoji}}</text></view>
          <text class="daily-label" style="color:{{item.label}}">{{item.title}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 主题标记 -->
  <view class="section-head">主题标记</view>

  <!-- 分类筛选 -->
  <view class="filter-bar">
    <view
      class="filter-chip {{activeTab === 'all' ? 'active' : ''}}"
      data-tab="all" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'all'}}"></view>
      <text>全部</text>
    </view>
    <view
      class="filter-chip {{activeTab === 'movie' ? 'active' : ''}}"
      data-tab="movie" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'movie'}}"></view>
      <text>电影</text>
    </view>
    <view
      class="filter-chip {{activeTab === 'oscar' ? 'active' : ''}}"
      data-tab="oscar" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'oscar'}}"></view>
      <text>奥斯卡</text>
    </view>
    <view
      class="filter-chip {{activeTab === 'reading' ? 'active' : ''}}"
      data-tab="reading" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'reading'}}"></view>
      <text>读书</text>
    </view>
    <view
      class="filter-chip {{activeTab === 'parenting' ? 'active' : ''}}"
      data-tab="parenting" bindtap="onTabTap"
    >
      <view class="chip-dot" wx:if="{{activeTab === 'parenting'}}"></view>
      <text>育儿</text>
    </view>
  </view>

  <!-- 片单/书单需求收集入口 -->
  <view class="request-entry" bindtap="onOpenRequestModal" hover-class="request-entry-hover">
    <view class="request-entry-icon"><text>💡</text></view>
    <view class="request-entry-body">
      <text class="request-entry-title">没找到想要的片单/书单？</text>
      <text class="request-entry-sub">说说你想标记的榜单，采纳后会上线</text>
    </view>
    <text class="request-entry-arrow">›</text>
  </view>

  <!-- 主题卡片网格（两列）：前两张 → 广告 → 剩余，确保广告在首屏可见 -->
  <view class="card-grid">
    <!-- 第一行（前2张） -->
    <navigator
      wx:for="{{filteredThemes}}"
      wx:for-index="idx"
      wx:key="id"
      wx:if="{{idx < 2}}"
      class="theme-card"
      url="{{item.url}}"
      hover-class="none"
    >
      <!-- 封面 -->
      <view class="card-cover">
        <block wx:if="{{item.image}}">
          <image class="cover-img" src="{{item.image}}" mode="{{item.imageMode || 'aspectFill'}}"></image>
          <view class="cover-tint {{item.tintClass}}"></view>
        </block>
        <block wx:elif="{{item.dynamicCover}}">
          <image class="cover-img" src="{{item.dynamicCover.cover}}" mode="aspectFill"></image>
          <view class="cover-tint {{item.tintClass}}"></view>
        </block>
        <view wx:elif="{{item.id === 'child_growth'}}" class="cover-placeholder growth">
          <view class="ruler-icon"></view>
          <text class="placeholder-text">成长评估</text>
        </view>
        <view wx:elif="{{item.id === 'daily_water'}}" class="cover-placeholder water">
          <view class="bottle-mini">
            <view class="bottle-cap"></view>
            <view class="bottle-neck"></view>
            <view class="bottle-body">
              <view class="bottle-water"></view>
            </view>
          </view>
          <text class="placeholder-text">每日喝水</text>
        </view>
        <view wx:elif="{{item.id === 'rt_horror_movies'}}" class="cover-placeholder rt-horror">
          <text class="placeholder-emoji">🔪</text>
          <text class="placeholder-text">恐怖电影</text>
        </view>
        <view wx:elif="{{item.id === 'rt_war_movies'}}" class="cover-placeholder rt-war">
          <text class="placeholder-emoji">🎖️</text>
          <text class="placeholder-text">战争电影</text>
        </view>
        <view wx:elif="{{item.id === 'rt_animation_movies'}}" class="cover-placeholder rt-animation">
          <text class="placeholder-emoji">🎨</text>
          <text class="placeholder-text">动画电影</text>
        </view>
        <view wx:elif="{{item.id === 'palme_dor_movies'}}" class="cover-placeholder palme">
          <text class="placeholder-emoji">🌴</text>
          <text class="placeholder-text">金棕榈奖</text>
        </view>
        <view wx:elif="{{item.id === 'oscar_screenplay_movies'}}" class="cover-placeholder oscar-screenplay">
          <text class="placeholder-emoji">✍️</text>
          <text class="placeholder-text">原创剧本</text>
        </view>
        <view wx:elif="{{item.id === 'oscar_foreign_movies'}}" class="cover-placeholder oscar-foreign">
          <text class="placeholder-emoji">🌍</text>
          <text class="placeholder-text">最佳外语片</text>
        </view>
        <view wx:elif="{{item.id === 'rt_action_movies'}}" class="cover-placeholder rt-action">
          <text class="placeholder-emoji">💥</text>
          <text class="placeholder-text">动作电影</text>
        </view>
        <view wx:elif="{{item.id === 'letterboxd500_movies'}}" class="cover-placeholder letterboxd500">
          <text class="placeholder-emoji">🎞️</text>
          <text class="placeholder-text">Letterboxd Top 500</text>
        </view>
        <view class="cover-mask"></view>
        <text class="cover-tag-label">{{item.tag}}</text>
        <view wx:if="{{item.id === 'palme_dor_movies' || item.id === 'oscar_screenplay_movies' || item.id === 'oscar_foreign_movies' || item.id === 'rt_action_movies' || item.id === 'letterboxd500_movies'}}" class="new-badge">
          <text>NEW</text>
        </view>
        <view wx:if="{{item.wishFrom}}" class="wish-badge">
          <text>来自用户{{item.wishFrom}}的许愿</text>
        </view>
        <image
          wx:if="{{item.id === 'oscar_movies'}}"
          class="oscar-icon"
          src="/images/oscar-icon.svg"
          mode="aspectFit"
        ></image>
      </view>

      <!-- 信息区：回到封面下方独立白底区（静态设计封面图本身带文字，叠在图上会跟原图文字打架，
           这个位置能保证在任何封面上都清晰）；分类标签改成纯文字，不用胶囊底 -->
      <view class="card-body">
        <text class="card-title">{{item.title}}</text>
        <view class="card-meta">
          <view wx:if="{{item.userCount > 0}}" class="meta-count">
            <text class="meta-count-number">{{item.userCountText}}</text>
            <text class="meta-count-label">人参与</text>
          </view>
          <view class="meta-arrow">
            <text>›</text>
          </view>
        </view>
      </view>
    </navigator>
  </view>

  <!-- 广告：夹在第一行（2张）和剩余卡片之间，首屏可见，大幅提升曝光率 -->
  <view class="ad-zone" wx:if="{{showNativeAd}}">
    <ad-custom unit-id="{{adUnitIds.category_native}}" bindload="onNativeAdLoad" binderror="onNativeAdError"></ad-custom>
  </view>

  <!-- 剩余卡片（第3张起） -->
  <view class="card-grid">
    <navigator
      wx:for="{{filteredThemes}}"
      wx:for-index="idx"
      wx:key="id"
      wx:if="{{idx >= 2}}"
      class="theme-card"
      url="{{item.url}}"
      hover-class="none"
    >
      <!-- 封面 -->
      <view class="card-cover">
        <block wx:if="{{item.image}}">
          <image class="cover-img" src="{{item.image}}" mode="{{item.imageMode || 'aspectFill'}}"></image>
          <view class="cover-tint {{item.tintClass}}"></view>
        </block>
        <block wx:elif="{{item.dynamicCover}}">
          <image class="cover-img" src="{{item.dynamicCover.cover}}" mode="aspectFill"></image>
          <view class="cover-tint {{item.tintClass}}"></view>
        </block>
        <view wx:elif="{{item.id === 'child_growth'}}" class="cover-placeholder growth">
          <view class="ruler-icon"></view>
          <text class="placeholder-text">成长评估</text>
        </view>
        <view wx:elif="{{item.id === 'daily_water'}}" class="cover-placeholder water">
          <view class="bottle-mini">
            <view class="bottle-cap"></view>
            <view class="bottle-neck"></view>
            <view class="bottle-body">
              <view class="bottle-water"></view>
            </view>
          </view>
          <text class="placeholder-text">每日喝水</text>
        </view>
        <view wx:elif="{{item.id === 'rt_horror_movies'}}" class="cover-placeholder rt-horror">
          <text class="placeholder-emoji">🔪</text>
          <text class="placeholder-text">恐怖电影</text>
        </view>
        <view wx:elif="{{item.id === 'rt_war_movies'}}" class="cover-placeholder rt-war">
          <text class="placeholder-emoji">🎖️</text>
          <text class="placeholder-text">战争电影</text>
        </view>
        <view wx:elif="{{item.id === 'rt_animation_movies'}}" class="cover-placeholder rt-animation">
          <text class="placeholder-emoji">🎨</text>
          <text class="placeholder-text">动画电影</text>
        </view>
        <view wx:elif="{{item.id === 'palme_dor_movies'}}" class="cover-placeholder palme">
          <text class="placeholder-emoji">🌴</text>
          <text class="placeholder-text">金棕榈奖</text>
        </view>
        <view wx:elif="{{item.id === 'oscar_screenplay_movies'}}" class="cover-placeholder oscar-screenplay">
          <text class="placeholder-emoji">✍️</text>
          <text class="placeholder-text">原创剧本</text>
        </view>
        <view wx:elif="{{item.id === 'oscar_foreign_movies'}}" class="cover-placeholder oscar-foreign">
          <text class="placeholder-emoji">🌍</text>
          <text class="placeholder-text">最佳外语片</text>
        </view>
        <view wx:elif="{{item.id === 'rt_action_movies'}}" class="cover-placeholder rt-action">
          <text class="placeholder-emoji">💥</text>
          <text class="placeholder-text">动作电影</text>
        </view>
        <view wx:elif="{{item.id === 'letterboxd500_movies'}}" class="cover-placeholder letterboxd500">
          <text class="placeholder-emoji">🎞️</text>
          <text class="placeholder-text">Letterboxd Top 500</text>
        </view>
        <view class="cover-mask"></view>
        <text class="cover-tag-label">{{item.tag}}</text>
        <view wx:if="{{item.id === 'palme_dor_movies' || item.id === 'oscar_screenplay_movies' || item.id === 'oscar_foreign_movies' || item.id === 'rt_action_movies' || item.id === 'letterboxd500_movies'}}" class="new-badge">
          <text>NEW</text>
        </view>
        <view wx:if="{{item.wishFrom}}" class="wish-badge">
          <text>来自用户{{item.wishFrom}}的许愿</text>
        </view>
        <image
          wx:if="{{item.id === 'oscar_movies'}}"
          class="oscar-icon"
          src="/images/oscar-icon.svg"
          mode="aspectFit"
        ></image>
      </view>

      <!-- 信息区：回到封面下方独立白底区（静态设计封面图本身带文字，叠在图上会跟原图文字打架，
           这个位置能保证在任何封面上都清晰）；分类标签改成纯文字，不用胶囊底 -->
      <view class="card-body">
        <text class="card-title">{{item.title}}</text>
        <view class="card-meta">
          <view wx:if="{{item.userCount > 0}}" class="meta-count">
            <text class="meta-count-number">{{item.userCountText}}</text>
            <text class="meta-count-label">人参与</text>
          </view>
          <view class="meta-arrow">
            <text>›</text>
          </view>
        </view>
      </view>
    </navigator>
  </view>

  <!-- 片单/书单需求收集弹窗 -->
  <view class="modal-overlay" hidden="{{!showRequestModal}}">
    <view class="modal-mask" bindtap="onCloseRequestModal"></view>
    <view class="modal-card">
      <text class="modal-title">许愿新榜单</text>
      <text class="modal-hint">想标记什么片单/书单，写下来告诉我们</text>

      <view class="request-type-row">
        <view class="request-type-chip {{requestType === 'movie' ? 'active' : ''}}" data-type="movie" bindtap="onRequestTypeTap">片单</view>
        <view class="request-type-chip {{requestType === 'book' ? 'active' : ''}}" data-type="book" bindtap="onRequestTypeTap">书单</view>
        <view class="request-type-chip {{requestType === 'other' ? 'active' : ''}}" data-type="other" bindtap="onRequestTypeTap">其他</view>
      </view>

      <textarea
        class="request-textarea"
        placeholder="例如：戛纳金棕榈获奖片单、茅盾文学奖书单…"
        placeholder-class="input-placeholder"
        maxlength="200"
        value="{{requestContent}}"
        bindinput="onRequestInput"
      ></textarea>
      <view class="request-count">{{requestContent.length}}/200</view>

      <view class="modal-actions">
        <button class="action-btn secondary" bindtap="onCloseRequestModal">取消</button>
        <button class="action-btn primary" bindtap="onSubmitRequest">提交</button>
      </view>
    </view>
  </view>

  <!-- 授权弹窗 -->
  <view class="modal-overlay" hidden="{{!showAuthModal}}">
    <view class="modal-mask" bindtap="onCancelAuth"></view>
    <view class="modal-card">
      <text class="modal-title">完善个人资料</text>
      <text class="modal-hint">设置头像和昵称，开始你的标记旅程</text>

      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="picker-img" src="{{tempAvatar || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <text class="picker-tip">点击选择头像</text>
      </button>

      <view class="input-row">
        <text class="input-label">昵称</text>
        <input
          type="nickname"
          class="input-field"
          placeholder="请输入昵称"
          placeholder-class="input-placeholder"
          bindinput="onNicknameInput"
          value="{{tempNickname}}"
        />
      </view>

      <view class="modal-actions">
        <button class="action-btn secondary" bindtap="onCancelAuth">取消</button>
        <button class="action-btn primary" bindtap="onConfirmAuth">保存</button>
      </view>
    </view>
  </view>

  <!-- 主题选择面板 -->
  <view class="theme-sheet" hidden="{{!showThemePicker}}">
    <view class="theme-sheet-mask" bindtap="onToggleThemePicker"></view>
    <view class="theme-sheet-body">
      <text class="theme-sheet-title">选择主题色</text>
      <view class="theme-sheet-options">
        <view
          class="theme-option {{themeClass === '' ? 'active' : ''}}"
          data-theme="" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#FAE0E4"></view>
          <text class="theme-option-label">樱花粉</text>
        </view>
        <view
          class="theme-option {{themeClass === 'theme-gold' ? 'active' : ''}}"
          data-theme="theme-gold" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#F7D66E"></view>
          <text class="theme-option-label">暖金</text>
        </view>
        <view
          class="theme-option {{themeClass === 'theme-green' ? 'active' : ''}}"
          data-theme="theme-green" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#9AAB65"></view>
          <text class="theme-option-label">橄榄绿</text>
        </view>
        <view
          class="theme-option {{themeClass === 'theme-sand' ? 'active' : ''}}"
          data-theme="theme-sand" bindtap="onThemeSelect"
        >
          <view class="theme-option-circle" style="background:#F8F3E7; border: 2rpx solid #EDE7DA"></view>
          <text class="theme-option-label">暖沙</text>
        </view>
      </view>
    </view>
  </view>

</view>

/* category — style.md v2.2.0 */

/* ========== 页面根 ========== */
.page-root {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: var(--space-6);
  box-sizing: border-box;
  --category-hero-title: #3d2530;
  --category-hero-slogan: rgba(61, 37, 48, 0.62);
  --category-user-title: #3d2530;
  --category-user-sub: #8a6e78;
  --category-user-arrow: #b8959f;
  --category-filter-text: #8a6e78;
  --category-filter-active-text: #3d2530;
  --category-tag-text: #8a6e78;
  --category-card-title: #3d2530;
  --category-card-desc: #946d7c;
  --category-meta-bg: rgba(250, 224, 228, 0.55);
  --category-meta-number: #c4607e;
  --category-meta-label: #946d7c;
  --category-meta-arrow-bg: rgba(250, 224, 228, 0.48);
  --category-meta-arrow-text: #b8959f;
}

/* ========== Hero 区 ========== */
.hero-section {
  position: relative;
  overflow: hidden;
  background: var(--brand-primary);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  padding-bottom: var(--space-4);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  background: var(--info);
  opacity: 0.35;
  border-radius: 50%;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: var(--warning);
  opacity: 0.25;
  border-radius: 50%;
}

/* 装饰圆：按主题交叉配色 */
.page-root.theme-gold {
  --category-hero-title: #463010;
  --category-hero-slogan: rgba(70, 48, 16, 0.58);
  --category-user-title: #463010;
  --category-user-sub: #8c6f3a;
  --category-user-arrow: #b89960;
  --category-filter-text: #8c6f3a;
  --category-filter-active-text: #463010;
  --category-tag-text: #8c6f3a;
  --category-card-title: #463010;
  --category-card-desc: #957642;
  --category-meta-bg: rgba(247, 214, 110, 0.18);
  --category-meta-number: #a07a14;
  --category-meta-label: #8c6f3a;
  --category-meta-arrow-bg: rgba(247, 214, 110, 0.16);
  --category-meta-arrow-text: #b89960;
}

.page-root.theme-gold .hero-section::before { background: var(--info); }
.page-root.theme-gold .hero-section::after { background: var(--success); }

.page-root.theme-green {
  --category-hero-title: #2a3520;
  --category-hero-slogan: rgba(42, 53, 32, 0.58);
  --category-user-title: #2a3520;
  --category-user-sub: #6a7752;
  --category-user-arrow: #94a176;
  --category-filter-text: #6a7752;
  --category-filter-active-text: #2a3520;
  --category-tag-text: #6a7752;
  --category-card-title: #2a3520;
  --category-card-desc: #6e7b54;
  --category-meta-bg: rgba(154, 171, 101, 0.14);
  --category-meta-number: #6a8035;
  --category-meta-label: #6e7b54;
  --category-meta-arrow-bg: rgba(154, 171, 101, 0.12);
  --category-meta-arrow-text: #94a176;
}

.page-root.theme-green .hero-section::before { background: var(--warning); }
.page-root.theme-green .hero-section::after { background: var(--info); }

.page-root.theme-sand {
  --category-hero-title: #3e3628;
  --category-hero-slogan: rgba(62, 54, 40, 0.55);
  --category-user-title: #3e3628;
  --category-user-sub: #82796a;
  --category-user-arrow: #a89e8c;
  --category-filter-text: #82796a;
  --category-filter-active-text: #3e3628;
  --category-tag-text: #82796a;
  --category-card-title: #3e3628;
  --category-card-desc: #8a8070;
  --category-meta-bg: rgba(237, 231, 218, 0.65);
  --category-meta-number: #8c7a4e;
  --category-meta-label: #8a8070;
  --category-meta-arrow-bg: rgba(237, 231, 218, 0.50);
  --category-meta-arrow-text: #a89e8c;
}

.header {
  position: relative;
  z-index: 1;
  padding: var(--space-3) var(--space-4) 0;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.header-top {
  display: flex;
  align-items: center;
}

.app-name {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--category-hero-title);
  line-height: 1.15;
  letter-spacing: 2rpx;
}

.theme-toggle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--space-2);
  transition: transform 120ms ease-out;
}

.theme-toggle:active {
  transform: scale(0.92);
}

.theme-toggle-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: var(--brand-primary);
  border: 3rpx solid var(--bg-card);
  box-shadow: inset 0 0 0 4rpx var(--brand-soft);
}

.app-slogan {
  font-size: var(--font-body);
  color: var(--category-hero-slogan);
  margin-top: var(--space-2);
  line-height: 1.4;
}

/* 用户卡片（登录前 & 登录后共用） */
.user-card {
  display: flex;
  align-items: center;
  margin-top: var(--space-2);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: transform 120ms ease-out;
}

.user-card:active {
  transform: scale(0.98);
}

.user-card-accent {
  width: 8rpx;
  height: 64rpx;
  border-radius: 4rpx;
  background: var(--brand-primary);
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.user-card-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.user-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.user-card-title {
  font-size: var(--font-body);
  font-weight: 700;
  color: var(--category-user-title);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-card-sub {
  font-size: var(--font-caption);
  color: var(--category-user-sub);
  margin-top: 4rpx;
  line-height: 1.3;
}

.user-card-arrow {
  font-size: 40rpx;
  color: var(--category-user-arrow);
  margin-left: var(--space-2);
  font-weight: 700;
  flex-shrink: 0;
}

/* ========== 分类筛选 ========== */
.filter-bar {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-3) var(--space-2);
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  padding: 0 28rpx;
  margin-right: 14rpx;
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--category-filter-text);
  background: var(--bg-section);
  flex-shrink: 0;
  transition: all 160ms ease-out;
  letter-spacing: 1rpx;
}

.filter-chip.active {
  background: var(--brand-primary);
  color: var(--category-filter-active-text);
  font-weight: 700;
  box-shadow: var(--shadow-cta);
}

.chip-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--category-filter-active-text);
  margin-right: 8rpx;
}

/* ========== 卡片网格（两列） ========== */
.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3);
  padding: 0 var(--space-3);
}

/* ========== 主题卡片 ========== */
.theme-card {
  background: var(--bg-section);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 120ms ease-out;
}

.theme-card:active {
  transform: scale(0.97);
}

/* 封面区 */
.card-cover {
  position: relative;
  width: 100%;
  padding-top: 75%;
  overflow: hidden;
}

.cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 50%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.15), transparent);
}

/* 分类标签 — 圆角与卡片一致 */
.tag-badge {
  position: absolute;
  top: var(--space-2);
  left: var(--space-2);
  background: rgba(255, 255, 255, 0.92);
  border-radius: var(--radius-pill);
  padding: 8rpx 18rpx;
  backdrop-filter: blur(4rpx);
  font-size: var(--font-mini);
  color: var(--category-tag-text);
  font-weight: 500;
  line-height: 1.2;
  box-shadow: var(--shadow-card);
  z-index: 2;
}

/* NEW 角标 — 放右上角，与左上角 tag-badge 对称 */
.new-badge {
  position: absolute;
  top: var(--space-2);
  right: var(--space-2);
  background: linear-gradient(135deg, #FF5A5F 0%, #FF8A5F 100%);
  border-radius: var(--radius-pill);
  padding: 6rpx 16rpx;
  font-size: var(--font-mini);
  color: #FFFFFF;
  font-weight: 700;
  letter-spacing: 1rpx;
  line-height: 1.2;
  box-shadow: 0 4rpx 10rpx rgba(255, 90, 95, 0.35);
  z-index: 2;
}

/* 奥斯卡 badge */
.oscar-icon {
  position: absolute;
  bottom: var(--space-1);
  right: var(--space-1);
  width: 40rpx;
  height: 40rpx;
  z-index: 2;
  filter: drop-shadow(0 2rpx 4rpx rgba(247, 214, 110, 0.5));
}

/* 无图封面占位 */
.cover-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.cover-placeholder.growth {
  background: linear-gradient(135deg, var(--warning-soft) 0%, var(--warning) 100%);
}

.ruler-icon {
  width: 40rpx;
  height: 80rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 6rpx;
  position: relative;
  margin-bottom: var(--space-1);
}

.ruler-icon::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 0;
  width: 16rpx;
  height: 3rpx;
  background: rgba(255, 255, 255, 0.8);
  box-shadow:
    0 14rpx 0 rgba(255, 255, 255, 0.5),
    0 28rpx 0 rgba(255, 255, 255, 0.8),
    0 42rpx 0 rgba(255, 255, 255, 0.5);
}

.placeholder-text {
  font-size: var(--font-mini);
  color: rgba(255, 255, 255, 0.88);
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 信息区 */
.card-body {
  padding: var(--space-2) var(--space-3) var(--space-3);
}

.card-title {
  display: block;
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--category-card-title);
  line-height: 1.3;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  font-size: var(--font-caption);
  color: var(--category-card-desc);
  line-height: 1.45;
  margin-bottom: var(--space-2);
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-count {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--category-meta-bg);
  font-size: var(--font-caption);
  color: var(--category-meta-label);
  line-height: 1;
}

.meta-count-number {
  color: var(--category-meta-number);
  font-weight: 700;
}

.meta-count-label {
  color: var(--category-meta-label);
}

.meta-arrow {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--category-meta-arrow-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-body);
  color: var(--category-meta-arrow-text);
  font-weight: 700;
}

/* ========== 广告 ========== */
.ad-zone {
  margin: var(--space-3) var(--space-3) 0;
}

/* ========== 授权弹窗 ========== */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(6rpx);
}

.modal-card {
  position: relative;
  width: 82%;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-5) var(--space-4) var(--space-4);
  box-shadow: var(--shadow-float);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: var(--font-h1);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-1);
}

.modal-hint {
  font-size: var(--font-caption);
  color: var(--text-muted);
  margin-bottom: var(--space-5);
}

.avatar-picker {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-picker::after { border: none; }

.picker-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-section);
  box-shadow: var(--shadow-card);
}

.picker-tip {
  font-size: var(--font-mini);
  color: var(--brand-primary);
  margin-top: var(--space-1);
}

.input-row {
  width: 100%;
  margin-top: var(--space-4);
  display: flex;
  align-items: center;
  height: 80rpx;
  background: var(--bg-section);
  border-radius: var(--radius-md);
  padding: 0 var(--space-3);
  box-sizing: border-box;
}

.input-label {
  font-size: var(--font-body);
  color: var(--text-secondary);
  width: 80rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  font-size: var(--font-body);
  color: var(--text-primary);
}

.input-placeholder {
  color: var(--text-muted);
}

.modal-actions {
  display: flex;
  width: 100%;
  margin-top: var(--space-5);
  gap: var(--space-2);
}

.action-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: var(--radius-pill);
  font-size: var(--font-body);
  font-weight: 600;
  padding: 0;
  margin: 0;
  transition: transform 120ms ease-out;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn::after { border: none; }

.action-btn.secondary {
  background: var(--bg-section);
  color: var(--text-secondary);
}

.action-btn.primary {
  background: var(--brand-primary);
  color: var(--text-primary);
  box-shadow: var(--shadow-cta);
}

/* ========== 主题选择面板 ========== */
.theme-sheet {
  position: fixed;
  inset: 0;
  z-index: 998;
}

.theme-sheet-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.25);
}

.theme-sheet-body {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--space-5) var(--space-4) calc(var(--space-6) + env(safe-area-inset-bottom));
}

.theme-sheet-title {
  font-size: var(--font-h2);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-4);
}

.theme-sheet-options {
  display: flex;
  justify-content: space-between;
}

.theme-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2);
  border-radius: var(--radius-lg);
  transition: transform 120ms ease-out;
}

.theme-option:active {
  transform: scale(0.95);
}

.theme-option.active {
  background: var(--bg-section);
}

.theme-option-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  box-shadow: var(--shadow-card);
}

.theme-option.active .theme-option-circle {
  box-shadow: 0 0 0 4rpx var(--bg-card), 0 0 0 8rpx var(--text-primary);
}

.theme-option-label {
  font-size: var(--font-caption);
  color: var(--text-secondary);
  font-weight: 500;
}

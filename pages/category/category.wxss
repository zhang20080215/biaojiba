/* 分类页 - 清新明亮风格 */
.category-container {
  min-height: 100vh;
  background: #f7f7fa;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* ========== Hero Banner ========== */
.hero-banner {
  background: linear-gradient(135deg, #e8707a 0%, #f0968a 50%, #f2b8a0 100%);
  padding: 60rpx 32rpx 48rpx;
  position: relative;
  overflow: hidden;
}

/* 背景光晕装饰 */
.hero-banner::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
}

.hero-banner::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -20rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.10);
  border-radius: 50%;
}

.login-area {
  position: absolute;
  top: 48rpx;
  right: 32rpx;
  z-index: 10;
}

.login-btn {
  padding: 12rpx 28rpx;
  background: rgba(255,255,255,0.30);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.login-btn:active {
  background: rgba(255,255,255,0.45);
}

.login-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.user-avatar-container {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(255,255,255,0.8);
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
  margin-bottom: 14rpx;
  position: relative;
  z-index: 1;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 400;
  position: relative;
  z-index: 1;
}

/* ========== Tab 导航 ========== */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #999;
  border-radius: 28rpx;
  transition: all 0.25s ease;
}

.tab-item.active {
  color: #e8707a;
  background: rgba(232, 112, 122, 0.08);
  font-weight: 700;
}

/* ========== 2列卡片网格 ========== */
.themes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

/* ========== 主题卡片 ========== */
.theme-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.theme-card:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
}

/* 封面区 */
.theme-cover {
  position: relative;
  height: 180rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.02) 0%, rgba(0,0,0,0.18) 100%);
}

/* 分类tag浮层 */
.cover-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: rgba(255,255,255,0.85);
  border-radius: 16rpx;
  padding: 4rpx 14rpx;
  backdrop-filter: blur(4rpx);
}

.cover-tag-text {
  font-size: 20rpx;
  color: #666;
  font-weight: 500;
}

/* 奥斯卡小金人 */
.oscar-badge {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  z-index: 2;
  filter: drop-shadow(0 2px 4px rgba(212,175,55,0.6));
}

/* 儿童生长封面 - 阳光风格 */
.growth-cover {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #fff8d0 0%, #ffe082 50%, #ffca28 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.growth-cover::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.5) 0%, rgba(255,183,77,0.1) 60%, transparent 80%);
  border-radius: 50%;
}

.growth-sun {
  font-size: 68rpx;
  position: absolute;
  top: 10rpx;
  right: 16rpx;
  z-index: 1;
}

.growth-baby {
  font-size: 72rpx;
  position: relative;
  z-index: 2;
}

/* 信息区 */
.theme-info {
  padding: 20rpx 20rpx 16rpx;
}

.theme-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #2c2c2c;
  margin-bottom: 8rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.theme-desc {
  display: block;
  font-size: 21rpx;
  color: #aaa;
  line-height: 1.4;
  margin-bottom: 14rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.theme-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-count {
  font-size: 20rpx;
  color: var(--theme-color, #e8707a);
  font-weight: 500;
}

.theme-arrow-btn {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(232, 112, 122, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-arrow-icon {
  font-size: 28rpx;
  color: var(--theme-color, #e8707a);
  font-weight: 700;
  transform: translateX(1rpx);
  display: block;
}

/* ========== 特殊卡片主题 ========== */

/* 奥斯卡黑金 */
.theme-card.oscar_movies {
  background: linear-gradient(180deg, #1a1a2e 0%, #252540 100%);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.theme-card.oscar_movies .theme-title {
  color: #f5d98a;
}

.theme-card.oscar_movies .theme-desc {
  color: rgba(255,255,255,0.5);
}

.theme-card.oscar_movies .theme-arrow-btn {
  background: rgba(212,175,55,0.15);
}

.theme-card.oscar_movies .theme-arrow-icon {
  color: #d4af37;
}

/* 育儿卡片暖色 */
.theme-card.child_growth {
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}

.theme-card.child_growth .theme-arrow-btn {
  background: rgba(255,179,0,0.10);
}

/* ========== 弹窗 ========== */
.auth-modal {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-mask {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
  backdrop-filter: blur(4rpx);
}

.auth-content {
  position: relative;
  width: 80%;
  background: #fff;
  border-radius: 28rpx;
  padding: 44rpx 40rpx 50rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c2c2c;
  margin-bottom: 12rpx;
}

.auth-subtitle {
  font-size: 24rpx;
  color: #aaa;
  margin-bottom: 40rpx;
}

.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after { border: none; }

.temp-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f5f5f5;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.avatar-edit-tip {
  font-size: 20rpx;
  color: #e8707a;
  margin-top: 12rpx;
}

.nickname-input-group {
  width: 100%;
  margin-top: 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  width: 80rpx;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 0 10rpx;
}

.auth-actions {
  display: flex;
  width: 100%;
  margin-top: 50rpx;
  justify-content: space-between;
}

.auth-btn {
  width: 45%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
}

.auth-btn::after { border: none; }

.auth-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.auth-btn.confirm {
  background: linear-gradient(135deg, #e8707a, #f0968a);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(232, 112, 122, 0.25);
}

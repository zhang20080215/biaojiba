@import "../../douban/list/list.wxss";

.movie-content {
  min-width: 0;
  align-items: flex-start;
}

.movie-info {
  min-width: 0;
  padding-right: var(--space-2);
}

/* 票房榜电影名常常较长，标题文本允许 2 行 clamp（图标顶端对齐） */
.movie-title {
  align-items: flex-start;
}

.movie-title-text {
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-height: 1.35;
  max-height: calc(1.35em * 2);
}

.movie-action {
  flex: 0 0 auto;
  align-self: center;
}

.movie-boxoffice-tag {
  font-size: var(--font-caption);
  font-weight: 700;
  color: #C4862D;
  background: rgba(254, 239, 191, 0.88);
  padding: 4rpx var(--space-2);
  border-radius: var(--radius-pill);
}

.movie-meta-chip {
  font-size: var(--font-mini);
  font-weight: 600;
  color: var(--text-secondary);
  background: rgba(156, 153, 143, 0.12);
  padding: 4rpx var(--space-2);
  border-radius: var(--radius-pill);
}

.movie-country-chip {
  font-size: var(--font-mini);
  font-weight: 600;
  color: var(--text-primary);
  background: var(--brand-soft);
  padding: 4rpx var(--space-2);
  border-radius: var(--radius-pill);
}

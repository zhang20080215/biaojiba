/* ===== 全球电影票房榜 分享页 — 低饱和暖色主题（参考奥斯卡布局） ===== */

/* ==================== 容器 ==================== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #fdf5f3 0%, #f8f5f0 100%);
  padding: 20rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
  overflow: auto;
}

/* ==================== Canvas ==================== */
.share-canvas {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  transform: scale(0.3);
  transform-origin: top center;
  margin-bottom: 40rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.04);
}

/* ==================== 保存按钮 ==================== */
.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #c0625a 0%, #c8785a 50%, #c49860 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.save-btn[disabled] {
  background: linear-gradient(135deg, #ccc 0%, #999 100%);
  box-shadow: none;
  opacity: 0.6;
}

/* ==================== 广告 ==================== */
.ad-banner-container {
  margin: 20rpx 24rpx 0;
}

/* ==================== 加载状态 ==================== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* ==================== 分享卡片 ==================== */
.share-card {
  background: linear-gradient(160deg, #f5f3f1 0%, #f5f2eb 50%, #f5f1f3 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx 18rpx 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.05), inset 0 1rpx 0 rgba(0, 0, 0, 0.02);
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

/* ==================== 卡片头部 ==================== */
.card-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.card-header-icon {
  font-size: 48rpx;
  filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
}

.card-title-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #c0625a;
  text-align: center;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-subtitle {
  font-size: 20rpx;
  color: rgba(192, 98, 90, 0.4);
  letter-spacing: 2rpx;
  margin-top: 4rpx;
  font-weight: 400;
}

/* 珊瑚色分割线 */
.coral-line {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(192, 98, 90, 0.25) 30%, rgba(196, 152, 96, 0.4) 50%, rgba(192, 98, 90, 0.25) 70%, transparent 100%);
  margin: 0 20rpx 28rpx 20rpx;
}

/* ==================== 统计数据 ==================== */
.stats-container {
  display: flex;
  gap: 16rpx;
  margin-bottom: 36rpx;
  justify-content: center;
}

.stat-item {
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.stat-item.watched {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.12) 0%, rgba(76, 175, 80, 0.06) 100%);
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

.stat-item.wish {
  background: linear-gradient(135deg, rgba(255, 165, 2, 0.12) 0%, rgba(255, 165, 2, 0.06) 100%);
  border: 1rpx solid rgba(255, 165, 2, 0.2);
}

.stat-item.unwatched {
  background: linear-gradient(135deg, rgba(158, 158, 158, 0.12) 0%, rgba(158, 158, 158, 0.05) 100%);
  border: 1rpx solid rgba(158, 158, 158, 0.2);
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
}

.stat-value {
  font-size: 26rpx;
  font-weight: 600;
}

.stat-item.watched .stat-label,
.stat-item.watched .stat-value {
  color: #4CAF50;
}

.stat-item.wish .stat-label,
.stat-item.wish .stat-value {
  color: #FFA502;
}

.stat-item.unwatched .stat-label,
.stat-item.unwatched .stat-value {
  color: #9E9E9E;
}

/* 统计项前的图例小图标 */
.stat-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 6rpx;
  position: relative;
  flex-shrink: 0;
}

.stat-icon.watched {
  background: rgba(76, 175, 80, 0.25);
  border: 1rpx solid rgba(76, 175, 80, 0.5);
}

.stat-icon.wish {
  background: rgba(255, 165, 2, 0.25);
  border: 1rpx solid rgba(255, 165, 2, 0.5);
}

.stat-icon.unwatched {
  background: rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(120, 120, 120, 0.3);
}

.stat-icon-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 18rpx;
  height: 18rpx;
  font-size: 12rpx;
  line-height: 18rpx;
  text-align: center;
  color: #fff;
  background: rgba(76, 175, 80, 0.9);
  border-radius: 50%;
}

.stat-icon-badge.wish {
  background: rgba(255, 165, 2, 0.9);
}

/* ==================== 文字海报网格 ==================== */
.text-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.text-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  padding: 10rpx 4rpx;
  gap: 4rpx;
  overflow: hidden;
  min-width: 0;
}

.text-cell.watched {
  background: linear-gradient(180deg, rgba(76, 175, 80, 0.18) 0%, rgba(76, 175, 80, 0.06) 100%);
  border: 1rpx solid rgba(76, 175, 80, 0.3);
}

.text-cell.wish {
  background: linear-gradient(180deg, rgba(255, 165, 2, 0.18) 0%, rgba(255, 165, 2, 0.06) 100%);
  border: 1rpx solid rgba(255, 165, 2, 0.35);
}

.text-cell.unwatched {
  background: linear-gradient(180deg, rgba(158, 158, 158, 0.12) 0%, rgba(158, 158, 158, 0.04) 100%);
  border: 1rpx solid rgba(158, 158, 158, 0.18);
}

.text-cell-rank {
  font-size: 18rpx;
  font-weight: 400;
}

.text-cell.watched .text-cell-rank { color: rgba(76, 175, 80, 0.6); }
.text-cell.wish .text-cell-rank { color: rgba(255, 165, 2, 0.6); }
.text-cell.unwatched .text-cell-rank { color: rgba(120, 120, 120, 0.7); }

.text-cell-title {
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
}

.text-cell.watched .text-cell-title {
  color: #4CAF50;
  text-decoration: line-through;
  text-decoration-color: rgba(76, 175, 80, 0.5);
}
.text-cell.wish .text-cell-title { color: #FFA502; font-weight: 600; }
.text-cell.unwatched .text-cell-title { color: #888; }

/* ==================== 电影墙预览 ==================== */
.wall-mode {
  padding: 40rpx 16rpx 18rpx 16rpx;
}

.wall-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  margin-bottom: 20rpx;
}

.wall-item {
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  aspect-ratio: 104/150;
}

.wall-poster {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.wall-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}

.wall-overlay.watched {
  background: linear-gradient(180deg, rgba(76, 175, 80, 0.06) 0%, rgba(76, 175, 80, 0.12) 100%);
  border: 1rpx solid rgba(76, 175, 80, 0.3);
  box-sizing: border-box;
}

.wall-overlay.wish {
  background: linear-gradient(180deg, rgba(255, 165, 2, 0.06) 0%, rgba(255, 165, 2, 0.10) 100%);
  border: 1rpx solid rgba(255, 165, 2, 0.3);
  box-sizing: border-box;
}

.wall-overlay.unwatched {
  background: rgba(0, 0, 0, 0.5);
}

.wall-status-icon {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  font-size: 16rpx;
  line-height: 24rpx;
  text-align: center;
  color: #fff;
  background: rgba(76, 175, 80, 0.85);
  border-radius: 50%;
}

.wall-status-icon.wish-icon {
  background: rgba(255, 165, 2, 0.85);
}

.wall-title {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 2rpx 4rpx;
  font-size: 14rpx;
  color: #fff;
  text-align: center;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 海报墙 ==================== */
.poster-wall {
  padding: 40rpx 20rpx 18rpx 20rpx;
}

.poster-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10rpx;
  margin-bottom: 40rpx;
}

.poster-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  aspect-ratio: 2/3;
}

.poster-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ==================== 提示 ==================== */
.empty-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 40rpx 20rpx;
}

/* ==================== 水印 ==================== */
.watermark-text {
  text-align: center;
  font-size: 22rpx;
  color: rgba(100, 100, 100, 0.5);
  padding: 6rpx 10rpx 10rpx;
  letter-spacing: 1rpx;
}

/* ==================== 响应式 ==================== */
@media screen and (max-width: 375px) {
  .card-title {
    font-size: 36rpx;
  }

  .stat-item {
    padding: 10rpx 16rpx;
  }
}

.share-page {
  min-height: 100vh;
  position: relative;
  background: #FFFCF5;
  box-sizing: border-box;
  padding-bottom: calc(208rpx + env(safe-area-inset-bottom));
}

.immersive-top {
  padding-left: var(--space-3);
  padding-right: var(--space-3);
  padding-bottom: var(--space-2);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
}

.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

.top-right {
  width: 56rpx;
  height: 56rpx;
}

.content-wrap {
  padding: 0 var(--space-3);
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100%;
  box-sizing: border-box;
}

.share-card {
  background: linear-gradient(135deg, #F8F3E7 0%, #EEF3E5 55%, #FAECE7 100%);
  border-radius: var(--radius-xl);
  padding: 24rpx 24rpx 18rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  width: 100%;
  box-sizing: border-box;
}

.share-card.poster-wall {
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.share-card.wall-mode {
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  gap: 12rpx;
}

.card-header-icon {
  font-size: 44rpx;
  line-height: 1;
}

.card-title-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.2;
}

.card-subtitle {
  font-size: 20rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
  margin-top: 6rpx;
}

.coral-line {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(156, 153, 143, 0.18) 25%, rgba(182, 202, 235, 0.45) 50%, rgba(156, 153, 143, 0.18) 75%, transparent 100%);
  margin: 0 20rpx 24rpx;
}

.stats-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
  justify-content: center;
}

.stat-item {
  padding: 10rpx 16rpx;
  border-radius: var(--radius-pill);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid transparent;
}

.stat-item.watched {
  border-color: rgba(154, 171, 101, 0.2);
}

.stat-item.wish {
  border-color: rgba(212, 168, 40, 0.2);
}

.stat-item.unwatched {
  border-color: rgba(156, 153, 143, 0.2);
}

.stat-label,
.stat-value {
  font-size: 22rpx;
  font-weight: 600;
}

.stat-item.watched .stat-label,
.stat-item.watched .stat-value {
  color: #9AAB65;
}

.stat-item.wish .stat-label,
.stat-item.wish .stat-value {
  color: #D4A828;
}

.stat-item.unwatched .stat-label,
.stat-item.unwatched .stat-value {
  color: #9C998F;
}

.stat-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 6rpx;
  position: relative;
  flex-shrink: 0;
}

.stat-icon.watched {
  background: rgba(154, 171, 101, 0.18);
  border: 1rpx solid rgba(154, 171, 101, 0.38);
}

.stat-icon.wish {
  background: rgba(212, 168, 40, 0.16);
  border: 1rpx solid rgba(212, 168, 40, 0.34);
}

.stat-icon.unwatched {
  background: rgba(156, 153, 143, 0.12);
  border: 1rpx solid rgba(156, 153, 143, 0.28);
}

.stat-icon-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 18rpx;
  height: 18rpx;
  font-size: 12rpx;
  line-height: 18rpx;
  text-align: center;
  color: #fff;
  background: rgba(154, 171, 101, 0.95);
  border-radius: 50%;
}

.stat-icon-badge.wish {
  background: rgba(212, 168, 40, 0.95);
}

.wall-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  margin-bottom: 20rpx;
}

.wall-item {
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  aspect-ratio: 104 / 150;
}

.wall-poster {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.wall-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.wall-overlay.watched {
  background: linear-gradient(180deg, rgba(154, 171, 101, 0.06) 0%, rgba(154, 171, 101, 0.14) 100%);
  border: 1rpx solid rgba(154, 171, 101, 0.32);
  box-sizing: border-box;
}

.wall-overlay.wish {
  background: linear-gradient(180deg, rgba(212, 168, 40, 0.06) 0%, rgba(212, 168, 40, 0.12) 100%);
  border: 1rpx solid rgba(212, 168, 40, 0.32);
  box-sizing: border-box;
}

.wall-overlay.unwatched {
  background: rgba(45, 45, 43, 0.48);
}

.wall-status-icon {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  font-size: 16rpx;
  line-height: 24rpx;
  text-align: center;
  color: #fff;
  background: rgba(154, 171, 101, 0.92);
  border-radius: 50%;
}

.wall-status-icon.wish-icon {
  background: rgba(212, 168, 40, 0.92);
}

.wall-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 2rpx 4rpx;
  font-size: 14rpx;
  color: #fff;
  text-align: center;
  background: linear-gradient(to top, rgba(45, 45, 43, 0.82) 0%, transparent 100%);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.poster-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10rpx;
  margin-bottom: 28rpx;
}

.poster-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(45, 45, 43, 0.08);
  aspect-ratio: 2 / 3;
  background: rgba(248, 243, 231, 0.9);
}

.poster-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.text-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.text-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  padding: 10rpx 4rpx;
  gap: 4rpx;
  overflow: hidden;
  min-width: 0;
}

.text-cell.watched {
  background: linear-gradient(180deg, rgba(225, 230, 209, 0.92) 0%, rgba(225, 230, 209, 0.55) 100%);
  border: 1rpx solid rgba(154, 171, 101, 0.32);
}

.text-cell.wish {
  background: linear-gradient(180deg, rgba(254, 239, 191, 0.92) 0%, rgba(254, 239, 191, 0.55) 100%);
  border: 1rpx solid rgba(212, 168, 40, 0.32);
}

.text-cell.unwatched {
  background: linear-gradient(180deg, rgba(242, 240, 234, 0.92) 0%, rgba(242, 240, 234, 0.56) 100%);
  border: 1rpx solid rgba(156, 153, 143, 0.18);
}

.text-cell-rank {
  font-size: 18rpx;
  font-weight: 500;
}

.text-cell.watched .text-cell-rank { color: rgba(154, 171, 101, 0.72); }
.text-cell.wish .text-cell-rank { color: rgba(212, 168, 40, 0.72); }
.text-cell.unwatched .text-cell-rank { color: rgba(156, 153, 143, 0.88); }

.text-cell-title {
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
}

.text-cell.watched .text-cell-title {
  color: #7B9A3C;
  text-decoration: line-through;
  text-decoration-color: rgba(123, 154, 60, 0.45);
}

.text-cell.wish .text-cell-title {
  color: #C4862D;
}

.text-cell.unwatched .text-cell-title {
  color: #7F7A70;
}

.empty-tip {
  text-align: center;
  color: var(--text-muted);
  font-size: 24rpx;
  padding: 40rpx 20rpx;
}

.watermark-text {
  text-align: center;
  font-size: 22rpx;
  color: rgba(156, 153, 143, 0.92);
  padding: 6rpx 10rpx 10rpx;
  font-weight: 600;
}

.ad-banner-container {
  margin: 20rpx 24rpx 0;
}

.save-btn-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 252, 245, 0) 0%, rgba(255, 252, 245, 0.92) 28%, rgba(255, 252, 245, 0.98) 100%);
  box-sizing: border-box;
  z-index: 20;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: var(--brand-primary);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: var(--shadow-cta);
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  transform: scale(0.98);
}

.save-btn[disabled] {
  background: linear-gradient(135deg, #d7d0c2 0%, #bdb6a8 100%);
  box-shadow: none;
  opacity: 0.7;
}

.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(45, 45, 43, 0.42);
  backdrop-filter: blur(8px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.28);
  border-top-color: #FFFFFF;
  animation: spin 0.9s linear infinite;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
  margin-top: 20rpx;
  font-weight: 600;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

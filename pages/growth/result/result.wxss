.container {
  padding: 24rpx;
  background: #f5f6fa;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 60rpx;
}

/* 儿童信息摘要 */
.summary-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.gender-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
}

.gender-badge.male {
  background: rgba(52, 152, 219, 0.6);
}

.gender-badge.female {
  background: rgba(233, 30, 140, 0.6);
}

.summary-info {
  flex: 1;
}

.summary-age {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.summary-metrics {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.dot {
  margin: 0 8rpx;
}

/* 营养状况卡片 */
.nutrition-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.nutrition-items {
  display: flex;
  gap: 16rpx;
}

.nutrition-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.nutrition-label {
  display: block;
  font-size: 22rpx;
  color: #95a5a6;
  margin-bottom: 8rpx;
}

.nutrition-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.nutrition-value.normal {
  color: #27ae60;
}

.nutrition-value.mild {
  color: #f39c12;
}

.nutrition-value.warning {
  color: #e74c3c;
}

/* 评估区间折叠 */
.range-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 0;
  margin-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.range-toggle-text {
  font-size: 24rpx;
  color: #999;
}

.range-toggle-arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
  transition: transform 0.3s;
  display: inline-block;
  transform: rotate(0deg);
}

.range-toggle-arrow.expanded {
  transform: rotate(90deg);
}

/* 评估区间表格 */
.range-section {
  margin-top: 20rpx;
  padding-top: 8rpx;
}

.range-table {
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.range-header {
  display: flex;
  background: #f8f9fa;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eee;
}

.range-th {
  font-size: 22rpx;
  color: #666;
  font-weight: 600;
  text-align: center;
}

.range-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.range-row:last-child {
  border-bottom: none;
}

.range-row.highlight {
  background: #f0faf4;
}

.range-td {
  font-size: 22rpx;
  color: #333;
  text-align: center;
}

.col-range {
  width: 34%;
  flex-shrink: 0;
}

.col-weight,
.col-height,
.col-body {
  width: 22%;
  flex-shrink: 0;
}

.range-td.normal {
  color: #27ae60;
  font-weight: 600;
}

.range-td.mild {
  color: #f39c12;
}

.range-td.warning {
  color: #e74c3c;
}

.range-note {
  display: block;
  font-size: 20rpx;
  color: #aaa;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 指标卡片 */
.indicator-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.indicator-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.indicator-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
}

.indicator-sub-name {
  font-size: 24rpx;
  font-weight: 400;
  color: #95a5a6;
}

.level-badge {
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

/* 百分位数 */
.percentile-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.percentile-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2c3e50;
}

.percentile-desc {
  font-size: 24rpx;
  color: #95a5a6;
}

/* 百分位条形图 */
.percentile-bar-container {
  margin-bottom: 16rpx;
}

.percentile-bar {
  position: relative;
  height: 24rpx;
  border-radius: 12rpx;
  overflow: visible;
}

.bar-zones {
  display: flex;
  height: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.zone {
  height: 100%;
}

.zone-low {
  background: #e74c3c;
}

.zone-below {
  background: #f39c12;
}

.zone-normal {
  background: #27ae60;
}

.zone-above {
  background: #f39c12;
}

.zone-high {
  background: #e74c3c;
}

.bar-marker {
  position: absolute;
  top: -8rpx;
  transform: translateX(-50%);
}

.marker-dot {
  width: 20rpx;
  height: 40rpx;
  background: #2c3e50;
  border-radius: 10rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.bar-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #bdc3c7;
  padding: 0 0;
}

/* 详细信息 */
.indicator-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-item {
  font-size: 24rpx;
  color: #7f8c8d;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.action-btn.secondary {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

/* 参考说明 */
.reference {
  margin-top: 32rpx;
  padding: 0 20rpx;
}

.ref-text {
  display: block;
  font-size: 22rpx;
  color: #bdc3c7;
  line-height: 1.8;
  text-align: center;
}

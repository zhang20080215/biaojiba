/* 结果页 - 男女主题化 */
.container {
  padding: 0 0 60rpx;
  background: #f2f4f8;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ========== 顶部 Summary 卡片 ========== */
.summary-card {
  background: linear-gradient(135deg, #667eea 0%, #5b7bd5 60%, #7c63d8 100%);
  padding: 48rpx 32rpx 32rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.summary-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.07);
  border-radius: 50%;
}

.theme-female .summary-card {
  background: linear-gradient(135deg, #f093fb 0%, #d6409f 60%, #e06db0 100%);
}

.summary-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.gender-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.gender-badge.male {
  background: rgba(52,152,219,0.4);
}

.gender-badge.female {
  background: rgba(255,255,255,0.25);
}

.gender-icon-text {
  font-size: 40rpx;
  color: #fff;
}

.summary-info {
  flex: 1;
  min-width: 0;
}

.summary-age {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.summary-metrics {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.dot {
  margin: 0 6rpx;
}

/* 营养 chips */
.nutrition-chips {
  display: flex;
  gap: 14rpx;
}

.chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 8rpx;
  border-radius: 16rpx;
}

.chip-normal {
  background: rgba(16,185,129,0.25);
  border: 1rpx solid rgba(16,185,129,0.4);
}

.chip-mild {
  background: rgba(251,191,36,0.25);
  border: 1rpx solid rgba(251,191,36,0.4);
}

.chip-warn {
  background: rgba(248,113,113,0.25);
  border: 1rpx solid rgba(248,113,113,0.4);
}

.chip-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
  margin-bottom: 6rpx;
}

.chip-val {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

/* ========== 通用section卡片 ========== */
.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}

/* ========== 评估区间卡片 ========== */
.range-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.range-toggle-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
}

.range-toggle-arrow {
  font-size: 36rpx;
  color: #b0b8c4;
  font-weight: 700;
  transition: transform 0.3s;
  display: inline-block;
  transform: rotate(0deg);
}

.range-toggle-arrow.expanded {
  transform: rotate(90deg);
}

.range-section {
  margin-top: 20rpx;
}

.range-table {
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eef0f4;
}

.range-header {
  display: flex;
  background: #f8f9fc;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef0f4;
}

.range-th {
  font-size: 21rpx;
  color: #666;
  font-weight: 600;
  text-align: center;
}

.range-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f6f8;
}

.range-row:last-child { border-bottom: none; }

.range-row.highlight { background: #f0fdf4; }

.range-td {
  font-size: 21rpx;
  color: #333;
  text-align: center;
}

.col-range { width: 36%; flex-shrink: 0; }
.col-weight, .col-height, .col-body { width: 21.3%; flex-shrink: 0; }

.range-td.normal { color: #10b981; font-weight: 600; }
.range-td.mild { color: #f59e0b; }
.range-td.warn { color: #ef4444; }

.range-note {
  display: block;
  font-size: 20rpx;
  color: #b0b8c4;
  margin-top: 14rpx;
  line-height: 1.5;
  text-align: center;
}

/* ========== 指标卡片 ========== */
.indicator-card {
  padding: 28rpx;
}

.indicator-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.indicator-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1f36;
}

.level-badge {
  padding: 6rpx 22rpx;
  border-radius: 20rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

/* 百分位大数字 */
.percentile-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.percentile-value {
  font-size: 52rpx;
  font-weight: 800;
  color: #1a1f36;
  line-height: 1;
}

.percentile-desc {
  font-size: 23rpx;
  color: #9ca3af;
}

/* 百分位彩虹条 */
.bar-wrap {
  margin-bottom: 18rpx;
}

.bar-track {
  position: relative;
  height: 22rpx;
  border-radius: 11rpx;
  overflow: visible;
  margin-bottom: 6rpx;
}

.bar-zones {
  display: flex;
  height: 100%;
  border-radius: 11rpx;
  overflow: hidden;
}

.zone { height: 100%; }
.zone-red    { background: #ef4444; }
.zone-orange { background: #f59e0b; }
.zone-green  { background: #10b981; }

/* 标记点 */
.bar-marker {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
}

.marker-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #1a1f36;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

/* 标签行（绝对定位） */
.bar-labels {
  position: relative;
  height: 28rpx;
  margin-top: 8rpx;
}

.bar-labels text {
  position: absolute;
  font-size: 19rpx;
  color: #c4cad4;
  transform: translateX(-50%);
}

/* 详细数值 */
.indicator-detail {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f2f4f8;
}

.detail-item {
  font-size: 22rpx;
  color: #9ca3af;
}

.detail-sep {
  font-size: 22rpx;
  color: #d1d5db;
}

/* ========== 操作按钮 ========== */
.actions {
  display: flex;
  gap: 20rpx;
  margin: 8rpx 20rpx 0;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.action-btn.secondary {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.theme-female .action-btn.secondary {
  color: #d6409f;
  border-color: #d6409f;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea, #5b7bd5);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.35);
}

.theme-female .action-btn.primary {
  background: linear-gradient(135deg, #f093fb, #d6409f);
  box-shadow: 0 8rpx 24rpx rgba(214,64,159,0.35);
}

/* ========== 参考说明 ========== */
.reference {
  margin-top: 32rpx;
  padding: 0 20rpx;
}

.ref-text {
  display: block;
  font-size: 21rpx;
  color: #c4cad4;
  line-height: 1.8;
  text-align: center;
}

<view class="container {{input.gender === 'female' ? 'theme-female' : 'theme-male'}}" wx:if="{{input}}">

  <!-- 顶部信息卡片（含营养评价chip） -->
  <view class="summary-card">
    <view class="summary-top">
      <view class="gender-badge {{input.gender}}">
        <text class="gender-icon-text">{{genderIcon}}</text>
      </view>
      <view class="summary-info">
        <text class="summary-age">{{ageText}}</text>
        <view class="summary-metrics">
          <text>体重 {{input.weight}}kg</text>
          <text class="dot">·</text>
          <text>{{input.ageMonths < 24 ? '身长' : '身高'}} {{input.height}}cm</text>
          <block wx:if="{{input.headCirc}}">
            <text class="dot">·</text>
            <text>头围 {{input.headCirc}}cm</text>
          </block>
        </view>
      </view>
    </view>

    <!-- 营养评价chip行 -->
    <view class="nutrition-chips" wx:if="{{nutrition}}">
      <view class="chip {{nutrition.weightStatus === '正常' ? 'chip-normal' : (nutrition.weightStatus.indexOf('略') >= 0 ? 'chip-mild' : 'chip-warn')}}">
        <text class="chip-label">体重</text>
        <text class="chip-val">{{nutrition.weightStatus}}</text>
      </view>
      <view class="chip {{nutrition.heightStatus === '正常' ? 'chip-normal' : (nutrition.heightStatus.indexOf('略') >= 0 ? 'chip-mild' : 'chip-warn')}}">
        <text class="chip-label">身高</text>
        <text class="chip-val">{{nutrition.heightStatus}}</text>
      </view>
      <view class="chip {{nutrition.bodyStatus === '正常' ? 'chip-normal' : (nutrition.bodyStatus === '偏瘦' || nutrition.bodyStatus === '超重' ? 'chip-mild' : 'chip-warn')}}">
        <text class="chip-label">体型</text>
        <text class="chip-val">{{nutrition.bodyStatus}}</text>
      </view>
    </view>
  </view>

  <!-- 评估标准说明（折叠） -->
  <view class="section-card range-card">
    <view class="range-toggle" bindtap="onToggleRange">
      <text class="range-toggle-text">发育状况评估标准说明</text>
      <text class="range-toggle-arrow {{showRange ? 'expanded' : ''}}">›</text>
    </view>
    <view wx:if="{{showRange}}" class="range-section">
      <view class="range-table">
        <view class="range-header">
          <text class="range-th col-range">百分位区间</text>
          <text class="range-th col-weight">体重</text>
          <text class="range-th col-height">身高</text>
          <text class="range-th col-body">体型(BMI)</text>
        </view>
        <view class="range-row"><text class="range-td col-range">&lt; 0.1%</text><text class="range-td col-weight warn">重度偏轻</text><text class="range-td col-height warn">重度偏矮</text><text class="range-td col-body warn">重度消瘦</text></view>
        <view class="range-row"><text class="range-td col-range">0.1%~2.3%</text><text class="range-td col-weight warn">偏轻</text><text class="range-td col-height warn">偏矮</text><text class="range-td col-body warn">消瘦</text></view>
        <view class="range-row"><text class="range-td col-range">2.3%~15.9%</text><text class="range-td col-weight mild">略偏轻</text><text class="range-td col-height mild">略偏矮</text><text class="range-td col-body mild">偏瘦</text></view>
        <view class="range-row highlight"><text class="range-td col-range">15.9%~84.1%</text><text class="range-td col-weight normal">正常</text><text class="range-td col-height normal">正常</text><text class="range-td col-body normal">正常</text></view>
        <view class="range-row"><text class="range-td col-range">84.1%~97.7%</text><text class="range-td col-weight mild">略偏重</text><text class="range-td col-height mild">略偏高</text><text class="range-td col-body mild">超重</text></view>
        <view class="range-row"><text class="range-td col-range">97.7%~99.9%</text><text class="range-td col-weight warn">偏重</text><text class="range-td col-height warn">偏高</text><text class="range-td col-body warn">肥胖</text></view>
        <view class="range-row"><text class="range-td col-range">&gt; 99.9%</text><text class="range-td col-weight warn">明显偏重</text><text class="range-td col-height warn">明显偏高</text><text class="range-td col-body warn">重度肥胖</text></view>
      </view>
      <text class="range-note">依据 WS/T 423-2022 标准差法（Z-score）评估</text>
    </view>
  </view>

  <!-- 各指标详情卡片 -->
  <view class="section-card indicator-card" wx:for="{{indicators}}" wx:key="name">
    <view class="indicator-header">
      <text class="indicator-name">{{item.name}}</text>
      <view class="level-badge" style="background: {{item.color}}">
        <text>{{item.level}}</text>
      </view>
    </view>

    <!-- 百分位大数字 -->
    <view class="percentile-row">
      <text class="percentile-value">{{item.percentile}}%</text>
      <text class="percentile-desc">超过{{item.percentile}}%的同龄儿童</text>
    </view>

    <!-- 百分位彩虹条（WS/T 423-2022 区间） -->
    <view class="bar-wrap">
      <view class="bar-track">
        <view class="bar-zones">
          <!-- 2.3% / 13.6% / 68.2% / 13.6% / 2.3% -->
          <view class="zone zone-red" style="width:2.3%"></view>
          <view class="zone zone-orange" style="width:13.6%"></view>
          <view class="zone zone-green" style="width:68.2%"></view>
          <view class="zone zone-orange" style="width:13.6%"></view>
          <view class="zone zone-red" style="width:2.3%"></view>
        </view>
        <view class="bar-marker" style="left:{{item.percentile > 99 ? 99 : (item.percentile < 1 ? 1 : item.percentile)}}%">
          <view class="marker-dot"></view>
        </view>
      </view>
      <!-- 标签：对应实际百分位分界 -->
      <view class="bar-labels">
        <text style="left:2.3%">2.3%</text>
        <text style="left:15.9%">15.9%</text>
        <text style="left:50%">50%</text>
        <text style="left:84.1%">84.1%</text>
        <text style="left:97.7%">97.7%</text>
      </view>
    </view>

    <!-- 详细数值 -->
    <view class="indicator-detail">
      <text class="detail-item">测量值 {{item.value}}{{item.unit}}</text>
      <text class="detail-sep">·</text>
      <text class="detail-item">中位数 {{item.median}}{{item.unit}}</text>
      <text class="detail-sep">·</text>
      <text class="detail-item">Z值 {{item.zScore}}</text>
    </view>
  </view>

  <!-- 离屏 Canvas -->
  <canvas type="2d" id="posterCanvas" style="width:1242px;height:1660px;position:fixed;left:-9999px;top:-9999px;"></canvas>

  <!-- 操作按钮 -->
  <view class="actions">
    <view class="action-btn secondary" bindtap="onBackTap">
      <text>重新评估</text>
    </view>
    <view class="action-btn primary" bindtap="onSavePoster">
      <text>{{isGenerating ? '生成中...' : '保存海报'}}</text>
    </view>
  </view>

  <!-- 参考说明 -->
  <view class="reference">
    <text class="ref-text">参考标准：WS/T 423-2022《7岁以下儿童生长标准》</text>
    <text class="ref-text">评价方法：标准差法（Z-score），精确百分位数换算</text>
  </view>

</view>

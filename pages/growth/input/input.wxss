.container {
  min-height: 100vh;
  background: #f2f4f8;
  box-sizing: border-box;
  padding-bottom: 60rpx;
}

/* ========== 标题卡片 ========== */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #5b7bd5 60%, #7c63d8 100%);
  padding: 56rpx 40rpx 44rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}

.theme-female .header-card {
  background: linear-gradient(135deg, #f093fb 0%, #d6409f 60%, #e06db0 100%);
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.header-standard {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.82);
  line-height: 1.6;
}

.header-badges {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.header-badge {
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  border: 1rpx solid rgba(255,255,255,0.35);
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
  white-space: nowrap;
}

/* ========== 表单卡片 ========== */
.form-card {
  background: #fff;
  border-radius: 0 0 24rpx 24rpx;
  padding: 0 32rpx;
  margin-bottom: 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}

.form-row.no-border {
  border-bottom: none;
}

/* 含提示的行容器 */
.form-row-wrap {
  border-bottom: 1rpx solid #f2f3f5;
}

.form-row-wrap .form-row {
  border-bottom: none;
  padding-bottom: 4rpx;
}

/* 字段提示 */
.field-hint {
  display: block;
  font-size: 21rpx;
  color: #b0b8c4;
  padding: 0 0 18rpx 124rpx;
  line-height: 1.4;
}

/* 标准标签 */
.form-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  width: 120rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

/* 头围行标签（flex横排，图标+文字+badge） */
.form-label-row {
  width: 120rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.form-label-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
}

.optional-badge {
  font-size: 18rpx;
  color: #fff;
  background: #c8cdd8;
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
  white-space: nowrap;
  line-height: 1.4;
}

/* ========== 性别选择 ========== */
.gender-group {
  display: flex;
  gap: 20rpx;
  flex: 1;
}

.gender-btn {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 76rpx;
  border-radius: 14rpx;
  border: 2rpx solid #e0e4ec;
  background: #f8f9fc;
  transition: all 0.2s;
}

.gender-btn.active.male {
  border-color: #5b7bd5;
  background: #eef2ff;
}

.gender-btn.active.female {
  border-color: #d6409f;
  background: #fde8f4;
}

.gender-icon {
  font-size: 34rpx;
  line-height: 1;
  /* 不设置宽高，让flex自然对齐 */
}

.gender-btn.active.male .gender-icon {
  color: #5b7bd5;
}

.gender-btn.active.female .gender-icon {
  color: #d6409f;
}

.gender-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
  line-height: 1;
}

.gender-btn.active.male .gender-text {
  color: #5b7bd5;
}

.gender-btn.active.female .gender-text {
  color: #d6409f;
}

/* ========== 年龄选择 ========== */
.age-picker-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
  border: 2rpx solid #e0e4ec;
  min-width: 100rpx;
}

.picker-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  white-space: nowrap;
}

.picker-arrow {
  font-size: 20rpx;
  color: #b0b8c4;
}

.age-display {
  font-size: 23rpx;
  color: #b0b8c4;
  white-space: nowrap;
}

/* ========== 输入框 ========== */
.input-box {
  display: flex;
  align-items: center;
  flex: 1;
  height: 76rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
  border: 2rpx solid #e0e4ec;
  padding: 0 24rpx;
}

.theme-female .input-box {
  border-color: #f5d0e8;
}

.theme-female .picker-box {
  border-color: #f5d0e8;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #2c3e50;
}

.input-unit {
  font-size: 26rpx;
  color: #b0b8c4;
  margin-left: 8rpx;
  white-space: nowrap;
}

/* ========== 提交按钮 ========== */
.submit-btn {
  margin: 40rpx 32rpx 0;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea, #5b7bd5);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(102,126,234,0.36);
  transition: all 0.3s;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 14rpx rgba(102,126,234,0.3);
}

.theme-female .submit-btn {
  background: linear-gradient(135deg, #f093fb, #d6409f);
  box-shadow: 0 8rpx 28rpx rgba(214,64,159,0.36);
}

.submit-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
}

<view class="container {{gender === 'female' ? 'theme-female' : 'theme-male'}}">

  <!-- 标题卡片 -->
  <view class="header-card">
    <text class="header-title">儿童生长发育评估</text>
    <text class="header-standard">依据中华人民共和国国家卫生健康委员会</text>
    <text class="header-standard">WS/T 423—2022《7岁以下儿童生长标准》</text>
    <view class="header-badges">
      <text class="header-badge">适用范围：0~7岁</text>
      <text class="header-badge">国家标准</text>
    </view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">

    <!-- 性别 -->
    <view class="form-row">
      <text class="form-label">性别</text>
      <view class="gender-group">
        <view class="gender-btn {{gender === 'male' ? 'active male' : ''}}" data-gender="male" bindtap="onGenderTap">
          <text class="gender-icon">♂</text>
          <text class="gender-text">男</text>
        </view>
        <view class="gender-btn {{gender === 'female' ? 'active female' : ''}}" data-gender="female" bindtap="onGenderTap">
          <text class="gender-icon">♀</text>
          <text class="gender-text">女</text>
        </view>
      </view>
    </view>

    <!-- 年龄 -->
    <view class="form-row">
      <text class="form-label">年龄</text>
      <view class="age-picker-row">
        <picker mode="selector" range="{{yearRange}}" value="{{yearIndex}}" bindchange="onYearChange">
          <view class="picker-box">
            <text class="picker-value">{{yearRange[yearIndex]}}</text>
            <text class="picker-arrow">▾</text>
          </view>
        </picker>
        <picker mode="selector" range="{{monthRange}}" value="{{monthIndex}}" bindchange="onMonthChange">
          <view class="picker-box">
            <text class="picker-value">{{monthRange[monthIndex]}}</text>
            <text class="picker-arrow">▾</text>
          </view>
        </picker>
        <text class="age-display">= {{ageText}}</text>
      </view>
    </view>

    <!-- 体重 -->
    <view class="form-row">
      <text class="form-label">体重</text>
      <view class="input-box">
        <input type="digit" class="input-field" placeholder="请输入" value="{{weight}}" bindinput="onWeightInput" />
        <text class="input-unit">kg</text>
      </view>
    </view>

    <!-- 身高（含提示行） -->
    <view class="form-row-wrap">
      <view class="form-row no-border">
        <text class="form-label">身高</text>
        <view class="input-box">
          <input type="digit" class="input-field" placeholder="请输入" value="{{height}}" bindinput="onHeightInput" />
          <text class="input-unit">cm</text>
        </view>
      </view>
      <text class="field-hint">· 2岁以下测量卧位身长，2岁及以上测量站立身高</text>
    </view>

    <!-- 头围（3岁以下可选） -->
    <view class="form-row no-border" wx:if="{{showHeadCirc}}">
      <view class="form-label-row">
        <text class="form-label-text">头围</text>
        <text class="optional-badge">选填</text>
      </view>
      <view class="input-box">
        <input type="digit" class="input-field" placeholder="请输入" value="{{headCirc}}" bindinput="onHeadCircInput" />
        <text class="input-unit">cm</text>
      </view>
    </view>

  </view>

  <!-- 提交按钮 -->
  <view class="submit-btn" bindtap="onSubmit">
    <text class="submit-text">开始评估</text>
  </view>

</view>

.container {
  min-height: 100vh;
  background: #f5f6fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.preview-hint {
  margin-bottom: 60rpx;
  font-size: 28rpx;
  color: #95a5a6;
}

.save-btn-container {
  width: 100%;
  padding: 0 40rpx;
}

.save-btn {
  width: 100%;
  min-height: 96rpx;
  padding: 14rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  letter-spacing: 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1.3;
}

.save-btn[disabled] {
  background: #bdc3c7;
}

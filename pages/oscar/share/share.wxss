/* ===== 奥斯卡分享页 — 黑金典礼风格 ===== */

/* ==================== 容器 ==================== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 100%);
  padding: 20rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
  overflow: auto;
}

/* ==================== Canvas ==================== */
.share-canvas {
  background: #1a1a1a;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  transform: scale(0.3);
  transform-origin: top center;
  margin-bottom: 40rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.15);
}

/* ==================== 保存按钮 ==================== */
.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #b8960c 0%, #d4af37 30%, #f5d98a 50%, #d4af37 70%, #b8960c 100%);
  color: #1a1a1a;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(212, 175, 55, 0.35);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(212, 175, 55, 0.25);
}

.save-btn[disabled] {
  background: linear-gradient(135deg, #333 0%, #444 100%);
  box-shadow: none;
  opacity: 0.6;
  color: #999;
}

/* ==================== 加载状态 ==================== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-text {
  color: #f5d98a;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* ==================== 分享卡片 ==================== */
.share-card {
  background: linear-gradient(160deg, #1a1a1a 0%, #252525 50%, #1e1e1e 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx 18rpx 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.4), inset 0 1rpx 0 rgba(212, 175, 55, 0.1);
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(212, 175, 55, 0.12);
}

/* ==================== 卡片头部 ==================== */
.card-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.card-oscar-icon {
  width: 56rpx;
  height: 56rpx;
  filter: drop-shadow(0 2px 4px rgba(212, 175, 55, 0.5));
}

.card-title-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #f5d98a;
  text-align: center;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(212, 175, 55, 0.3);
}

.card-subtitle {
  font-size: 20rpx;
  color: rgba(212, 175, 55, 0.5);
  letter-spacing: 2rpx;
  margin-top: 4rpx;
  font-weight: 400;
}

/* 金色分割线 */
.gold-line {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(212, 175, 55, 0.4) 30%, rgba(245, 217, 138, 0.6) 50%, rgba(212, 175, 55, 0.4) 70%, transparent 100%);
  margin: 0 20rpx 28rpx 20rpx;
}

/* ==================== 统计数据 ==================== */
.stats-container {
  display: flex;
  gap: 16rpx;
  margin-bottom: 36rpx;
  justify-content: center;
}

.stat-item {
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.stat-item.watched {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.2) 0%, rgba(212, 175, 55, 0.08) 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.25);
}

.stat-item.wish {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.18) 0%, rgba(255, 193, 7, 0.06) 100%);
  border: 1rpx solid rgba(255, 193, 7, 0.25);
}

.stat-item.unwatched {
  background: linear-gradient(135deg, rgba(158, 158, 158, 0.15) 0%, rgba(158, 158, 158, 0.05) 100%);
  border: 1rpx solid rgba(158, 158, 158, 0.2);
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
}

.stat-value {
  font-size: 26rpx;
  font-weight: 600;
}

.stat-item.watched .stat-label,
.stat-item.watched .stat-value {
  color: #e5c05c;
}

.stat-item.wish .stat-label,
.stat-item.wish .stat-value {
  color: #ffd54f;
}

.stat-item.unwatched .stat-label,
.stat-item.unwatched .stat-value {
  color: #888;
}

/* 统计项前的图例小图标 */
.stat-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 6rpx;
  position: relative;
  flex-shrink: 0;
}

.stat-icon.watched {
  background: rgba(212, 175, 55, 0.35);
  border: 1rpx solid rgba(212, 175, 55, 0.7);
}

.stat-icon.wish {
  background: rgba(255, 193, 7, 0.3);
  border: 1rpx solid rgba(255, 193, 7, 0.6);
}

.stat-icon.unwatched {
  background: rgba(0, 0, 0, 0.55);
  border: 1rpx solid rgba(120, 120, 120, 0.4);
}

.stat-icon-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 18rpx;
  height: 18rpx;
  font-size: 12rpx;
  line-height: 18rpx;
  text-align: center;
  color: #fff;
  background: rgba(212, 175, 55, 0.9);
  border-radius: 50%;
}

.stat-icon-badge.wish {
  background: rgba(255, 193, 7, 0.9);
}

/* ==================== 文字海报网格 ==================== */
.text-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.text-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  padding: 10rpx 4rpx;
  gap: 4rpx;
  overflow: hidden;
  min-width: 0;
}

.text-cell.watched {
  background: linear-gradient(180deg, rgba(212, 175, 55, 0.22) 0%, rgba(212, 175, 55, 0.08) 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.4);
}

.text-cell.wish {
  background: linear-gradient(180deg, rgba(255, 193, 7, 0.20) 0%, rgba(255, 193, 7, 0.08) 100%);
  border: 1rpx solid rgba(255, 193, 7, 0.45);
}

.text-cell.unwatched {
  background: linear-gradient(180deg, rgba(120, 120, 120, 0.14) 0%, rgba(120, 120, 120, 0.05) 100%);
  border: 1rpx solid rgba(120, 120, 120, 0.22);
}

.text-cell-year {
  font-size: 18rpx;
  font-weight: 400;
}

.text-cell.watched .text-cell-year { color: rgba(212, 175, 55, 0.55); }
.text-cell.wish .text-cell-year { color: rgba(255, 193, 7, 0.55); }
.text-cell.unwatched .text-cell-year { color: rgba(180, 180, 180, 0.45); }

.text-cell-title {
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
}

.text-cell.watched .text-cell-title {
  color: #d4af37;
  text-decoration: line-through;
  text-decoration-color: rgba(212, 175, 55, 0.5);
}
.text-cell.wish .text-cell-title { color: #FFC107; font-weight: 600; }
.text-cell.unwatched .text-cell-title { color: #BDBDBD; }

/* ==================== 电影墙预览 ==================== */
.wall-mode {
  padding: 40rpx 16rpx 18rpx 16rpx;
}

.wall-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  margin-bottom: 20rpx;
}

.wall-item {
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  aspect-ratio: 104/150;
}

.wall-poster {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.wall-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}

.wall-overlay.watched {
  background: linear-gradient(180deg, rgba(212, 175, 55, 0.08) 0%, rgba(212, 175, 55, 0.15) 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.35);
  box-sizing: border-box;
}

.wall-overlay.wish {
  background: linear-gradient(180deg, rgba(255, 193, 7, 0.08) 0%, rgba(255, 193, 7, 0.12) 100%);
  border: 1rpx solid rgba(255, 193, 7, 0.35);
  box-sizing: border-box;
}

.wall-overlay.unwatched {
  background: rgba(0, 0, 0, 0.55);
}

.wall-status-icon {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  font-size: 16rpx;
  line-height: 24rpx;
  text-align: center;
  color: #fff;
  background: rgba(212, 175, 55, 0.85);
  border-radius: 50%;
}

.wall-status-icon.wish-icon {
  background: rgba(255, 193, 7, 0.85);
}

.wall-title {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 2rpx 4rpx;
  font-size: 14rpx;
  color: #fff;
  text-align: center;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 海报墙 ==================== */
.poster-wall {
  padding: 40rpx 20rpx 18rpx 20rpx;
}

.poster-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10rpx;
  margin-bottom: 40rpx;
}

.poster-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
  aspect-ratio: 2/3;
  border: 1rpx solid rgba(212, 175, 55, 0.08);
}

.poster-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.poster-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.85), transparent);
  color: #f5d98a;
  font-size: 20rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 提示 ==================== */
.empty-tip {
  text-align: center;
  color: #666;
  font-size: 24rpx;
  padding: 40rpx 20rpx;
}

.more-tip {
  text-align: center;
  color: #888;
  font-size: 20rpx;
  padding: 20rpx;
  background: rgba(212, 175, 55, 0.05);
  border-radius: 12rpx;
  margin-top: 10rpx;
}

/* ==================== 水印 ==================== */
.watermark-text {
  text-align: center;
  font-size: 22rpx;
  color: rgba(200, 200, 200, 0.4);
  padding: 6rpx 10rpx 10rpx;
  letter-spacing: 1rpx;
}

/* ==================== 响应式 ==================== */
@media screen and (max-width: 375px) {
  .card-title {
    font-size: 36rpx;
  }

  .stat-item {
    padding: 10rpx 16rpx;
  }

  .movie-tag {
    font-size: 20rpx;
    padding: 6rpx 12rpx;
  }
}

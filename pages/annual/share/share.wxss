/* 2026 年度院线电影海报生成页样式 - 蓝色主题 */

/* ==================== 容器样式 ==================== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  padding: 20rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
  overflow: auto;
}

/* ==================== Canvas 画布样式 ==================== */
.share-canvas {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  transform: scale(0.3);
  transform-origin: top center;
  margin-bottom: 40rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
}

/* ==================== 操作按钮区域 ==================== */
.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 18rpx 38rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4a90d9 0%, #3570a8 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.save-btn[disabled] {
  background: linear-gradient(135deg, #ccc 0%, #999 100%);
  box-shadow: none;
  opacity: 0.6;
}

/* ==================== 广告 ==================== */
.ad-banner-container {
  margin: 20rpx 24rpx 0;
}

/* ==================== 加载状态 ==================== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* ==================== 分享卡片样式 ==================== */
.share-card {
  background: linear-gradient(135deg, #dce8f5 0%, #e8dff5 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx 18rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* ==================== 个人信息栏 ==================== */
.profile-bar {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #eee;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.nickname {
  font-size: 36rpx;
  color: #2c3e50;
  font-weight: bold;
}

/* ==================== 卡片标题 ==================== */
.card-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #2c3e50;
  text-align: center;
  margin-bottom: 36rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
  letter-spacing: 1rpx;
}

/* ==================== 统计数据 ==================== */
.stats-container {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
  justify-content: center;
}

.stat-item {
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.stat-item.watched {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.12) 0%, rgba(76, 175, 80, 0.08) 100%);
  border-color: rgba(76, 175, 80, 0.2);
}

.stat-item.wish {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.12) 0%, rgba(255, 193, 7, 0.08) 100%);
  border-color: rgba(255, 193, 7, 0.2);
}

.stat-item.unwatched {
  background: linear-gradient(135deg, rgba(158, 158, 158, 0.12) 0%, rgba(158, 158, 158, 0.08) 100%);
  border-color: rgba(158, 158, 158, 0.2);
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
}

.stat-value {
  font-size: 26rpx;
  font-weight: 600;
}

.stat-item.watched .stat-label,
.stat-item.watched .stat-value {
  color: #4CAF50;
}

.stat-item.wish .stat-label,
.stat-item.wish .stat-value {
  color: #FF8F00;
}

.stat-item.unwatched .stat-label,
.stat-item.unwatched .stat-value {
  color: #9E9E9E;
}

/* ==================== 电影标签网格 ==================== */
.movie-grid {
  flex-wrap: wrap;
  margin-bottom: 40rpx;
  position: relative;
  padding: 20rpx;
  border-radius: 16rpx;
}

/* ==================== 电影标签 ==================== */
.movie-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.movie-tag {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  transition: all 0.2s ease;
}

.movie-tag.watched {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.15) 0%, rgba(76, 175, 80, 0.08) 100%);
  color: #4CAF50;
  border-color: rgba(76, 175, 80, 0.3);
  text-decoration: line-through;
  text-decoration-thickness: 2rpx;
}

.movie-tag.wish {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.2) 0%, rgba(255, 193, 7, 0.12) 100%);
  color: #FF8F00;
  border-color: rgba(255, 193, 7, 0.4);
  font-weight: 600;
}

.movie-tag.unwatched {
  background: linear-gradient(135deg, rgba(158, 158, 158, 0.12) 0%, rgba(158, 158, 158, 0.06) 100%);
  color: #9E9E9E;
  border-color: rgba(158, 158, 158, 0.3);
}

/* ==================== 海报墙样式 ==================== */
.poster-wall {
  padding: 40rpx 20rpx 18rpx 20rpx;
}

.poster-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 40rpx;
}

.poster-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  aspect-ratio: 2/3;
}

.poster-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.poster-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
  color: white;
  font-size: 20rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 提示信息 ==================== */
.empty-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 40rpx 20rpx;
}

.more-tip {
  text-align: center;
  color: #666;
  font-size: 20rpx;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 12rpx;
  margin-top: 10rpx;
}

/* ==================== 卡片底部 ==================== */
.card-footer {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 16rpx 10rpx;
  margin-top: 20rpx;
  opacity: 0.8;
}

/* ==================== 响应式适配 ==================== */
@media screen and (max-width: 375px) {
  .card-title {
    font-size: 40rpx;
  }

  .stat-item {
    padding: 10rpx 16rpx;
  }

  .movie-tag {
    font-size: 20rpx;
    padding: 6rpx 12rpx;
  }
}

/* ==================== 预览水印 ==================== */
.watermark-text {
  text-align: center;
  font-size: 22rpx;
  color: rgba(100, 100, 100, 0.6);
  padding: 6rpx 10rpx 10rpx;
  letter-spacing: 1rpx;
}

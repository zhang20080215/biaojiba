page {
  background:
    radial-gradient(circle at top left, rgba(196, 220, 192, 0.42), transparent 36%),
    linear-gradient(180deg, #f4f1e7 0%, #f8f7f2 34%, #fbfaf6 100%);
  min-height: 100vh;
  color: #24302b;
}

.page-root {
  padding: 24rpx 24rpx 56rpx;
}

.hero-section {
  position: relative;
  overflow: hidden;
  padding: 28rpx 28rpx 32rpx;
  border-radius: 36rpx;
  background:
    linear-gradient(140deg, rgba(31, 57, 47, 0.96) 0%, rgba(55, 87, 74, 0.94) 52%, rgba(98, 120, 95, 0.9) 100%);
  box-shadow: 0 18rpx 48rpx rgba(34, 45, 37, 0.18);
}

.hero-bg {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(10rpx);
  opacity: 0.9;
}

.hero-bg-left {
  width: 280rpx;
  height: 280rpx;
  top: -120rpx;
  left: -60rpx;
  background: rgba(207, 226, 180, 0.2);
}

.hero-bg-right {
  width: 220rpx;
  height: 220rpx;
  right: -40rpx;
  bottom: -70rpx;
  background: rgba(255, 242, 201, 0.16);
}

.hero-topbar,
.hero-copy,
.hero-stats,
.status-filters {
  position: relative;
  z-index: 1;
}

.hero-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-user {
  display: flex;
  align-items: center;
  min-width: 0;
}

.hero-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
}

.hero-user-copy {
  min-width: 0;
}

.hero-user-label,
.hero-user-sub,
.hero-kicker,
.hero-title,
.hero-desc,
.hero-stat-value,
.hero-stat-label,
.section-title,
.section-meta,
.month-label,
.month-count,
.month-sub,
.action-btn,
.movie-title,
.movie-subtitle,
.movie-meta-label,
.movie-meta-value,
.rating-chip-label,
.rating-chip-value,
.mark-tag,
.mark-btn,
.empty-title,
.empty-desc,
.auth-title,
.auth-subtitle,
.input-label,
.nickname-input,
.auth-btn {
  display: block;
}

.hero-user-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #f7f2df;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-user-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(247, 242, 223, 0.72);
}

.hero-home {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #f5f0dd;
  background: rgba(255, 255, 255, 0.1);
}

.hero-copy {
  margin-top: 34rpx;
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: rgba(240, 236, 214, 0.72);
}

.hero-title {
  margin-top: 14rpx;
  font-size: 52rpx;
  line-height: 1.12;
  font-weight: 700;
  color: #fff6dc;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: rgba(245, 240, 221, 0.82);
}

.hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 30rpx;
}

.hero-stat {
  flex: 1 1 calc(50% - 8rpx);
  min-width: 0;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
}

.hero-stat.accent {
  background: rgba(242, 231, 182, 0.14);
}

.hero-stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff7e2;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(247, 242, 223, 0.72);
}

.status-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.status-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(247, 242, 223, 0.78);
  background: rgba(255, 255, 255, 0.08);
}

.status-chip.active {
  color: #1d2b24;
  background: #f4e9b9;
}

.status-chip.active.watched {
  background: #d7efdc;
}

.status-chip.active.wish {
  background: #ffe6c7;
}

.status-chip.active.muted {
  background: #e1e5df;
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 12rpx 30rpx rgba(78, 89, 78, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f312a;
}

.section-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7c877d;
}

.months-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.month-card {
  width: calc((100% - 70rpx) / 6);
  padding: 18rpx 0;
  border-radius: 22rpx;
  text-align: center;
  background: #f3f1e7;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.month-card.active {
  background: linear-gradient(180deg, #335446 0%, #436655 100%);
  border-color: rgba(244, 233, 185, 0.36);
}

.month-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #304036;
}

.month-count {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1e2e27;
}

.month-sub {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #7a867b;
}

.month-card.active .month-label,
.month-card.active .month-count,
.month-card.active .month-sub {
  color: #fff7e3;
}

.action-head {
  margin-bottom: 18rpx;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  padding: 22rpx 26rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  color: #213128;
  background: #eef0ea;
  flex: 1 1 220rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1d4b3b 0%, #6a835f 100%);
  color: #fff8e6;
}

.action-btn.success {
  background: #d7efdc;
}

.action-btn.warning {
  background: #ffe7c9;
}

.action-btn.secondary {
  background: #ece9de;
}

.action-btn.ghost {
  background: #f2f2ef;
  color: #70786f;
}

.movie-section {
  margin-top: 26rpx;
}

.movie-head {
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.empty-state {
  padding: 68rpx 28rpx;
  border-radius: 28rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
  box-shadow: 0 10rpx 28rpx rgba(72, 83, 73, 0.06);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #33453b;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a867b;
}

.ad-infeed-container {
  margin: 18rpx 0;
  overflow: hidden;
  border-radius: 28rpx;
}

.movie-card {
  margin-bottom: 20rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 14rpx 34rpx rgba(75, 88, 76, 0.08);
}

.movie-main {
  display: flex;
  align-items: stretch;
}

.movie-check-wrap {
  display: flex;
  align-items: center;
  margin-right: 10rpx;
}

.movie-check {
  transform: scale(0.92);
}

.movie-cover {
  width: 156rpx;
  height: 220rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  background: #ecede8;
  box-shadow: 0 8rpx 18rpx rgba(54, 66, 57, 0.12);
}

.movie-body {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
  display: flex;
  flex-direction: column;
}

.movie-title-row {
  min-width: 0;
}

.movie-title {
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f3028;
}

.movie-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #748075;
}

.movie-meta-list {
  margin-top: 18rpx;
}

.movie-meta-item {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.movie-meta-label {
  width: 72rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #7d887e;
}

.movie-meta-value {
  font-size: 24rpx;
  color: #314139;
}

.movie-meta-ellipsis {
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.rating-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.rating-chip {
  min-width: 132rpx;
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: #f1efe7;
}

.rating-chip.douban {
  background: rgba(61, 183, 84, 0.12);
}

.rating-chip.imdb {
  background: rgba(255, 209, 77, 0.22);
}

.rating-chip.tomato {
  background: rgba(226, 88, 67, 0.12);
}

.rating-chip-label {
  font-size: 20rpx;
  color: #657168;
}

.rating-chip-value {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #22312a;
}

.movie-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: auto;
  padding-top: 22rpx;
}

.mark-tag,
.mark-btn {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.mark-tag.watched,
.mark-btn.watched {
  color: #1f6f3d;
  background: #d8efdd;
}

.mark-tag.wish,
.mark-btn.wish {
  color: #b85f17;
  background: #ffe8cb;
}

.auth-modal {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-mask {
  position: absolute;
  inset: 0;
  background: rgba(25, 32, 27, 0.4);
  backdrop-filter: blur(6rpx);
}

.auth-content {
  position: relative;
  z-index: 1;
  width: 82%;
  padding: 44rpx 40rpx 48rpx;
  border-radius: 32rpx;
  background: #fffdf7;
  box-shadow: 0 20rpx 50rpx rgba(35, 45, 37, 0.18);
}

.auth-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #23342c;
  text-align: center;
}

.auth-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a867b;
  text-align: center;
}

.avatar-btn {
  margin-top: 34rpx;
  padding: 0;
  background: transparent;
  border: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after,
.auth-btn::after {
  border: none;
}

.temp-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: #edf0e8;
}

.avatar-edit-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #476453;
}

.nickname-input-group {
  display: flex;
  align-items: center;
  margin-top: 34rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #ece7d8;
}

.input-label {
  width: 88rpx;
  font-size: 26rpx;
  color: #47544c;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f3028;
}

.auth-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.auth-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.auth-btn.cancel {
  background: #f0efe9;
  color: #778278;
}

.auth-btn.confirm {
  background: linear-gradient(135deg, #214536 0%, #5c7559 100%);
  color: #fff8e6;
}

<view class="page-root">
  <view class="hero-section">
    <view class="hero-bg hero-bg-left"></view>
    <view class="hero-bg hero-bg-right"></view>

    <view class="hero-topbar">
      <view class="hero-user" bindtap="onHeaderLoginClick">
        <image class="hero-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <view class="hero-user-copy">
          <text class="hero-user-label">{{userInfo.nickName || '点击登录'}}</text>
          <text class="hero-user-sub">记录你的院线观影年度</text>
        </view>
      </view>
      <view class="hero-home" bindtap="onBackHome">返回首页</view>
    </view>

    <view class="hero-copy">
      <text class="hero-kicker">年度院线电影</text>
      <text class="hero-title">2026 影院上映片单</text>
      <text class="hero-desc">每天自动补充今天及之后的新片，历史缺口可继续手动补录。</text>
    </view>

    <view class="hero-stats">
      <view class="hero-stat">
        <text class="hero-stat-value">{{allCount}}</text>
        <text class="hero-stat-label">累计片数</text>
      </view>
      <view class="hero-stat">
        <text class="hero-stat-value">{{watchedCount}}</text>
        <text class="hero-stat-label">已看</text>
      </view>
      <view class="hero-stat">
        <text class="hero-stat-value">{{wishCount}}</text>
        <text class="hero-stat-label">想看</text>
      </view>
      <view class="hero-stat accent">
        <text class="hero-stat-value">{{selectedMonthCount}}</text>
        <text class="hero-stat-label">{{selectedMonthLabel || '当前月'}}上映</text>
      </view>
    </view>

    <view class="status-filters">
      <view class="status-chip {{statusFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="onStatusFilterChange">全部</view>
      <view class="status-chip {{statusFilter === 'watched' ? 'active watched' : ''}}" data-filter="watched" bindtap="onStatusFilterChange">已看</view>
      <view class="status-chip {{statusFilter === 'wish' ? 'active wish' : ''}}" data-filter="wish" bindtap="onStatusFilterChange">想看</view>
      <view class="status-chip {{statusFilter === 'unwatched' ? 'active muted' : ''}}" data-filter="unwatched" bindtap="onStatusFilterChange">未标记</view>
    </view>
  </view>

  <view class="section-card month-section">
    <view class="section-head">
      <text class="section-title">月份</text>
      <text class="section-meta">两行展示 12 个月新片数量</text>
    </view>
    <view class="months-grid">
      <block wx:for="{{monthSummaries}}" wx:key="key">
        <view class="month-card {{selectedMonth === item.key ? 'active' : ''}}" data-month="{{item.key}}" bindtap="onMonthSelect">
          <text class="month-label">{{item.label}}</text>
          <text class="month-count">{{item.count}}</text>
          <text class="month-sub">上映</text>
        </view>
      </block>
    </view>
  </view>

  <view class="section-card action-section">
    <view class="section-head action-head">
      <view>
        <text class="section-title">操作区</text>
        <text class="section-meta">{{selectedMonthLabel || '本月'}} · {{movies.length}} 部符合当前筛选</text>
      </view>
    </view>
    <view class="action-row">
      <block wx:if="{{!isBatchEditing}}">
        <view class="action-btn secondary" bindtap="onStartBatchEdit">批量标记</view>
        <view class="action-btn primary" bindtap="onShareTap">生成观影海报</view>
      </block>
      <block wx:else>
        <view class="action-btn success" bindtap="onBatchWatch">批量已看</view>
        <view class="action-btn warning" bindtap="onBatchWish">批量想看</view>
        <view class="action-btn secondary" bindtap="onBatchUnwatch">批量未看</view>
        <view class="action-btn ghost" bindtap="onCancelBatchEdit">取消</view>
      </block>
    </view>
  </view>

  <view class="movie-section">
    <view class="section-head movie-head">
      <view>
        <text class="section-title">电影区</text>
        <text class="section-meta">{{selectedMonthLabel || '当前月份'}}上映影片</text>
      </view>
    </view>

    <view wx:if="{{movies.length === 0}}" class="empty-state">
      <text class="empty-title">这个月份还没有可展示的电影</text>
      <text class="empty-desc">你可以下拉刷新，或者先手动补录历史数据。</text>
    </view>

    <block wx:for="{{movies}}" wx:key="_id">
      <view wx:if="{{showInfeedAd && (index === 6 || index === 18)}}" class="ad-infeed-container">
        <ad-custom unit-id="{{adUnitIds.movielist_infeed}}" bindload="onInfeedAdLoad" binderror="onInfeedAdError"></ad-custom>
      </view>

      <view class="movie-card">
        <view class="movie-main" bindtap="onMovieCardTap" data-movie-id="{{item._id}}">
          <view wx:if="{{isBatchEditing}}" class="movie-check-wrap">
            <checkbox class="movie-check" value="{{item._id}}" checked="{{item.checked}}" catchtap="onMovieCheck" data-movie-id="{{item._id}}" />
          </view>

          <image class="movie-cover" src="{{item.thumbCover || item.cover}}" mode="aspectFill" lazy-load="true" binderror="onImageError" bindload="onImageLoad" data-movie-id="{{item._id}}" show-menu-by-longpress="false" />

          <view class="movie-body">
            <view class="movie-title-row">
              <text class="movie-title">{{item.title}}</text>
              <text wx:if="{{item.subtitleText}}" class="movie-subtitle">{{item.subtitleText}}</text>
            </view>

            <view class="movie-meta-list">
              <view class="movie-meta-item">
                <text class="movie-meta-label">上映</text>
                <text class="movie-meta-value">{{item.releaseDateText}}</text>
              </view>
              <view class="movie-meta-item">
                <text class="movie-meta-label">导演</text>
                <text class="movie-meta-value movie-meta-ellipsis">{{item.directorText}}</text>
              </view>
            </view>

            <view class="rating-row">
              <view class="rating-chip douban">
                <text class="rating-chip-label">豆瓣</text>
                <text class="rating-chip-value">{{item.doubanRatingText}}</text>
              </view>
              <view class="rating-chip imdb">
                <text class="rating-chip-label">IMDb</text>
                <text class="rating-chip-value">{{item.imdbRatingText}}</text>
              </view>
              <view class="rating-chip tomato">
                <text class="rating-chip-label">烂番茄</text>
                <text class="rating-chip-value">{{item.rottenTomatoesText}}</text>
              </view>
            </view>

            <view class="movie-footer">
              <block wx:if="{{!isBatchEditing}}">
                <block wx:if="{{markStatusMap[item._id] === 'watched'}}">
                  <view class="mark-tag watched">{{markDateMap[item._id]}} 已看</view>
                </block>
                <block wx:elif="{{markStatusMap[item._id] === 'wish'}}">
                  <view class="mark-tag wish">{{markDateMap[item._id]}} 想看</view>
                </block>
                <block wx:else>
                  <view class="mark-btn wish" data-id="{{item._id}}" data-type="wish" catchtap="onMarkTap">想看</view>
                  <view class="mark-btn watched" data-id="{{item._id}}" data-type="watched" catchtap="onMarkTap">已看</view>
                </block>
              </block>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="auth-modal" hidden="{{!showAuthModal}}">
    <view class="auth-mask" bindtap="onCancelAuth"></view>
    <view class="auth-content">
      <view class="auth-title">完善个人资料</view>
      <view class="auth-subtitle">登录后即可同步你的已看、想看和年度海报。</view>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="temp-avatar" src="{{tempAvatar || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <view class="avatar-edit-tip">点击修改头像</view>
      </button>
      <view class="nickname-input-group">
        <text class="input-label">昵称</text>
        <input class="nickname-input" type="nickname" placeholder="请输入昵称" bindinput="onNicknameInput" bindblur="onNicknameInput" value="{{tempNickname}}" />
      </view>
      <view class="auth-actions">
        <button class="auth-btn cancel" bindtap="onCancelAuth">暂不登录</button>
        <button class="auth-btn confirm" bindtap="onConfirmAuth">保存并登录</button>
      </view>
    </view>
  </view>
</view>

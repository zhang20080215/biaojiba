<!-- 顶部分栏tab -->
<view class="tabs-bar">
  <view class="tab {{activeTab === 0 ? 'active' : ''}}" data-idx="0" bindtap="onTabChange">
    全部({{allCount}})
  </view>
  <view class="tab {{activeTab === 1 ? 'active' : ''}}" data-idx="1" bindtap="onTabChange">
    已看({{watchedCount}})
  </view>
  <view class="tab {{activeTab === 2 ? 'active' : ''}}" data-idx="2" bindtap="onTabChange">
    想看({{wishCount}})
  </view>
  <view class="tab {{activeTab === 3 ? 'active' : ''}}" data-idx="3" bindtap="onTabChange">
    未看({{unwatchedCount}})
  </view>
</view>

<!-- 分享按钮 -->
<view class="share-section">
  <button class="share-btn" bindtap="onShareTap">生成观影卡片</button>
</view>

<!-- 批量标记按钮区 -->
<view wx:if="{{userInfo}}" class="batch-options">
  <block wx:if="{{!isBatchEditing}}">
    <button class="batch-btn" bindtap="onStartBatchEdit">批量标记</button>
  </block>
  <block wx:elif="{{isBatchEditing}}">
    <button class="batch-btn batch-btn-watched" bindtap="onBatchWatch">批量已看</button>
    <button class="batch-btn batch-btn-wish" bindtap="onBatchWish">批量想看</button>
    <button class="batch-btn batch-btn-cancel" bindtap="onCancelBatchEdit">取消</button>
  </block>
</view>

<!-- 电影列表区 -->
<view class="movie-list">
  <block wx:for="{{movies}}" wx:key="_id">
    <view class="movie-row" bindtap="{{isBatchEditing ? 'onMovieCheck' : ''}}" data-movie-id="{{item._id}}">
      <!-- 复选框 -->
      <checkbox wx:if="{{isBatchEditing}}" class="batch-checkbox" value="{{item._id}}" checked="{{item.checked}}" catchtap="onMovieCheck" data-movie-id="{{item._id}}" />

      <!-- 电影内容容器，用于右移 -->
      <view class="movie-content {{isBatchEditing ? 'batch-editing' : ''}}">
      <!-- 电影封面 -->
      <image 
        class="movie-thumb" 
        src="{{item.cover}}" 
        lazy-load="true"
        mode="aspectFill"
        binderror="onImageError"
        bindload="onImageLoad"
        data-movie-id="{{item._id}}"
        show-menu-by-longpress="false"
      />

      <!-- 电影信息 -->
      <view class="movie-info">
        <view class="movie-title">{{item.rank}}. {{item.title}}</view>
        <view class="movie-rating">评分：{{item.rating}}</view>
      </view>

      <!-- 标记状态/按钮区 -->
        <block wx:if="{{!isBatchEditing}}">
      <block wx:if="{{markStatusMap[item._id] === 'watched'}}">
        <view class="mark-status">
          <text class="mark-text watched">{{markDateMap[item._id]}}已看</text>
        </view>
      </block>
      <block wx:elif="{{markStatusMap[item._id] === 'wish'}}">
        <view class="mark-status">
          <text class="mark-text wish">{{markDateMap[item._id]}}想看</text>
        </view>
      </block>
      <block wx:else>
        <view class="mark-buttons">
          <button class="mark-btn"
                  data-id="{{item._id}}"
                  data-type="watched"
                  catchtap="onMarkTap">
            已看
          </button>
          <button class="mark-btn mark-btn-wish"
                  data-id="{{item._id}}"
                  data-type="wish"
                  catchtap="onMarkTap">
            想看
          </button>
        </view>
      </block>
        </block>
      </view>
    </view>
  </block>
</view>

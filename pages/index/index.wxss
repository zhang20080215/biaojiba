/* ===== 整体页面背景 ===== */
page {
  background: linear-gradient(180deg,#f6f9ff 0%,#f7f7fa 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}


/* ===== 分栏 tabs 样式 ===== */
.tabs-bar {
  display: flex;
  background: rgba(255,255,255,0.98);
  box-shadow: 0 2px 12px 0 rgba(0,0,0,0.04);
  border-radius: 18rpx;
  margin: 0 16rpx 20rpx 16rpx;
  padding: 0 0 10rpx 0;
}

/* ===== 分享按钮区域 ===== */
.share-section {
  display: flex;
  justify-content: center;
  margin: 0 16rpx 20rpx 16rpx;
}

.share-btn {
  background: linear-gradient(90deg, #4cbbff 0%, #409eff 100%);
  color: #ffffff;
  font-size: 16px;
  border-radius: 20rpx;
  padding: 16rpx 40rpx;
  border: none;
  text-align: center;
  font-weight: 600;
  box-shadow: 0 4px 16px rgba(64, 158, 255, 0.25);
  transition: all 0.2s ease;
  letter-spacing: 1rpx;
}

.share-btn:active {
  transform: translateY(1px);
  box-shadow: 0 2px 8px rgba(64, 158, 255, 0.2);
  opacity: 0.95;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 16px;
  color: #b0b7c6;
  padding: 20rpx 0 12rpx 0;
  position: relative;
  font-weight: 500;
  letter-spacing: 0.5px;
  transition: color 0.18s;
}
.tab.active {
  color: #409eff;
  font-weight: 700;
}
.tab.active::after {
  content: '';
  display: block;
  width: 32rpx;
  height: 6rpx;
  background: linear-gradient(90deg,#41d6c3,#2aa9ff);
  border-radius: 3rpx;
  margin: 0 auto;
  margin-top: 2rpx;
}

/* ===== 批量标记按钮区 ===== */
.batch-options {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin: 0 0 20rpx 0;
  padding: 0 16rpx;
  box-sizing: border-box;
  gap: 12rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  padding: 16rpx;
  margin: 0;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  transform: translateY(-1px); /* 微调位置，消除间隙 */
}

.batch-btn {
  font-size: 14px;
  padding: 12rpx 24rpx;
  border-radius: 14px;
  border: none;
  font-weight: 500;
  text-align: center;
  background: #f0f0f0;
  color: #333;
  transition: all 0.2s ease;
  min-width: 100rpx;
}

.batch-btn:active {
  transform: translateY(1px);
  opacity: 0.9;
}

.batch-btn-watched {
  background: linear-gradient(90deg,#4cbbff 0%,#409eff 100%);
  color: #fff;
  box-shadow: 0 4px 12px rgba(64, 158, 255, 0.2);
}

.batch-btn-wish {
  background: linear-gradient(90deg,#ffc107 0%,#ff9800 100%);
  color: #fff;
  box-shadow: 0 4px 12px rgba(255, 152, 0, 0.2);
}

.batch-btn-cancel {
  background: #e0e0e0;
  color: #666;
}

/* ===== 电影列表整体 ===== */
.movie-list {
  width: 100%;
  margin: 0;
  padding-bottom: 40rpx;
}

/* ===== 单行电影卡片 ===== */
.movie-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 8px 36px 0 rgba(64,158,255,0.07), 0 2px 8px rgba(80,100,150,0.03);
  margin: 18rpx 16rpx;
  padding: 18rpx 16rpx 18rpx 16rpx; /* 原始内边距 */
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.15s, padding 0.3s; /* 添加 padding 过渡 */
}
.movie-row:active {
  box-shadow: 0 2px 12px 0 rgba(41,112,255,0.08);
}

/* 电影内容容器，用于右移和隐藏单个按钮 */
.movie-content {
  flex: 1; /* 填充剩余空间 */
  display: flex; /* 保持内部flex布局 */
  align-items: center;
  transition: transform 0.3s; /* 添加右移过渡 */
}

/* 批量编辑模式下电影内容右移 */
.movie-content.batch-editing {
  transform: translateX(40rpx); /* 向右移动，为复选框留空间 */
}

/* 复选框样式（可选调整） */
.batch-checkbox {
  margin-left: 16rpx;
  margin-right: -24rpx;
  transform: scale(0.9);
}

/* 加粗复选框对号 */
.batch-checkbox .wx-checkbox-input.wx-checkbox-input-checked {
  background: #409eff !important;
  border-color: #409eff !important;
}

.batch-checkbox .wx-checkbox-input.wx-checkbox-input-checked::before {
  font-weight: bold;
  font-size: 28rpx;
  color: #fff;
}

/* ===== 电影封面小图 ===== */
.movie-thumb {
  width: 62px;
  height: 88px;
  border-radius: 16rpx;
  box-shadow: 0 2px 10px rgba(80,120,200,0.08);
  margin-right: 18rpx;
  object-fit: cover;
  background: #f3f4f8;
}

/* ===== 电影信息区 ===== */
.movie-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}
.movie-title {
  font-size: 14px;
  color: #181c2e;
  font-weight: 700;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  margin: 0 0 6rpx 0;
  max-width: 100%;
}
.movie-rating {
  font-size: 15px;
  color: #39aaff;
  margin: 2rpx 0 0 0;
  font-weight: 500;
  letter-spacing: 0.4px;
}

/* ===== 标记状态显示区 ===== */
.mark-status {
  margin-left: auto; /* 推到最右边 */
  padding: 0 10rpx; /* 调整内边距 */
  border-radius: 10rpx; /* 可选：圆角 */
  display: flex; /* 使用flex居中文本 */
  align-items: center;
  height: 100%; /* 填充父容器高度 */
}

.mark-text {
  font-size: 13px; /* 调整字体大小 */
  font-weight: 600;
  letter-spacing: 0.3px;
  white-space: nowrap; /* 防止换行 */
}

.mark-text.watched {
  color: #4CAF50; /* 已看颜色 */
}

.mark-text.wish {
  color: #FFC107; /* 想看颜色 */
}

/* ===== 标记按钮 ===== */
.mark-buttons {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 12rpx;
}
.mark-btn {
  min-width: 40px;
  max-width: 60px;
  font-size: 13px;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  height: 30px;
  line-height: 30px;
  padding: 0 12rpx;
  margin-left: 0;
  background: #f6f8fa;
  color: #409eff;
  box-shadow: 0 2px 8px rgba(70,130,255,0.07);
  transition: background 0.16s, color 0.16s;
}
.mark-btn-wish {
  background: #fff6ea;
  color: #ff9500;
}
.mark-btn:active {
  background: #e7f1fa;
  color: #2178bc;
  opacity: .8;
}

/* ===== 滚动条优化（仅在支持的环境生效） ===== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

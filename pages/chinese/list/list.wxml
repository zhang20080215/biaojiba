<!-- 豆瓣高分华语电影 TOP100 列表页 -->

<!-- 顶部 Hero 区域 -->
<view class="hero-header">
  <view class="hero-bg"></view>
  <view class="hero-content">
    <view class="hero-top-row">
      <view class="user-profile-section" bindtap="onHeaderLoginClick">
        <image class="avatar-small" src="{{userInfo.avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <text class="nickname-small">{{userInfo.nickName || '点击登录'}}</text>
      </view>
      <view class="home-nav-section" bindtap="onBackHome">
        <text class="home-text">首页</text>
      </view>
    </view>
    <view class="hero-title-area">
      <view class="hero-badge">TOP 100</view>
      <view class="hero-title">豆瓣高分华语电影</view>
      <view class="hero-subtitle">跨越大陆港台三地，华语影史经典巡礼</view>
    </view>
    <!-- 进度条 -->
    <view class="progress-section">
      <view class="progress-bar-track">
        <view class="progress-bar-fill" style="width: {{allCount > 0 ? (watchedCount / allCount * 100) : 0}}%"></view>
      </view>
      <view class="progress-stats">
        <text class="progress-label">已看 {{watchedCount}}/{{allCount}}</text>
        <text class="progress-percent">{{watchPercent}}%</text>
      </view>
    </view>
  </view>
</view>

<!-- 统计与分栏 Tab -->
<view class="tabs-bar">
  <view class="tab {{activeTab === 0 ? 'active' : ''}}" data-idx="0" bindtap="onTabChange">
    <text class="tab-label">全部</text>
    <text class="tab-count">{{allCount}}</text>
  </view>
  <view class="tab {{activeTab === 1 ? 'active' : ''}}" data-idx="1" bindtap="onTabChange">
    <text class="tab-label">已看</text>
    <text class="tab-count">{{watchedCount}}</text>
  </view>
  <view class="tab {{activeTab === 2 ? 'active' : ''}}" data-idx="2" bindtap="onTabChange">
    <text class="tab-label">想看</text>
    <text class="tab-count">{{wishCount}}</text>
  </view>
  <view class="tab {{activeTab === 3 ? 'active' : ''}}" data-idx="3" bindtap="onTabChange">
    <text class="tab-label">未看</text>
    <text class="tab-count">{{unwatchedCount}}</text>
  </view>
</view>

<!-- 操作栏：批量 + 海报生成 -->
<view class="sticky-action-container">
  <view class="middle-action-section">
    <view wx:if="{{userInfo}}" class="batch-options">
      <block wx:if="{{!isBatchEditing}}">
        <view class="icon-btn batch-icon" bindtap="onStartBatchEdit">批量标记</view>
      </block>
      <block wx:elif="{{isBatchEditing}}">
        <view class="icon-btn action-watched" bindtap="onBatchWatch">批量已看</view>
        <view class="icon-btn action-wish" bindtap="onBatchWish">想看</view>
        <view class="icon-btn action-cancel" bindtap="onCancelBatchEdit">取消</view>
      </block>
    </view>
    <view class="generate-card-wrapper" bindtap="onShareTap" wx:if="{{!isBatchEditing}}">
      <view class="generate-card-btn-large">生成观影海报</view>
    </view>
  </view>
</view>

<!-- 电影列表区 -->
<view class="movie-list">
  <block wx:for="{{movies}}" wx:key="_id">
    <!-- 信息流广告位 -->
    <view wx:if="{{showInfeedAd && (index === 10 || index === 50)}}" class="ad-infeed-container">
      <ad-custom unit-id="{{adUnitIds.movielist_infeed}}" bindload="onInfeedAdLoad" binderror="onInfeedAdError"></ad-custom>
    </view>
    <view class="movie-row {{markStatusMap[item._id] === 'watched' ? 'is-watched' : ''}}" bindtap="{{isBatchEditing ? 'onMovieCheck' : ''}}" data-movie-id="{{item._id}}">
      <checkbox wx:if="{{isBatchEditing}}" class="batch-checkbox" value="{{item._id}}" checked="{{item.checked}}" catchtap="onMovieCheck" data-movie-id="{{item._id}}" />
      <view class="movie-content {{isBatchEditing ? 'batch-editing' : ''}}">
        <!-- 排名徽章 -->
        <view class="rank-badge {{item.rank <= 10 ? 'rank-top' : ''}}">{{item.rank}}</view>
        <!-- 海报 -->
        <view class="poster-wrapper">
          <image class="movie-thumb" src="{{item.thumbCover || item.cover}}" lazy-load="true" mode="aspectFill" binderror="onImageError" bindload="onImageLoad" data-movie-id="{{item._id}}" show-menu-by-longpress="false" />
          <view class="poster-shine"></view>
        </view>
        <!-- 信息 -->
        <view class="movie-info">
          <view class="movie-title">{{item.title}}</view>
          <view class="movie-meta">
            <text class="rating-star">★</text>
            <text class="movie-rating">{{item.rating}}</text>
          </view>
        </view>
        <!-- 标记 -->
        <block wx:if="{{!isBatchEditing}}">
          <block wx:if="{{markStatusMap[item._id] === 'watched'}}">
            <view class="mark-status mark-watched-badge">
              <text class="mark-icon">✓</text>
              <text class="mark-text watched">已看</text>
            </view>
          </block>
          <block wx:elif="{{markStatusMap[item._id] === 'wish'}}">
            <view class="mark-status mark-wish-badge">
              <text class="mark-icon">♡</text>
              <text class="mark-text wish">想看</text>
            </view>
          </block>
          <block wx:else>
            <view class="mark-buttons">
              <button class="mark-btn mark-btn-watched" data-id="{{item._id}}" data-type="watched" catchtap="onMarkTap">已看</button>
              <button class="mark-btn mark-btn-wish" data-id="{{item._id}}" data-type="wish" catchtap="onMarkTap">想看</button>
            </view>
          </block>
        </block>
      </view>
    </view>
  </block>
</view>

<!-- 个人信息授权弹窗 -->
<view class="auth-modal" hidden="{{!showAuthModal}}">
  <view class="auth-mask" bindtap="onCancelAuth"></view>
  <view class="auth-content">
    <view class="auth-decoration"></view>
    <view class="auth-title">完善个人资料</view>
    <view class="auth-subtitle">登录后即可标记和生成海报</view>
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="temp-avatar" src="{{tempAvatar || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
      <view class="avatar-edit-tip">点击选择头像</view>
    </button>
    <view class="nickname-input-group">
      <text class="input-label">昵称</text>
      <input type="nickname" class="nickname-input" placeholder="请输入昵称" bindinput="onNicknameInput" bindblur="onNicknameInput" value="{{tempNickname}}" />
    </view>
    <view class="auth-actions">
      <button class="auth-btn cancel" bindtap="onCancelAuth">暂不登录</button>
      <button class="auth-btn confirm" bindtap="onConfirmAuth">保存并登录</button>
    </view>
  </view>
</view>

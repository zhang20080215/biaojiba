/* ============================================================
   豆瓣高分华语电影 TOP100 — 电影手册风格
   色调：朱砂红 × 暖象牙 × 墨色，致敬华语影史
   ============================================================ */

/* ===== 全局 ===== */
page {
  --cinnabar: #a63d2f;
  --cinnabar-light: #c9564a;
  --cinnabar-deep: #7a2b20;
  --gold-warm: #d4a853;
  --ivory: #faf6f0;
  --ivory-dark: #f0ebe3;
  --ink: #1a1410;
  --ink-light: #3d352d;
  --ink-muted: #8a7e72;
  --green-mark: #527a4a;
  --amber-wish: #c48f2c;

  background: var(--ivory);
  min-height: 100vh;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: var(--ink);
}

/* ===== Hero 顶部区域 ===== */
.hero-header {
  position: relative;
  overflow: hidden;
  margin-bottom: 0;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(165deg, var(--cinnabar-deep) 0%, var(--cinnabar) 40%, var(--cinnabar-light) 100%);
}

/* 纹理叠加 — 用伪元素模拟胶片颗粒质感 */
.hero-bg::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.03) 2px,
    rgba(0,0,0,0.03) 4px
  );
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 32rpx 36rpx;
}

.hero-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-profile-section {
  display: flex;
  align-items: center;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  margin-right: 14rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.15);
}

.nickname-small {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.9);
  max-width: 280rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.home-nav-section {
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.25);
}

.home-nav-section:active {
  background: rgba(255,255,255,0.25);
}

.home-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

/* Hero 标题区 */
.hero-title-area {
  margin-bottom: 28rpx;
}

.hero-badge {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--cinnabar-deep);
  background: var(--gold-warm);
  padding: 4rpx 18rpx;
  border-radius: 6rpx;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 3rpx;
  line-height: 1.25;
  margin-bottom: 8rpx;
  text-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  letter-spacing: 1rpx;
  font-weight: 400;
}

/* 进度条 */
.progress-section {
  margin-top: 4rpx;
}

.progress-bar-track {
  height: 8rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold-warm) 0%, #f0c96a 100%);
  border-radius: 4rpx;
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  min-width: 2%;
}

.progress-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.progress-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 400;
}

.progress-percent {
  font-size: 24rpx;
  color: var(--gold-warm);
  font-weight: 700;
  letter-spacing: 0.5px;
}

/* ===== 分栏 Tabs ===== */
.tabs-bar {
  display: flex;
  background: #fff;
  margin: 0;
  padding: 4rpx 8rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 101;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 16rpx;
  position: relative;
  transition: all 0.25s ease;
}

.tab-label {
  font-size: 26rpx;
  color: var(--ink-muted);
  font-weight: 500;
  line-height: 1;
  margin-bottom: 4rpx;
  transition: color 0.25s;
}

.tab-count {
  font-size: 20rpx;
  color: #bbb;
  font-weight: 600;
  transition: color 0.25s;
}

.tab.active .tab-label {
  color: var(--cinnabar);
  font-weight: 700;
}

.tab.active .tab-count {
  color: var(--cinnabar-light);
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 5rpx;
  background: var(--cinnabar);
  border-radius: 3rpx;
}

/* ===== 吸顶操作栏 ===== */
.sticky-action-container {
  position: sticky;
  top: 96rpx;
  z-index: 100;
  background: rgba(250, 246, 240, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.middle-action-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 24rpx;
}

.batch-options {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.icon-btn {
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 26rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
  line-height: 1.3;
}

.batch-icon {
  background: rgba(166, 61, 47, 0.08);
  color: var(--cinnabar);
  border: 1rpx solid rgba(166, 61, 47, 0.15);
}

.batch-icon:active {
  background: rgba(166, 61, 47, 0.15);
}

.action-cancel {
  background: var(--ivory-dark);
  color: var(--ink-muted);
}

.action-watched {
  background: rgba(82, 122, 74, 0.08);
  color: var(--green-mark);
  border: 1rpx solid rgba(82, 122, 74, 0.15);
}

.action-wish {
  background: rgba(196, 143, 44, 0.08);
  color: var(--amber-wish);
  border: 1rpx solid rgba(196, 143, 44, 0.15);
}

/* 生成海报按钮 */
.generate-card-wrapper {
  flex: 0 0 auto;
}

.generate-card-btn-large {
  background: linear-gradient(135deg, var(--cinnabar) 0%, var(--cinnabar-deep) 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 8rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 16rpx rgba(166, 61, 47, 0.3);
  transition: all 0.2s ease;
}

.generate-card-btn-large:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(166, 61, 47, 0.2);
}

.icon-btn:active {
  transform: translateY(1px);
  opacity: 0.85;
}

/* ===== 电影列表 ===== */
.movie-list {
  width: 100%;
  padding: 12rpx 0 60rpx;
}

/* ===== 单行电影卡片 ===== */
.movie-row {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 24rpx 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.movie-row:active {
  background: var(--ivory);
}

/* 已看的卡片 — 左侧金色竖条 */
.movie-row.is-watched {
  border-left: 5rpx solid var(--gold-warm);
}

.movie-content {
  flex: 1;
  display: flex;
  align-items: center;
  transition: transform 0.3s;
}

.movie-content.batch-editing {
  transform: translateX(40rpx);
}

/* 排名徽章 */
.rank-badge {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ink-muted);
  background: var(--ivory-dark);
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

.rank-badge.rank-top {
  background: linear-gradient(135deg, var(--cinnabar) 0%, var(--cinnabar-light) 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(166, 61, 47, 0.25);
}

/* 海报 */
.poster-wrapper {
  position: relative;
  flex-shrink: 0;
  margin-right: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12), 0 1rpx 4rpx rgba(0,0,0,0.06);
}

.movie-thumb {
  width: 120rpx;
  height: 168rpx;
  display: block;
  background: var(--ivory-dark);
}

/* 海报光泽 — 电影胶片感 */
.poster-shine {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(
    135deg,
    rgba(255,255,255,0.15) 0%,
    transparent 40%,
    transparent 60%,
    rgba(255,255,255,0.05) 100%
  );
  pointer-events: none;
}

/* 电影信息 */
.movie-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  padding: 4rpx 0;
}

.movie-title {
  font-size: 30rpx;
  color: var(--ink);
  font-weight: 700;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
  line-height: 1.3;
}

.movie-meta {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-star {
  font-size: 24rpx;
  color: var(--gold-warm);
  line-height: 1;
}

.movie-rating {
  font-size: 28rpx;
  color: var(--cinnabar-light);
  font-weight: 500;
  letter-spacing: 0.5px;
  font-variant-numeric: tabular-nums;
  opacity: 0.85;
}

/* ===== 标记状态 ===== */
.mark-status {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  margin-left: auto;
  flex-shrink: 0;
}

.mark-watched-badge {
  background: rgba(82, 122, 74, 0.08);
  border: 1rpx solid rgba(82, 122, 74, 0.15);
}

.mark-wish-badge {
  background: rgba(196, 143, 44, 0.08);
  border: 1rpx solid rgba(196, 143, 44, 0.15);
}

.mark-icon {
  font-size: 22rpx;
  line-height: 1;
}

.mark-watched-badge .mark-icon {
  color: var(--green-mark);
}

.mark-wish-badge .mark-icon {
  color: var(--amber-wish);
}

.mark-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.3px;
  white-space: nowrap;
}

.mark-text.watched {
  color: var(--green-mark);
}

.mark-text.wish {
  color: var(--amber-wish);
}

/* ===== 标记按钮 ===== */
.mark-buttons {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-left: auto;
  flex-shrink: 0;
}

.mark-btn {
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 8rpx;
  border: none;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  margin: 0;
  transition: all 0.15s ease;
  min-width: 0;
}

.mark-btn::after {
  border: none;
}

.mark-btn-watched {
  background: var(--cinnabar);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(166, 61, 47, 0.2);
}

.mark-btn-watched:active {
  background: var(--cinnabar-deep);
  transform: scale(0.96);
}

.mark-btn-wish {
  background: transparent;
  color: var(--amber-wish);
  border: 1rpx solid rgba(196, 143, 44, 0.35);
}

.mark-btn-wish:active {
  background: rgba(196, 143, 44, 0.08);
  transform: scale(0.96);
}

/* ===== 批量编辑 Checkbox ===== */
.batch-checkbox {
  margin-left: 16rpx;
  margin-right: -16rpx;
  transform: scale(0.85);
}

.batch-checkbox .wx-checkbox-input.wx-checkbox-input-checked {
  background: var(--cinnabar) !important;
  border-color: var(--cinnabar) !important;
}

.batch-checkbox .wx-checkbox-input.wx-checkbox-input-checked::before {
  font-weight: bold;
  font-size: 28rpx;
  color: #fff;
}

/* ===== 信息流广告 ===== */
.ad-infeed-container {
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

/* ===== 滚动条 ===== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ============================================================
   授权弹窗 — 毛玻璃 + 朱砂红调
   ============================================================ */
.auth-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26, 20, 16, 0.6);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.auth-content {
  position: relative;
  width: 82%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 44rpx;
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

/* 顶部装饰条 */
.auth-decoration {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--cinnabar-deep), var(--cinnabar), var(--gold-warm));
}

.auth-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--ink);
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.auth-subtitle {
  font-size: 24rpx;
  color: var(--ink-muted);
  margin-bottom: 40rpx;
}

.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after {
  border: none;
}

.temp-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  background: var(--ivory-dark);
  border: 3rpx solid var(--cinnabar-light);
  box-shadow: 0 4rpx 16rpx rgba(166, 61, 47, 0.15);
}

.avatar-edit-tip {
  font-size: 20rpx;
  color: var(--cinnabar);
  margin-top: 14rpx;
  font-weight: 500;
}

.nickname-input-group {
  width: 100%;
  margin-top: 36rpx;
  background: var(--ivory);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
}

.input-label {
  font-size: 26rpx;
  color: var(--ink-muted);
  width: 80rpx;
  font-weight: 500;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink);
  padding: 0 10rpx;
}

.auth-actions {
  display: flex;
  width: 100%;
  margin-top: 44rpx;
  gap: 20rpx;
}

.auth-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
}

.auth-btn::after {
  border: none;
}

.auth-btn.cancel {
  background: var(--ivory);
  color: var(--ink-muted);
  border: 1rpx solid rgba(0,0,0,0.06);
}

.auth-btn.confirm {
  background: linear-gradient(135deg, var(--cinnabar) 0%, var(--cinnabar-deep) 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(166, 61, 47, 0.3);
}

.auth-btn.confirm:active {
  box-shadow: 0 2rpx 8rpx rgba(166, 61, 47, 0.2);
  transform: translateY(2rpx);
}

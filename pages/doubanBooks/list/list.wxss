/* pages/doubanBooks/list/list.wxss — 豆瓣读书 TOP250 列表（骨架阶段） */
/* 配色取读书主题：米白底 + 暖棕字 + 墨绿强调，区别于电影主题 */

page {
  background: #F7F2E7;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Hero */
.hero {
  position: relative;
  padding: 80rpx 40rpx 56rpx;
  background: linear-gradient(180deg, #F7E8C8 0%, #F7F2E7 100%);
  color: #3A2E1E;
}

.hero-back {
  position: absolute;
  top: 60rpx;
  left: 24rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.hero-back-icon {
  font-size: 48rpx;
  line-height: 48rpx;
  color: #3A2E1E;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  margin-top: 24rpx;
  letter-spacing: 2rpx;
}

.hero-slogan {
  font-size: 28rpx;
  color: #6B5A3E;
  margin-top: 12rpx;
}

.hero-progress {
  margin-top: 36rpx;
}

.hero-progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(58, 46, 30, 0.12);
  border-radius: 6rpx;
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6E8E5C 0%, #9AAB65 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.hero-progress-text {
  font-size: 24rpx;
  color: #6B5A3E;
  margin-top: 12rpx;
}

/* Sticky bar */
.sticky-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #F7F2E7;
  padding: 16rpx 32rpx 8rpx;
  border-bottom: 1rpx solid rgba(58, 46, 30, 0.08);
}

.tabs {
  display: flex;
  gap: 12rpx;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.7);
  transition: all 0.2s ease;
}

.tab-active {
  background: #3A2E1E;
  color: #F7E8C8;
}

.tab-label {
  font-size: 26rpx;
  font-weight: 600;
}

.tab-count {
  font-size: 22rpx;
  margin-top: 4rpx;
  opacity: 0.75;
}

.action-bar {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.action-btn {
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.action-btn-primary {
  background: #6E8E5C;
  color: #fff;
}

/* Book list */
.book-list {
  padding: 24rpx 32rpx;
}

.book-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(58, 46, 30, 0.04);
}

.book-cover {
  position: relative;
  width: 160rpx;
  height: 230rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
  overflow: hidden;
  background: #E8DFC8;
}

.book-cover image {
  width: 100%;
  height: 100%;
}

.book-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9C8B6A;
  font-size: 26rpx;
}

.book-rank {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  background: rgba(58, 46, 30, 0.78);
  color: #F7E8C8;
  font-size: 20rpx;
  border-radius: 999rpx;
}

.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.book-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3A2E1E;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-author {
  font-size: 24rpx;
  color: #6B5A3E;
  margin-top: 8rpx;
}

.book-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9C8B6A;
}

.book-rating {
  color: #C58A2E;
  font-weight: 600;
}

.book-actions {
  margin-top: auto;
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
}

.book-action {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(58, 46, 30, 0.06);
  color: #6B5A3E;
}

.book-action-read {
  background: #6E8E5C;
  color: #fff;
}

.book-action-wish {
  background: #C58A2E;
  color: #fff;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: #9C8B6A;
  font-size: 28rpx;
}

/* Toast */
.custom-toast {
  position: fixed;
  left: 50%;
  bottom: 120rpx;
  transform: translateX(-50%) translateY(20rpx);
  padding: 16rpx 32rpx;
  background: rgba(58, 46, 30, 0.9);
  color: #F7E8C8;
  font-size: 26rpx;
  border-radius: 12rpx;
  opacity: 0;
  transition: all 0.2s ease;
  pointer-events: none;
}

.custom-toast-visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

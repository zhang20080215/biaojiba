/* 全平台电影评分查询：详情页 */

page {
  background-color: #FFFFFF;
}

.page-root {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: var(--space-6);
}

/* ========== loading / error ========== */
.loading-state, .error-state {
  padding: 200rpx var(--space-4);
  text-align: center;
}

.loading-state text {
  font-size: 28rpx;
  color: var(--text-secondary, #666);
}

.error-text {
  display: block;
  font-size: 28rpx;
  color: var(--danger, #d63838);
  margin-bottom: 40rpx;
}

.retry-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: var(--brand-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* ========== Hero ========== */
.hero-section {
  position: relative;
  width: 100%;
  height: 480rpx;
  overflow: hidden;
}

.hero-poster {
  width: 100%;
  height: 100%;
  filter: blur(0);
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.75) 100%);
  color: #FFFFFF;
}

.movie-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
}

.meta-text {
  font-size: 24rpx;
}

.genre-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.genre-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 16rpx;
  padding: 4rpx 16rpx;
}

/* ========== 三平台评分卡 ========== */
.rating-grid {
  display: flex;
  gap: 16rpx;
  padding: var(--space-5) var(--space-4) var(--space-2);
}

.rating-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  text-align: center;
  min-height: 200rpx;
  justify-content: center;
}

.rating-card.douban {
  background: linear-gradient(135deg, #2e8d2e 0%, #4caf50 100%);
}

.rating-card.imdb {
  background: linear-gradient(135deg, #d4a017 0%, #f5c518 100%);
}

.rating-card.rotten {
  background: linear-gradient(135deg, #d34a23 0%, #f25c2a 100%);
}

.rating-card-header {
  margin-bottom: 16rpx;
}

.platform-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.rating-main {
  display: block;
  font-size: 56rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.rating-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 12rpx;
}

.no-data {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
  padding: 16rpx 0;
}

/* ========== 信息行 ========== */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx var(--space-4);
  border-bottom: 1rpx solid #F0F0F0;
  font-size: 26rpx;
}

.info-label {
  color: var(--text-secondary, #666);
}

.info-value {
  color: var(--text-primary, #333);
  font-family: monospace;
}

/* ========== Action bar ========== */
.action-bar {
  padding: var(--space-5) var(--space-4) 0;
}

.refresh-btn {
  text-align: center;
  padding: 28rpx;
  background: var(--brand-primary);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  transition: opacity 120ms ease-out;
}

.refresh-btn-hover {
  opacity: 0.75;
}

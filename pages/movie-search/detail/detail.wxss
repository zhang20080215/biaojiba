/* 全平台电影评分查询：详情页（沉浸式，与首页 hero 风格一致） */

page {
  background-color: #FFFCF5;
}

.page-root {
  --ms-bg: #FFFCF5;
  --ms-card: #FFFFFF;
  --ms-text: #2a3520;
  --ms-text-sub: #6a7752;
  --ms-text-mute: #94a176;
  --ms-brand: #9AAB65;
  --ms-brand-deep: #6a8035;
  --ms-brand-soft: #E1E6D1;
  --ms-douban: #2E8D2E;
  --ms-imdb: #B8860B;
  --ms-rt: #C7361A;
  --ms-popcorn: #E89E2F;
  min-height: 100vh;
  background: var(--ms-bg);
  box-sizing: border-box;
  position: relative;
  overflow-x: hidden;
}

/* ========== 顶部 toast ========== */
.ms-toast {
  position: fixed;
  top: 18%;
  left: 50%;
  transform: translate(-50%, -8rpx);
  z-index: 1000;
  max-width: 78vw;
  padding: 20rpx 28rpx;
  background: rgba(42, 53, 32, 0.92);
  color: #FFFFFF;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
  word-break: break-word;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease, transform 220ms ease;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
}
.ms-toast.is-show {
  opacity: 1;
  transform: translate(-50%, 0);
}
.ms-toast-icon {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--ms-brand);
  color: #FFFFFF;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
  font-weight: 700;
}

/* ========== loading / error 全屏态 ========== */
.loading-state, .error-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-4);
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--ms-brand-soft);
  border-top-color: var(--ms-brand);
  border-radius: 50%;
  animation: ms-spin 800ms linear infinite;
  margin-bottom: var(--space-3);
}
.loading-text {
  font-size: 26rpx;
  color: var(--ms-text-sub);
  line-height: 1.6;
  text-align: center;
  white-space: pre-line;
}
.error-text {
  font-size: 28rpx;
  color: #D63838;
  margin-bottom: var(--space-5);
  line-height: 1.5;
  text-align: center;
}
.retry-btn {
  padding: 20rpx 56rpx;
  background: var(--ms-brand-deep);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 999rpx;
  transition: transform 120ms ease-out;
}
.retry-btn:active {
  transform: scale(0.97);
}

/* ========== Hero：海报全屏 + 文字浮在海报上 ==========
   海报 aspectFill 100% 铺满整屏，文字白色加阴影浮在底部，
   渐变蒙层底部加深确保文字 contrast >= 4.5:1 */
.hero-wrap {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: var(--ms-text);
}

.hero-bg {
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.hero-bg-placeholder {
  background: linear-gradient(160deg, #4a5836 0%, #2a3520 100%);
}

/* 渐变蒙层：顶部清晰、底部加深，确保白字浮在海报上对比度足够 */
.hero-mask {
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.1) 35%,
    rgba(0, 0, 0, 0.55) 70%,
    rgba(0, 0, 0, 0.85) 100%
  );
}

.status-bar-spacer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 5;
}

/* ========== Hero 下半部内容 ========== */
.hero-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 4;
  padding: var(--space-4) var(--space-4) 88rpx;  /* 底部 padding 48→88，让评分卡浮起，留呼吸 */
  display: flex;
  flex-direction: column;
  gap: var(--space-4);  /* hero-meta ↔ 评分行 24→32rpx 拉开 */
}

.hero-meta {
  padding: 0 var(--space-2);
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}
.hero-sub-line {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
}
.hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.4;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.4);
}
.genre-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: var(--space-2);
}
.genre-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
  line-height: 1.4;
  backdrop-filter: blur(8rpx);
}

/* ========== 四平台评分（同主页 hero 风格：简单灰色文字 label） ========== */
.hero-rating-row {
  display: flex;
  gap: 12rpx;
  padding: 0 var(--space-1);
}

.hero-rating-cell {
  /* 固定 1/4 宽（扣 3 个 12rpx gap）—— wx:if 隐藏部分卡片时其余卡片保持原宽，靠左对齐 */
  flex: 0 0 calc((100% - 36rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 6rpx 14rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-md);
  min-width: 0;
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
  box-shadow: 0 4rpx 12rpx rgba(42, 53, 32, 0.12);
}

.hero-rating-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--ms-text-sub);
  letter-spacing: 0.5rpx;
}

.hero-rating-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--ms-brand-deep);
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}
.hero-rating-value.is-empty {
  color: var(--ms-text-mute);
  font-weight: 600;
  font-size: 28rpx;
}

.hero-rating-votes {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: var(--ms-text-mute);
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}

@keyframes ms-spin { to { transform: rotate(360deg); } }

/* ========== 保存按钮（hero-content 内，评分行下方） ========== */
.save-btn {
  margin-top: var(--space-3);
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ms-brand-deep);
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.18);
  transition: opacity 120ms ease-out, transform 120ms ease-out;
}
.save-btn-hover {
  opacity: 0.88;
  transform: scale(0.98);
}
.save-btn.is-loading {
  opacity: 0.65;
}
.save-btn-main {
  display: block;
  line-height: 1.3;
}
.save-btn-sub {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  opacity: 0.85;
  margin-top: 6rpx;
  letter-spacing: 0;
}

/* ========== 离屏 Canvas（视野外，物理像素 1080×1440） ========== */
.save-canvas-offscreen {
  position: fixed;
  top: -99999rpx;
  left: -99999rpx;
  width: 540rpx;       /* 半 rpx 显示尺寸（任意，绘制看 canvas.width/height） */
  height: 720rpx;
  pointer-events: none;
}

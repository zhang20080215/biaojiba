<!-- 全平台电影评分查询：电影详情页（沉浸式海报背景，同首页 hero 风格） -->
<view class="page-root">

  <view class="ms-toast {{toast.show ? 'is-show' : ''}}" aria-live="polite">
    <text wx:if="{{toast.icon === 'success'}}" class="ms-toast-icon">✓</text>
    <text class="ms-toast-text">{{toast.text}}</text>
  </view>

  <!-- loading：全屏居中 spinner -->
  <view wx:if="{{loading && !movie}}" class="loading-state">
    <view class="loading-spinner" />
    <text class="loading-text">正在抓取三平台评分\n首次查询约需 10 秒</text>
  </view>

  <!-- error：全屏居中报错 + 重试 -->
  <view wx:elif="{{error}}" class="error-state">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="onRetry">重试</view>
  </view>

  <!-- 主体：沉浸式海报 + 评分卡 -->
  <view wx:elif="{{movie}}" class="hero-wrap">
    <image wx:if="{{movie.poster}}"
           class="hero-bg"
           src="{{movie.poster}}"
           mode="aspectFill"
           lazy-load="false" />
    <view wx:else class="hero-bg hero-bg-placeholder" />

    <view class="hero-mask" />

    <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;" />

    <view class="hero-content">
      <view class="hero-meta">
        <text class="hero-title">{{movie.title}}</text>
        <view class="hero-sub-line">
          <text wx:if="{{movie.year}}" class="hero-sub">{{movie.year}}</text>
          <text wx:if="{{movie.directorText}}" class="hero-sub">· 导演 {{movie.directorText}}</text>
        </view>
        <view wx:if="{{movie.genres && movie.genres.length}}" class="genre-row">
          <view wx:for="{{movie.genres}}" wx:key="*this" class="genre-tag">{{item}}</view>
        </view>
      </view>

      <view class="hero-rating-row">
        <view wx:if="{{movie.douban && movie.douban.rating}}" class="hero-rating-cell">
          <text class="hero-rating-label">豆瓣</text>
          <text class="hero-rating-value">{{movie.douban.rating}}</text>
          <text class="hero-rating-votes">{{movie.doubanVotesRaw || ' '}}</text>
        </view>
        <view wx:if="{{movie.imdb && movie.imdb.rating}}" class="hero-rating-cell">
          <text class="hero-rating-label">IMDB</text>
          <text class="hero-rating-value">{{movie.imdb.rating}}</text>
          <text class="hero-rating-votes">{{movie.imdbVotesRaw || ' '}}</text>
        </view>
        <view wx:if="{{movie.hasRtCritic}}" class="hero-rating-cell">
          <text class="hero-rating-label">新鲜度</text>
          <text class="hero-rating-value">{{movie.rtCriticText}}</text>
          <text class="hero-rating-votes">{{movie.rtCriticCountRaw || '影评人'}}</text>
        </view>
        <view wx:if="{{movie.hasRtAudience}}" class="hero-rating-cell">
          <text class="hero-rating-label">爆米花</text>
          <text class="hero-rating-value">{{movie.rtAudienceText}}</text>
          <text class="hero-rating-votes">{{movie.rtAudienceCountRaw || '观众'}}</text>
        </view>
      </view>

      <!-- 保存到相册（命中广告灰度时显示副文案：需观看广告后保存） -->
      <view class="save-btn {{isGenerating ? 'is-loading' : ''}}"
            bindtap="onSaveImage"
            hover-class="save-btn-hover" hover-stay-time="100">
        <text class="save-btn-main">{{isGenerating ? '生成中…' : '保存图片到相册'}}</text>
        <text wx:if="{{needRewardedAd && !isGenerating}}" class="save-btn-sub">需观看广告后保存</text>
      </view>
    </view>
  </view>

  <!-- 离屏 Canvas：放在视野外，仅用于绘制海报后导出 -->
  <canvas type="2d" id="saveCanvas" class="save-canvas-offscreen" />
</view>

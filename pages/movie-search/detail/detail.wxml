<!-- 全平台电影评分查询：电影详情页（三平台聚合数据） -->
<view class="page-root">

  <view wx:if="{{loading}}" class="loading-state">
    <text>正在抓取数据…首次查询需要 10 秒左右</text>
  </view>

  <view wx:elif="{{error}}" class="error-state">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="onRefresh">重试</view>
  </view>

  <block wx:elif="{{movie}}">
    <view class="hero-section">
      <image class="hero-poster" src="{{movie.poster}}" mode="aspectFill" />
      <view class="hero-overlay">
        <text class="movie-title">{{movie.title}}</text>
        <view class="meta-line">
          <text wx:if="{{movie.year}}" class="meta-text">{{movie.year}}</text>
          <text wx:if="{{movie.directors && movie.directors.length}}" class="meta-text">· {{movie.directors[0]}}{{movie.directors.length > 1 ? ' 等' : ''}}</text>
        </view>
        <view wx:if="{{movie.genres && movie.genres.length}}" class="genre-row">
          <view wx:for="{{movie.genres}}" wx:key="*this" class="genre-tag">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="rating-grid">
      <!-- 豆瓣 -->
      <view class="rating-card douban">
        <view class="rating-card-header">
          <text class="platform-name">豆瓣</text>
        </view>
        <block wx:if="{{movie.douban && movie.douban.rating}}">
          <text class="rating-main">{{movie.douban.rating}}</text>
          <text class="rating-sub">{{movie.douban.votes || 0}} 人评分</text>
        </block>
        <view wx:else class="no-data">暂无数据</view>
      </view>

      <!-- IMDB -->
      <view class="rating-card imdb">
        <view class="rating-card-header">
          <text class="platform-name">IMDB</text>
        </view>
        <block wx:if="{{movie.imdb && movie.imdb.rating}}">
          <text class="rating-main">{{movie.imdb.rating}}</text>
          <text class="rating-sub">{{movie.imdb.votes || 0}} 人评分</text>
        </block>
        <view wx:else class="no-data">
          <text>{{movie.imdbId ? '暂无数据' : '无 IMDB 条目'}}</text>
        </view>
      </view>

      <!-- 烂番茄 -->
      <view class="rating-card rotten">
        <view class="rating-card-header">
          <text class="platform-name">烂番茄</text>
        </view>
        <block wx:if="{{movie.rottenTomatoes && movie.rottenTomatoes.score}}">
          <text class="rating-main">{{movie.rottenTomatoes.score}}</text>
          <text class="rating-sub">新鲜度</text>
        </block>
        <view wx:else class="no-data">
          <text>{{movie.imdbId ? '暂无数据' : '无烂番茄条目'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{movie.imdbId}}" class="info-row">
      <text class="info-label">IMDB ID</text>
      <text class="info-value">{{movie.imdbId}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">数据更新</text>
      <text class="info-value">{{updatedAtDisplay}}{{cached ? ' (缓存)' : ''}}</text>
    </view>

    <view class="action-bar">
      <view class="refresh-btn" bindtap="onRefresh" hover-class="refresh-btn-hover">
        <text>{{loading ? '刷新中…' : '刷新数据'}}</text>
      </view>
    </view>
  </block>
</view>

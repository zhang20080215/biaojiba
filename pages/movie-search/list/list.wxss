/* 全平台电影评分查询：用户查询历史列表 */

page {
  background-color: #1F2D3D;
}

.page-root {
  --ms-cta: #1F2D3D;
  --ms-cta-pressed: #34495E;
  --ms-bg: #F7F7F8;
  --ms-card: #FFFFFF;
  --ms-line: #E8E8EC;
  --ms-text: #1A1A1A;
  --ms-text-sub: #6F6F76;
  --ms-text-mute: #A0A0A8;
  --ms-douban: #2E8D2E;
  --ms-imdb: #B8860B;
  --ms-rt: #C7361A;
  --ms-disabled-bg: #E5E5E9;
  --ms-disabled-text: #9C9CA4;
  min-height: 100vh;
  background: var(--ms-bg);
  box-sizing: border-box;
  padding-bottom: var(--space-6);
}

/* ========== 顶部 toast ========== */
.ms-toast {
  position: fixed;
  top: 18%;
  left: 50%;
  transform: translate(-50%, -8rpx);
  z-index: 1000;
  max-width: 78vw;
  padding: 20rpx 28rpx;
  background: rgba(26, 26, 26, 0.92);
  color: #FFFFFF;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
  word-break: break-word;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease, transform 220ms ease;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
}
.ms-toast.is-show {
  opacity: 1;
  transform: translate(-50%, 0);
}
.ms-toast-icon {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #5EC85E;
  color: #FFFFFF;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
  font-weight: 700;
}

/* ========== Hero ========== */
.hero-section {
  position: relative;
  overflow: hidden;
  background: var(--ms-cta);
  padding: var(--space-5) var(--space-4) var(--space-6);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}
.hero-section::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -50rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 50%;
}

.header { position: relative; z-index: 1; }

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
  letter-spacing: 0.5rpx;
  display: block;
}
.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: var(--space-2);
  line-height: 1.5;
  display: block;
}

/* ========== 搜索入口卡片 ========== */
.search-entry-bar {
  margin: -32rpx var(--space-4) 0;
  position: relative;
  z-index: 2;
}

.search-entry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 28rpx var(--space-3);
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ms-cta);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: transform 120ms ease-out;
}
.search-entry-btn-hover {
  transform: scale(0.98);
  background: #FAFAFB;
}
.search-entry-plus {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  border-radius: 50%;
  background: var(--ms-cta);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

/* ========== 提示 / 空态 ========== */
.hint {
  padding: var(--space-4);
  text-align: center;
  font-size: 26rpx;
  color: var(--ms-text-sub);
}
.hint.error { color: #D63838; }

.empty-state {
  padding: 120rpx var(--space-4);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
}
.empty-illustration {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 2rpx dashed var(--ms-line);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: var(--space-2);
}
.empty-illustration::before,
.empty-illustration::after {
  content: '';
  position: absolute;
  background: var(--ms-disabled-bg);
  border-radius: 4rpx;
}
.empty-illustration::before {
  width: 76rpx;
  height: 4rpx;
  top: 58rpx;
}
.empty-illustration::after {
  width: 48rpx;
  height: 4rpx;
  bottom: 58rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--ms-text);
  font-weight: 500;
}
.empty-sub {
  font-size: 24rpx;
  color: var(--ms-text-mute);
  margin-top: -8rpx;
}
.empty-cta {
  margin-top: var(--space-2);
  padding: 20rpx 56rpx;
  background: var(--ms-cta);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-pill);
  transition: transform 120ms ease-out, background 120ms ease-out;
}
.empty-cta:active {
  background: var(--ms-cta-pressed);
  transform: scale(0.97);
}

/* ========== 电影列表（左滑出"更新 / 删除"两个操作） ========== */
.movie-list {
  padding: var(--space-3) var(--space-4) 0;
}

.movie-card-cell {
  position: relative;
  margin-bottom: var(--space-3);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.card-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 240rpx;
  display: flex;
  z-index: 0;
}
.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.action-btn:active { opacity: 0.85; }
.action-update {
  background: #6a8035;  /* 与 input 页深橄榄一致 */
}
.action-delete {
  background: #D63838;
}
.action-loading::before {
  content: '';
  display: inline-block;
  width: 22rpx;
  height: 22rpx;
  margin-right: 6rpx;
  vertical-align: -3rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: ms-spin 700ms linear infinite;
}

.movie-card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  padding: var(--space-3);
  background: var(--ms-card);
  border-radius: var(--radius-md);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 240ms cubic-bezier(0.4, 0, 0.2, 1);
}
.movie-card.is-swiped {
  transform: translateX(-240rpx);
}

.movie-card-head {
  display: flex;
  gap: var(--space-3);
  align-items: center;
}

.movie-poster {
  width: 100rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  background: var(--ms-line);
  flex-shrink: 0;
}

.movie-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.movie-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ms-text);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.movie-sub {
  font-size: 22rpx;
  color: var(--ms-text-sub);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 四平台评分行（豆瓣 / IMDB / 新鲜度 / 爆米花） ========== */
/* 跨满整张卡片宽度，每格 ≈ 145rpx 装得下"新鲜度"chip + 数字 + "222万人评" */
.rating-row {
  display: flex;
  gap: 12rpx;
  margin-top: 0;
}

.rating-cell {
  /* 固定 1/4 宽（扣 3 个 12rpx gap） */
  flex: 0 0 calc((100% - 36rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 8rpx 14rpx;
  background: #F7F7F8;
  border-radius: var(--radius-sm);
  min-width: 0;
  box-sizing: border-box;
}

.rating-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--ms-text-sub);
  letter-spacing: 0.5rpx;
  line-height: 1.2;
  white-space: nowrap;
}
.rating-label-douban,
.rating-label-imdb,
.rating-label-rt,
.rating-label-popcorn { background: transparent; }

.rating-value {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--ms-text);
  line-height: 1.1;
  margin-top: 10rpx;
  font-variant-numeric: tabular-nums;
}
.rating-value.is-empty {
  color: var(--ms-text-mute);
  font-weight: 600;
}

.rating-votes {
  font-size: 18rpx;
  color: var(--ms-text-mute);
  margin-top: 4rpx;
  line-height: 1.2;
  white-space: nowrap;
}

/* ========== 更新按钮 ========== */
.update-btn {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 64rpx;
  padding: 0 22rpx;
  line-height: 64rpx;
  background: var(--ms-cta);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-pill);
  text-align: center;
  transition: opacity 120ms ease-out, transform 120ms ease-out, background 120ms ease-out;
}
.update-btn-hover {
  background: var(--ms-cta-pressed);
  transform: scale(0.97);
}
.update-btn-loading { opacity: 0.65; }
.update-btn-loading::before {
  content: '';
  display: inline-block;
  width: 20rpx;
  height: 20rpx;
  margin-right: 6rpx;
  vertical-align: -3rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: ms-spin 700ms linear infinite;
}
.update-btn-disabled {
  background: var(--ms-disabled-bg);
  color: var(--ms-disabled-text);
}

@keyframes ms-spin { to { transform: rotate(360deg); } }

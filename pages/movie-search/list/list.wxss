/* 全平台电影评分查询：用户查询历史列表 */

page {
  background-color: var(--brand-primary);
}

.page-root {
  min-height: 100vh;
  background: #FFFFFF;
  box-sizing: border-box;
  padding-bottom: var(--space-6);
}

/* ========== Hero ========== */
.hero-section {
  position: relative;
  overflow: hidden;
  background: var(--brand-primary);
  padding: var(--space-5) var(--space-4) var(--space-6);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  background: var(--info);
  opacity: 0.35;
  border-radius: 50%;
}

.header {
  position: relative;
  z-index: 1;
}

.app-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
  letter-spacing: 1rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: var(--space-2);
  display: block;
}

/* ========== 搜索入口 ========== */
.search-entry-bar {
  margin: -32rpx var(--space-4) 0;
  position: relative;
  z-index: 2;
}

.search-entry-btn {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--brand-primary);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-entry-btn-hover {
  opacity: 0.7;
}

/* ========== 提示 / 空态 ========== */
.hint {
  padding: var(--space-4);
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.hint.error {
  color: var(--danger, #d63838);
}

.empty-state {
  padding: 120rpx var(--space-4);
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary, #999);
  display: block;
  margin-bottom: 32rpx;
}

.empty-cta {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: var(--brand-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* ========== 电影列表 ========== */
.movie-list {
  padding: var(--space-4);
}

.movie-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 120ms ease-out;
}

.movie-card-hover {
  transform: scale(0.985);
}

.movie-poster {
  width: 140rpx;
  height: 196rpx;
  border-radius: 10rpx;
  background: #EEE;
  flex-shrink: 0;
}

.movie-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.movie-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary, #1A1A1A);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.movie-year {
  font-size: 24rpx;
  color: var(--text-secondary, #888);
}

.rating-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.rating-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #F5F6F8;
  border-radius: 10rpx;
}

.rating-label {
  font-size: 22rpx;
  color: var(--text-secondary, #666);
  margin-bottom: 6rpx;
}

.rating-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--brand-primary);
  line-height: 1;
}

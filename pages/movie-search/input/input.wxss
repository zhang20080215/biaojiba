/* 全平台电影评分查询：输入页 */

page {
  background-color: var(--brand-primary);
}

.page-root {
  min-height: 100vh;
  background: #FFFFFF;
  box-sizing: border-box;
  padding-bottom: var(--space-6);
}

/* ========== Hero ========== */
.hero-section {
  position: relative;
  overflow: hidden;
  background: var(--brand-primary);
  padding: var(--space-5) var(--space-4) var(--space-6);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  background: var(--info);
  opacity: 0.35;
  border-radius: 50%;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: var(--warning);
  opacity: 0.25;
  border-radius: 50%;
}

.header {
  position: relative;
  z-index: 1;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.app-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: var(--space-2);
  line-height: 1.5;
}

/* ========== 搜索栏 ========== */
.search-bar {
  display: flex;
  gap: 16rpx;
  padding: var(--space-4);
  background: #FFFFFF;
  margin-top: -32rpx;
  border-radius: 24rpx 24rpx 0 0;
  position: relative;
  z-index: 2;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F5F6F8;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1A1A1A);
}

.search-btn {
  height: 80rpx;
  padding: 0 32rpx;
  line-height: 80rpx;
  background: var(--brand-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  transition: opacity 120ms ease-out;
}

.search-btn.disabled {
  opacity: 0.45;
}

.search-btn:active {
  opacity: 0.7;
}

/* ========== 提示区 ========== */
.hint-area {
  padding: 0 var(--space-4);
  min-height: 60rpx;
}

.hint {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
  padding: 16rpx 0;
}

.hint.error {
  color: var(--danger, #d63838);
}

/* ========== 候选列表 ========== */
.candidate-list {
  padding: var(--space-2) var(--space-4);
}

.candidate-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 120ms ease-out, box-shadow 120ms ease-out;
}

.candidate-card-hover {
  transform: scale(0.985);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.candidate-thumb {
  width: 90rpx;
  height: 126rpx;
  border-radius: 8rpx;
  background: #EEE;
  flex-shrink: 0;
}

.candidate-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.candidate-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #1A1A1A);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.candidate-year {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
}

.candidate-subtype {
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.candidate-arrow {
  font-size: 40rpx;
  color: var(--text-tertiary, #BBB);
  font-weight: 300;
  flex-shrink: 0;
}

/* ========== 历史入口 ========== */
.list-entry {
  margin: var(--space-5) var(--space-4) 0;
  padding: 24rpx;
  text-align: center;
  background: #F5F6F8;
  border-radius: 12rpx;
}

.list-entry-text {
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

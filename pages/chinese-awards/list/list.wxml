<view class="page-root">
  <view class="hero-section">
    <view class="hero-overlay hero-overlay-right"></view>
    <view class="hero-overlay hero-overlay-left"></view>
    <view class="hero-content">
      <view class="hero-top-row">
        <view class="user-profile-section" bindtap="onHeaderLoginClick">
          <image class="avatar-small" src="{{userInfo.avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
          <text class="nickname-small">{{userInfo.nickName || '点击登录'}}</text>
        </view>
        <view class="home-nav-section" bindtap="onBackHome">
          <text class="home-text">首页</text>
        </view>
      </view>

      <view class="hero-title-area">
        <view class="hero-kicker">四大奖项榜单</view>
        <view class="hero-title">华语电影最高荣誉殿堂</view>
        <view class="hero-subtitle">金马奖、金像奖、金鸡奖、百花奖历年最佳影片</view>
      </view>

      <view class="hero-progress-card">
        <view class="hero-progress-head">
          <text class="hero-progress-label">已看进度</text>
          <text class="hero-progress-percent">{{watchPercent}}%</text>
        </view>
        <view class="hero-progress-bar">
          <view class="hero-progress-fill" style="width: {{watchPercent}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="filter-surface">
    <scroll-view class="award-filter-scroll" scroll-x="true" show-scrollbar="false">
      <view class="award-filter-row">
        <block wx:for="{{awardFilters}}" wx:key="key">
          <view class="award-filter-chip {{activeAwardKey === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="onAwardFilterTap">{{item.label}}</view>
        </block>
      </view>
    </scroll-view>
  </view>

  <view class="sticky-top-group">
    <view class="tabs-shell">
      <view class="tabs-bar">
        <view class="tab {{activeTab === 0 ? 'active' : ''}}" data-idx="0" bindtap="onTabChange">
          <text class="tab-label">全部</text>
          <text class="tab-count">{{allCount}}</text>
        </view>
        <view class="tab {{activeTab === 1 ? 'active' : ''}}" data-idx="1" bindtap="onTabChange">
          <text class="tab-label">已看</text>
          <text class="tab-count">{{watchedCount}}</text>
        </view>
        <view class="tab {{activeTab === 2 ? 'active' : ''}}" data-idx="2" bindtap="onTabChange">
          <text class="tab-label">想看</text>
          <text class="tab-count">{{wishCount}}</text>
        </view>
        <view class="tab {{activeTab === 3 ? 'active' : ''}}" data-idx="3" bindtap="onTabChange">
          <text class="tab-label">未看</text>
          <text class="tab-count">{{unwatchedCount}}</text>
        </view>
      </view>
    </view>

    <view class="sticky-action-container">
      <view class="middle-action-section {{userInfo ? '' : 'align-right'}}">
        <view wx:if="{{userInfo}}" class="batch-options">
          <block wx:if="{{!isBatchEditing}}">
            <view class="icon-btn batch-icon" bindtap="onStartBatchEdit">批量标记</view>
          </block>
          <block wx:elif="{{isBatchEditing}}">
            <view class="icon-btn action-watched" bindtap="onBatchWatch">批量已看</view>
            <view class="icon-btn action-wish" bindtap="onBatchWish">批量想看</view>
            <view class="icon-btn action-cancel" bindtap="onCancelBatchEdit">取消</view>
          </block>
        </view>
        <view class="generate-card-wrapper" bindtap="onShareTap" wx:if="{{!isBatchEditing}}">
          <view class="generate-card-btn">生成观影海报</view>
        </view>
        <view class="hero-tip" wx:if="{{isBatchEditing}}">
          <text class="hero-tip-text">豆瓣搜不到的条目不会展示</text>
        </view>
      </view>
    </view>
  </view>

  <view class="movie-list">
    <block wx:if="{{movies.length}}">
      <block wx:for="{{movies}}" wx:key="_id">
        <view wx:if="{{showInfeedAd && (index === 10 || index === 50)}}" class="ad-infeed-container">
          <ad-custom unit-id="{{adUnitIds.movielist_infeed}}" bindload="onInfeedAdLoad" binderror="onInfeedAdError"></ad-custom>
        </view>
        <view class="movie-row {{markStatusMap[item._id] === 'watched' ? 'is-watched' : ''}}" bindtap="{{isBatchEditing ? 'onMovieCheck' : ''}}" data-movie-id="{{item._id}}">
          <view wx:if="{{isBatchEditing}}" class="batch-checkbox-wrap">
            <checkbox class="batch-checkbox" value="{{item._id}}" checked="{{item.checked}}" catchtap="onMovieCheck" data-movie-id="{{item._id}}" />
          </view>

          <view class="movie-content {{isBatchEditing ? 'batch-editing' : ''}}">
            <image class="movie-thumb" src="{{item.thumbCover || item.cover || '/images/default-movie.jpg'}}" lazy-load="true" mode="aspectFill" binderror="onImageError" bindload="onImageLoad" data-movie-id="{{item._id}}" show-menu-by-longpress="false" />

            <view class="movie-info">
              <view class="movie-title">{{item.title}}</view>
              <view class="movie-tag-row">
                <text class="meta-tag">{{item.awardYear}}</text>
                <text class="meta-tag">{{item.awardCeremony}}</text>
                <text class="meta-tag rating">豆瓣 {{item.ratingText}}</text>
              </view>
              <view wx:if="{{item.director}}" class="movie-director">导演：{{item.director}}</view>
              <view wx:if="{{item.playPlatformsText}}" class="movie-platforms">播放平台：{{item.playPlatformsText}}</view>
            </view>

            <view class="movie-action" wx:if="{{!isBatchEditing}}">
              <block wx:if="{{markStatusMap[item._id] === 'watched'}}">
                <view class="mark-tag watched">{{markDateMap[item._id] || ''}}已看</view>
              </block>
              <block wx:elif="{{markStatusMap[item._id] === 'wish'}}">
                <view class="mark-tag wish">{{markDateMap[item._id] || ''}}想看</view>
              </block>
              <block wx:else>
                <button class="mark-btn mark-btn-wish" data-id="{{item._id}}" data-type="wish" catchtap="onMarkTap">想看</button>
                <button class="mark-btn" data-id="{{item._id}}" data-type="watched" catchtap="onMarkTap">已看</button>
              </block>
            </view>
          </view>
        </view>
      </block>
    </block>

    <view wx:else class="empty-state">
      <view class="empty-title">当前筛选下暂无可展示电影</view>
      <view class="empty-desc">可以切换奖项或状态筛选，查看其他最佳影片。</view>
    </view>
  </view>

  <view class="auth-modal" hidden="{{!showAuthModal}}">
    <view class="auth-mask" bindtap="onCancelAuth"></view>
    <view class="auth-content">
      <view class="auth-decoration"></view>
      <view class="auth-title">完善个人资料</view>
      <view class="auth-subtitle">登录后即可标记和管理你的观影进度</view>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="temp-avatar" src="{{tempAvatar || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <view class="avatar-edit-tip">点击选择头像</view>
      </button>
      <view class="nickname-input-group">
        <text class="input-label">昵称</text>
        <input type="nickname" class="nickname-input" placeholder="请输入昵称" bindinput="onNicknameInput" bindblur="onNicknameInput" value="{{tempNickname}}" />
      </view>
      <view class="auth-actions">
        <button class="auth-btn cancel" bindtap="onCancelAuth">暂不登录</button>
        <button class="auth-btn confirm" bindtap="onConfirmAuth">保存并登录</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showSharePicker}}" class="share-picker show" catchtouchmove="onSharePickerTouchMove">
    <view class="share-picker-mask" bindtap="onCloseSharePicker"></view>
    <view class="share-picker-panel">
      <view class="share-picker-header">
        <text class="share-picker-title">选择海报样式</text>
        <view class="share-picker-close" bindtap="onCloseSharePicker">×</view>
      </view>
      <view class="share-picker-options">
        <view class="share-option" bindtap="onShareTypeSelect" data-type="poster">
          <view class="share-option-icon">
            <image class="share-option-icon-img" src="/images/icon-share-poster.svg" mode="aspectFit"></image>
          </view>
          <view class="share-option-info">
            <text class="share-option-name">海报墙</text>
            <text class="share-option-desc">将已看电影封面拼成观影海报</text>
          </view>
          <text class="share-option-arrow">›</text>
        </view>
        <view class="share-option" bindtap="onShareTypeSelect" data-type="text">
          <view class="share-option-icon">
            <image class="share-option-icon-img" src="/images/icon-share-text.svg" mode="aspectFit"></image>
          </view>
          <view class="share-option-info">
            <text class="share-option-name">文字卡片</text>
            <text class="share-option-desc">展示全部奖项电影的标记状态</text>
          </view>
          <text class="share-option-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>

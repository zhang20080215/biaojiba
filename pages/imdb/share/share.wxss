.share-page {
  min-height: 100vh;
  position: relative;
  background: #FFFCF5;
  box-sizing: border-box;
  padding-bottom: calc(208rpx + env(safe-area-inset-bottom));
}

.immersive-top {
  padding-left: var(--space-3);
  padding-right: var(--space-3);
  padding-bottom: var(--space-2);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
}

.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

.top-right {
  width: 56rpx;
  height: 56rpx;
}

.theme-scroll {
  flex: 0 1 auto;
  white-space: nowrap;
  padding-bottom: 4rpx;
}

.bg-panel {
  margin-top: var(--space-2);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-xl);
  background: #F8F3E7;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(237, 231, 218, 0.92);
  box-shadow: 0 4rpx 14rpx rgba(45, 45, 43, 0.05);
}

.bg-panel-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: var(--space-2);
  flex: 0 0 auto;
}

.theme-chip {
  display: inline-flex;
  align-items: center;
  height: 54rpx;
  padding: 0 18rpx;
  margin-right: 12rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid transparent;
  transition: transform 120ms ease-out, box-shadow 120ms ease-out, border-color 120ms ease-out;
}

.theme-chip.active {
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(45, 45, 43, 0.08);
  border-color: rgba(182, 202, 235, 0.95);
  transform: translateY(-1rpx);
}

.theme-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

.theme-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.theme-check {
  margin-left: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #6A89B6;
  line-height: 1;
}

.content-wrap {
  padding: 0 var(--space-3);
}

.share-card {
  background: linear-gradient(135deg, #FDECEC 0%, #D2F1FE 100%);
  border-radius: var(--radius-xl);
  padding: 18rpx 24rpx 18rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.share-card.poster-wall {
  display: flex;
  flex-direction: column;
}

.share-card.text-list-card {
  aspect-ratio: 1242 / 1660;
  display: flex;
  flex-direction: column;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.25;
}

.stats-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
  justify-content: center;
}

.stat-item {
  border-radius: var(--radius-pill);
  padding: 8rpx 16rpx;
  display: inline-flex;
  align-items: center;
  border: 1rpx solid transparent;
  background: rgba(255, 255, 255, 0.42);
}

.stat-item.watched {
  border-color: rgba(154, 171, 101, 0.2);
}

.stat-item.watched .stat-inline {
  color: #9AAB65;
}

.stat-item.wish {
  border-color: rgba(212, 168, 40, 0.2);
}

.stat-item.wish .stat-inline {
  color: #D4A828;
}

.stat-item.unwatched {
  border-color: rgba(156, 153, 143, 0.2);
}

.stat-item.unwatched .stat-inline {
  color: #9C998F;
}

.stat-inline {
  font-size: 22rpx;
  font-weight: 500;
}

.poster-grid {
  display: grid;
  flex: 1;
  align-content: start;
}

.poster-item {
  aspect-ratio: 2 / 3;
  border-radius: 6rpx;
  overflow: hidden;
  background: rgba(248, 243, 231, 0.9);
}

.poster-image {
  width: 100%;
  height: 100%;
  display: block;
}

.style-toggle {
  display: flex;
  gap: 12rpx;
}

.style-chip {
  display: flex;
  align-items: center;
  height: 54rpx;
  padding: 0 20rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid transparent;
  transition: transform 120ms ease-out, box-shadow 120ms ease-out, border-color 120ms ease-out;
}

.style-chip.active {
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(45, 45, 43, 0.08);
  border-color: rgba(182, 202, 235, 0.95);
  transform: translateY(-1rpx);
}

.style-chip-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.movie-grid {
  padding: 0;
  flex: 1;
}

.movie-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.movie-list-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  grid-auto-flow: column;
  gap: 0;
  flex: 1;
  align-content: start;
}

.movie-list-item {
  display: flex;
  align-items: center;
  padding: 3rpx 0;
  overflow: hidden;
}

.movie-list-dot {
  width: 12rpx;
  height: 12rpx;
  min-width: 12rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.movie-list-item.watched .movie-list-dot {
  background: #9AAB65;
}

.movie-list-item.wish .movie-list-dot {
  background: #D4A828;
}

.movie-list-item.unwatched .movie-list-dot {
  background: #9C998F;
}

.movie-list-title {
  font-size: 16rpx;
  font-weight: 500;
  color: rgba(45, 45, 43, 0.82);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.movie-list-item.watched .movie-list-title {
  text-decoration: line-through;
  text-decoration-color: rgba(45, 45, 43, 0.55);
}

.movie-tag {
  max-width: 100%;
  padding: 8rpx 14rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-mini);
  border: 1rpx solid transparent;
  line-height: 1.35;
}

.movie-tag.watched {
  background: var(--success-soft);
  color: var(--success);
  border-color: rgba(154, 171, 101, 0.25);
  text-decoration: line-through;
  text-decoration-color: rgba(154, 171, 101, 0.7);
}

.movie-tag.wish {
  background: var(--warning-soft);
  color: #D4A828;
  border-color: rgba(212, 168, 40, 0.25);
}

.movie-tag.unwatched {
  background: var(--bg-section);
  color: var(--text-muted);
  border-color: var(--line-subtle);
}

.empty-tip {
  text-align: center;
  color: var(--text-muted);
  font-size: var(--font-caption);
  padding: var(--space-4) 0;
}

.watermark-text {
  margin-top: 18rpx;
  text-align: center;
  font-size: var(--font-mini);
  font-weight: 600;
  color: rgba(45, 45, 43, 0.72);
}

.save-btn-container {
  position: fixed;
  left: var(--space-3);
  right: var(--space-3);
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 20;
}

.save-btn {
  height: 88rpx;
  border-radius: var(--radius-pill);
  background: var(--brand-primary);
  color: var(--text-primary);
  font-size: var(--font-body);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-cta);
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  opacity: 0.5;
}

.ad-banner-container {
  margin: var(--space-3) var(--space-3) 0;
}

.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.34);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.35);
  border-top-color: #FFFFFF;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  margin-top: var(--space-2);
  color: #FFFFFF;
  font-size: var(--font-caption);
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

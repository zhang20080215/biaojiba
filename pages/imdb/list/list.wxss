@import "../../douban/list/list.wxss";

.movie-content {
  min-width: 0;
  align-items: flex-start;
}

.movie-info {
  min-width: 0;
  padding-right: var(--space-2);
}

.movie-title {
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-height: 1.35;
  max-height: calc(1.35em * 2);
}

.movie-action {
  flex: 0 0 auto;
  align-self: center;
}

.movie-meta-chip {
  font-size: var(--font-mini);
  font-weight: 600;
  color: var(--text-secondary);
  background: rgba(156, 153, 143, 0.12);
  padding: 4rpx var(--space-2);
  border-radius: var(--radius-pill);
}

.movie-extra-line,
.movie-extra-line.secondary {
  margin-top: 6rpx;
  font-size: var(--font-caption);
  color: var(--text-secondary);
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.movie-extra-line.secondary {
  color: var(--text-muted);
}

<view class="page-root">
  <view class="top-toast {{toast.show ? 'is-show' : ''}}">
    <text class="top-toast-icon" wx:if="{{toast.icon === 'success'}}">✓</text>
    <text class="top-toast-text">{{toast.text}}</text>
  </view>

  <view class="custom-nav" style="height: {{navOffset}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar" style="height: {{navBarHeight}}px;">
      <view class="nav-btn nav-btn-left" bindtap="onBack" hover-class="nav-btn-active">
        <text class="nav-chev">‹</text>
      </view>
      <text class="nav-title">添加电影</text>
    </view>
  </view>

  <view class="content" style="padding-top: {{navOffset}}px;">
    <!-- 日期：简洁右对齐 -->
    <view class="date-row">
      <text class="date-row-label">记录到</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="date-pill">
          <text class="date-pill-text">{{dateText}}</text>
          <text class="date-pill-chev">›</text>
        </view>
      </picker>
    </view>

    <!-- 搜索 -->
    <view class="card">
      <view class="card-title">搜索电影</view>

      <view class="search-row">
        <view class="search-input-wrap">
          <text class="search-icon">⌕</text>
          <input class="search-input"
                 placeholder="输入电影名称"
                 placeholder-class="placeholder"
                 value="{{keyword}}"
                 bindinput="onKeywordInput"
                 bindconfirm="onSearch"
                 confirm-type="search"
                 maxlength="50" />
          <text wx:if="{{keyword}}" class="clear-x" bindtap="onClearKeyword">✕</text>
        </view>
        <view class="search-btn {{keyword ? '' : 'disabled'}}" bindtap="onSearch">{{searching ? '搜索中' : '搜索'}}</view>
      </view>

      <text wx:if="{{searching}}" class="hint">搜索中...</text>
      <text wx:elif="{{error}}" class="hint error">{{error}}</text>
      <text wx:elif="{{searched && candidates.length === 0}}" class="hint">没找到匹配的电影，换个关键词试试</text>

      <!-- 候选列表（未选中时，点整张卡片即选中） -->
      <view wx:if="{{!selected && candidates.length > 0}}" class="candidate-list">
        <view class="candidate-card"
              wx:for="{{candidates}}"
              wx:key="doubanId"
              data-douban-id="{{item.doubanId}}"
              bindtap="onSelectMovie"
              hover-class="tap-soft">
          <image class="candidate-poster" src="{{item.posterThumb || '/images/default-movie.jpg'}}" mode="aspectFill" lazy-load="true" />
          <view class="candidate-info">
            <text class="candidate-title">{{item.title}}</text>
            <view wx:if="{{item.ratingText}}" class="candidate-rating">
              <text class="cand-score">豆瓣 {{item.ratingText}}</text>
              <text wx:if="{{item.votesText}}" class="cand-votes">{{item.votesText}}</text>
            </view>
            <text wx:if="{{item.year}}" class="candidate-meta">{{item.year}}</text>
            <text wx:if="{{item.director}}" class="candidate-meta">导演：{{item.director}}</text>
            <text wx:if="{{item.subtype && !item.director}}" class="candidate-meta">{{item.subtype}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 选中电影：电影信息 + 全平台评分 + 我的评分 + 短评，同一张卡片 -->
    <view wx:if="{{selected}}" class="card">
      <view class="movie-head">
        <image class="movie-poster" src="{{posterSrc}}" mode="aspectFill" />
        <view class="movie-head-info">
          <text class="movie-title">{{selected.title}}</text>
          <text wx:if="{{movieMeta}}" class="movie-meta">{{movieMeta}}</text>
        </view>
        <view class="del-btn" bindtap="onReselect" hover-class="tap-soft">✕</view>
      </view>

      <!-- 全平台评分 -->
      <view wx:if="{{ratingsLoading}}" class="ratings-loading">
        <view class="rl-spinner"></view>
        <text class="rl-text">正在获取豆瓣 · IMDb · 烂番茄评分…</text>
      </view>
      <view wx:elif="{{ratingCells.length}}" class="ratings">
        <view class="rating-cell" wx:for="{{ratingCells}}" wx:key="label">
          <text class="rating-label">{{item.label}}</text>
          <text class="rating-value {{item.value === '—' ? 'is-empty' : ''}}">{{item.value}}</text>
          <text class="rating-sub">{{item.sub}}</text>
        </view>
      </view>
      <view wx:else class="ratings-fail">{{ratingsError || '暂无全平台评分'}}</view>

      <view class="divider"></view>

      <!-- 我的评分（点亮五角星，最少半颗） -->
      <view class="field">
        <view class="field-head">
          <text class="field-label">我的评分</text>
          <text class="rating-readout {{rating > 0 ? 'is-active' : ''}}">{{ratingLabel}}</text>
        </view>
        <view class="star-row"
              bindtouchstart="onStarTouchStart"
              catchtouchmove="onStarTouchMove">
          <view class="star" wx:for="{{stars}}" wx:key="index">
            <text class="star-base">★</text>
            <view class="star-fill star-{{item}}"><text class="star-glyph">★</text></view>
          </view>
        </view>
      </view>

      <!-- 心情：网格末位为「更多」，点击弹窗选更多 -->
      <view class="field">
        <text class="field-label">心情</text>
        <view class="mood-grid">
          <view wx:for="{{visibleMoods}}" wx:key="key"
                class="mood-chip {{mood === item.key ? 'active' : ''}}"
                data-key="{{item.key}}"
                bindtap="onMoodTap">
            <text class="mood-emoji">{{item.emoji}}</text>
            <text class="mood-label">{{item.label}}</text>
          </view>
          <view class="mood-chip mood-more" bindtap="onOpenMoodModal">
            <text class="mood-emoji">⋯</text>
            <text class="mood-label">更多</text>
          </view>
        </view>
      </view>

      <!-- 短评 -->
      <view class="field">
        <view class="field-head">
          <text class="field-label">短评</text>
          <text class="count">{{noteCount}}/140</text>
        </view>
        <textarea class="note"
                  value="{{note}}"
                  maxlength="140"
                  placeholder="写一句看完后的感受（可不填）"
                  placeholder-class="placeholder"
                  bindinput="onNoteInput" />
      </view>
    </view>

    <!-- 底部提交 -->
    <view wx:if="{{selected}}" class="submit-bar">
      <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
        {{submitting ? '记录中...' : '添加观影记录'}}
      </view>
    </view>
  </view>

  <!-- 更多心情弹窗 -->
  <view class="mood-modal" wx:if="{{moodModal}}" catchtouchmove="true">
    <view class="mood-modal-mask" bindtap="onCloseMoodModal"></view>
    <view class="mood-modal-sheet">
      <view class="mood-modal-head">
        <text class="mood-modal-title">选择心情</text>
        <text class="mood-modal-close" bindtap="onCloseMoodModal">✕</text>
      </view>
      <view class="mood-modal-grid">
        <view wx:for="{{moods}}" wx:key="key"
              class="mood-chip {{mood === item.key ? 'active' : ''}}"
              data-key="{{item.key}}"
              bindtap="onPickMood">
          <text class="mood-emoji">{{item.emoji}}</text>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

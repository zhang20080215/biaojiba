page {
  min-height: 100vh;
  background: #FAF6EB;
}
.page-root {
  min-height: 100vh;
  color: #1A1A1A;
  font-family: -apple-system, "PingFang SC", system-ui;
}
.top-toast {
  position: fixed;
  top: 22%;
  left: 50%;
  transform: translate(-50%, -8rpx);
  z-index: 1000;
  background: rgba(26, 26, 26, 0.88);
  color: #fff;
  padding: 18rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease, transform 220ms ease;
}
.top-toast.is-show {
  opacity: 1;
  transform: translate(-50%, 0);
}
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: #FAF6EB;
}
.nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
}
.nav-btn {
  position: absolute;
  top: 50%;
  left: 22rpx;
  width: 76rpx;
  height: 76rpx;
  margin-top: -38rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-btn-active {
  background: rgba(26, 26, 26, 0.06);
}
.nav-chev {
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}
.content {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}
.year-head {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 34rpx;
}
.year-arrow {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #6B6356;
}
.year-arrow.is-disabled {
  opacity: 0.25;
}
.year-label {
  min-width: 180rpx;
  text-align: center;
  font-size: 52rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}
.state-text,
.empty {
  padding: 110rpx 0;
  text-align: center;
  color: #A89E8C;
}
.empty-title {
  display: block;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 800;
}
.empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
}
.month-grid {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.month-card {
  background: #FFFFFF;
  border: 2rpx solid #E8E0CC;
  border-radius: 22rpx;
  padding: 24rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.month-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #FAF6EB;
  border: 2rpx solid #ECE4D2;
  font-size: 54rpx;
  line-height: 96rpx;
  text-align: center;
}
.month-icon.icon-empty {
  color: #D8CDB4;
  border-style: dashed;
}
.month-name {
  margin-top: 14rpx;
  font-size: 26rpx;
  font-weight: 800;
}
.month-count {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #A89E8C;
}
.review {
  margin-top: 34rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8E0CC;
  border-radius: 28rpx;
  padding: 28rpx;
}
.review-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
}
.review-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.review-item {
  background: #FAF6EB;
  border-radius: 20rpx;
  padding: 20rpx;
}
.review-label {
  display: block;
  font-size: 22rpx;
  color: #A89E8C;
  font-weight: 700;
}
.review-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 800;
}
.director-line {
  margin-top: 18rpx;
  background: #FAF6EB;
  border-radius: 20rpx;
  padding: 20rpx;
}

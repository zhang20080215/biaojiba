/* pages/daily/stats/stats.wxss */
page {
  min-height: 100vh;
  background: #FAF6EB;
}

/* ==== 顶部 toast（中上部，替代 wx.showToast 的中央位置）==== */
.top-toast {
  position: fixed;
  top: 22%;
  left: 50%;
  transform: translate(-50%, -8rpx);
  z-index: 1000;
  background: rgba(26, 26, 26, 0.88);
  color: #ffffff;
  padding: 18rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease, transform 220ms ease;
  white-space: nowrap;
  max-width: 80vw;
}
.top-toast.is-show {
  opacity: 1;
  transform: translate(-50%, 0);
}
.top-toast-icon {
  font-size: 30rpx;
  font-weight: 700;
}

.page-root {
  min-height: 100vh;
  color: #1A1A1A;
  position: relative;
  overflow-x: hidden;
  box-sizing: border-box;
  font-family: -apple-system, "PingFang SC", "Hiragino Sans GB", system-ui;
}

/* ==== Nav ==== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: #FAF6EB;
  box-sizing: border-box;
}
.nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.nav-btn {
  position: absolute;
  top: 50%;
  width: 76rpx;
  height: 76rpx;
  margin-top: -38rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1A1A1A;
}
.nav-btn-left { left: 22rpx; }
.nav-btn-active { background: rgba(26, 26, 26, 0.06); }
.nav-chev {
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

/* ==== Content ==== */
.content {
  padding: 0 44rpx 80rpx;
  box-sizing: border-box;
}

/* 分段控件 */
.seg {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: #EFE7D2;
  border-radius: 22rpx;
  padding: 6rpx;
}
.seg-item {
  height: 70rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B6356;
  font-size: 26rpx;
  font-weight: 600;
}
.seg-item.active {
  background: #FFFFFF;
  color: #1A1A1A;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

/* Headline */
.headline {
  margin-top: 28rpx;
  text-align: center;
  padding-bottom: 16rpx;
}
.headline-cap {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #A89E8C;
  letter-spacing: 0.12em;
}
.headline-num {
  margin-top: 14rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6rpx;
}
.hnum {
  font-size: 104rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -0.03em;
  line-height: 0.95;
  font-variant-numeric: tabular-nums;
}
.hunit {
  font-size: 32rpx;
  font-weight: 500;
  color: #6B6356;
}
.headline-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #A89E8C;
}

/* 卡片 */
.card {
  margin-top: 12rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8E0CC;
  border-radius: 36rpx;
  padding: 36rpx 32rpx 28rpx;
  box-sizing: border-box;
}
.card-title {
  display: block;
  font-size: 24rpx;
  color: #6B6356;
  font-weight: 600;
  margin-bottom: 24rpx;
}

/* 周/月翻页 nav */
.period-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}
.period-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B6356;
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
}
.period-arrow.is-disabled {
  opacity: 0.25;
}
.period-arrow-active {
  background: rgba(26, 26, 26, 0.06);
}
.period-label {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}

/* 柱状（水柱）*/
.bars {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding-top: 8rpx;
}
.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}
.bar-pct {
  font-size: 18rpx;
  font-weight: 600;
  color: #A89E8C;
  height: 22rpx;
  line-height: 22rpx;
  font-variant-numeric: tabular-nums;
}
.bar-pct-hit {
  color: #2A8BC4;
}
.bar-label {
  font-size: 22rpx;
  color: #A89E8C;
  font-weight: 500;
}
.wc-future {
  opacity: 0.5;
}

/* WaterColumn 水柱外框 */
.wc {
  width: 56rpx;
  height: 260rpx;
  border-radius: 20rpx;
  border: 3rpx solid #E8E0CC;
  background: #FFFFFF;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}
.wc-achieved {
  border-color: #1A1A1A;
}
.wc-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #2A8BC4;
  transition: height 320ms ease;
}
.wc-wave {
  position: absolute;
  top: -4rpx;
  left: -6rpx;
  right: -6rpx;
  height: 14rpx;
  background: #B8E0F2;
  border-radius: 50%;
  opacity: 0.85;
}

/* 月视图日历（周一开头，7 列）*/
.cal-head {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 10rpx;
}
.cal-head-cell {
  text-align: center;
  font-size: 20rpx;
  color: #A89E8C;
  font-weight: 600;
  letter-spacing: 0.02em;
}
.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 14rpx 8rpx;
  padding: 4rpx 0 4rpx;
}
.cal-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}
.cal-empty {
  visibility: hidden;
}
.cal-cell-future {
  opacity: 0.5;
}

.wc-small {
  width: 48rpx;
  height: 96rpx;
  border-radius: 14rpx;
  border-width: 2rpx;
}
.wc-small .wc-fill {
  background: #2A8BC4;
}
.cal-day {
  font-size: 20rpx;
  color: #A89E8C;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}
.cal-day-hit {
  color: #1A1A1A;
}

/* KPI 4 宫格 */
.kpi-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
.kpi-tile {
  background: #FFFFFF;
  border: 2rpx solid #E8E0CC;
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}
.kpi-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #A89E8C;
}
.kpi-value-row {
  margin-top: 10rpx;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.kpi-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.kpi-unit {
  font-size: 24rpx;
  color: #6B6356;
}


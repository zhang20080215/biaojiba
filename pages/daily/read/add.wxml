<view class="page-root">
  <view class="top-toast {{toast.show ? 'is-show' : ''}}">
    <text class="top-toast-icon" wx:if="{{toast.icon === 'success'}}">✓</text>
    <text class="top-toast-text">{{toast.text}}</text>
  </view>

  <view class="custom-nav" style="height: {{navOffset}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar" style="height: {{navBarHeight}}px;">
      <view class="nav-btn nav-btn-left" bindtap="onBack" hover-class="nav-btn-active">
        <text class="nav-chev">‹</text>
      </view>
      <text class="nav-title">添加图书</text>
    </view>
  </view>

  <view class="content" style="padding-top: {{navOffset}}px;">
    <!-- 日期：简洁右对齐 -->
    <view class="date-row">
      <text class="date-row-label">记录到</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="date-pill">
          <text class="date-pill-text">{{dateText}}</text>
          <text class="date-pill-chev">›</text>
        </view>
      </picker>
    </view>

    <!-- 搜索 -->
    <view class="card">
      <view class="card-title">搜索书籍</view>

      <view class="search-row">
        <view class="search-input-wrap">
          <text class="search-icon">⌕</text>
          <input class="search-input"
                 placeholder="输入书名"
                 placeholder-class="placeholder"
                 value="{{keyword}}"
                 bindinput="onKeywordInput"
                 bindconfirm="onSearch"
                 confirm-type="search"
                 maxlength="50" />
          <text wx:if="{{keyword}}" class="clear-x" bindtap="onClearKeyword">✕</text>
        </view>
        <view class="search-btn {{keyword ? '' : 'disabled'}}" bindtap="onSearch">{{searching ? '搜索中' : '搜索'}}</view>
      </view>

      <text wx:if="{{searching}}" class="hint">搜索中...</text>
      <text wx:elif="{{error}}" class="hint error">{{error}}</text>
      <text wx:elif="{{searched && candidates.length === 0}}" class="hint">没找到匹配的书，换个关键词试试</text>

      <!-- 候选列表（未选中时，点整张卡片即选中） -->
      <view wx:if="{{!selected && candidates.length > 0}}" class="candidate-list">
        <view class="candidate-card"
              wx:for="{{candidates}}"
              wx:key="doubanId"
              data-douban-id="{{item.doubanId}}"
              bindtap="onSelectMovie"
              hover-class="tap-soft">
          <image class="candidate-poster" src="{{item.posterThumb || '/images/default-movie.jpg'}}" mode="aspectFill" lazy-load="true" binderror="onCandCoverError" data-index="{{index}}" />
          <view class="candidate-info">
            <text class="candidate-title">{{item.title}}</text>
            <view wx:if="{{item.ratingText}}" class="candidate-rating">
              <text class="cand-score">豆瓣 {{item.ratingText}}</text>
              <text wx:if="{{item.votesText}}" class="cand-votes">{{item.votesText}}</text>
            </view>
            <text wx:if="{{item.author}}" class="candidate-meta">作者：{{item.author}}</text>
            <text wx:if="{{item.pubText}}" class="candidate-meta">{{item.pubText}}</text>
            <text wx:elif="{{item.subtype && !item.author}}" class="candidate-meta">{{item.subtype}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 选中书籍：与搜索结果同款排版（封面 + 书名 + 豆瓣评分/人数 + 作者 + 出版社·年份） -->
    <view wx:if="{{selected}}" class="card">
      <view class="selected-head">
        <image class="candidate-poster" src="{{selected.posterThumb || '/images/default-movie.jpg'}}" mode="aspectFill" binderror="onSelCoverError" />
        <view class="candidate-info">
          <text class="candidate-title">{{selected.title}}</text>
          <view wx:if="{{selected.ratingText}}" class="candidate-rating">
            <text class="cand-score">豆瓣 {{selected.ratingText}}</text>
            <text wx:if="{{selected.votesText}}" class="cand-votes">{{selected.votesText}}</text>
          </view>
          <text wx:if="{{selected.author}}" class="candidate-meta">作者：{{selected.author}}</text>
          <text wx:if="{{selected.publisherText}}" class="candidate-meta">出版社：{{selected.publisherText}}</text>
          <text wx:if="{{selected.year}}" class="candidate-meta">出版年：{{selected.year}}</text>
          <text class="candidate-meta">总页数：{{selected.pagesText}}</text>
        </view>
        <view class="del-btn" bindtap="onReselect" hover-class="tap-soft">✕</view>
      </view>

      <view class="divider"></view>

      <!-- 我的评分（点亮五角星，最少半颗） -->
      <view class="field">
        <view class="field-head">
          <text class="field-label">我的评分</text>
          <text class="rating-readout {{rating > 0 ? 'is-active' : ''}}">{{ratingLabel}}</text>
        </view>
        <view class="star-row" bindtouchstart="onStarTouchStart" catchtouchmove="onStarTouchMove">
          <view class="star" wx:for="{{stars}}" wx:key="index">
            <text class="star-base">★</text>
            <view class="star-fill star-{{item}}"><text class="star-glyph">★</text></view>
            <view class="star-hit star-hit-l" catchtap="onStarTap" data-value="{{index + 0.5}}"></view>
            <view class="star-hit star-hit-r" catchtap="onStarTap" data-value="{{index + 1}}"></view>
          </view>
        </view>
      </view>

      <!-- 阅读进度：当前页可输入，总页数来自豆瓣详情（未知时只记当前页、不显示分母） -->
      <view class="field">
        <view class="field-head">
          <text class="field-label">阅读进度</text>
          <text wx:if="{{progressText}}" class="rating-readout is-active">{{progressText}}</text>
        </view>
        <view class="progress-row">
          <input class="page-input"
                 type="number"
                 value="{{currentPage}}"
                 placeholder="0"
                 placeholder-class="placeholder"
                 maxlength="5"
                 bindinput="onCurrentPageInput" />
          <text wx:if="{{totalPages}}" class="page-sep">/</text>
          <text wx:if="{{totalPages}}" class="page-total">{{totalPages}}</text>
          <text class="page-unit">页</text>
        </view>
      </view>

      <!-- 心情：网格末位为「更多」，点击弹窗选更多 -->
      <view class="field">
        <text class="field-label">心情</text>
        <view class="mood-grid">
          <view wx:for="{{visibleMoods}}" wx:key="key"
                class="mood-chip {{mood === item.key ? 'active' : ''}}"
                data-key="{{item.key}}"
                bindtap="onMoodTap">
            <text class="mood-emoji">{{item.emoji}}</text>
            <text class="mood-label">{{item.label}}</text>
          </view>
          <view class="mood-chip mood-more" bindtap="onOpenMoodModal">
            <text class="mood-emoji">⋯</text>
            <text class="mood-label">更多</text>
          </view>
        </view>
      </view>

      <!-- 短评 -->
      <view class="field">
        <view class="field-head">
          <text class="field-label">短评</text>
          <text class="count">{{noteCount}}/140</text>
        </view>
        <textarea class="note"
                  value="{{note}}"
                  maxlength="140"
                  placeholder="写一句读完后的感受（可不填）"
                  placeholder-class="placeholder"
                  bindinput="onNoteInput" />
      </view>
    </view>

    <!-- 底部提交 -->
    <view wx:if="{{selected}}" class="submit-bar">
      <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
        {{submitting ? '记录中...' : '添加阅读记录'}}
      </view>
    </view>
  </view>

  <!-- 更多心情弹窗 -->
  <view class="mood-modal" wx:if="{{moodModal}}" catchtouchmove="true">
    <view class="mood-modal-mask" bindtap="onCloseMoodModal"></view>
    <view class="mood-modal-sheet">
      <view class="mood-modal-head">
        <text class="mood-modal-title">选择心情</text>
        <text class="mood-modal-close" bindtap="onCloseMoodModal">✕</text>
      </view>
      <view class="mood-modal-grid">
        <view wx:for="{{moods}}" wx:key="key"
              class="mood-chip {{mood === item.key ? 'active' : ''}}"
              data-key="{{item.key}}"
              bindtap="onPickMood">
          <text class="mood-emoji">{{item.emoji}}</text>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

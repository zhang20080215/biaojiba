page {
  min-height: 100vh;
  background: #FAF6EB;
}
.page-root {
  min-height: 100vh;
  color: #1A1A1A;
  font-family: -apple-system, "PingFang SC", system-ui;
}
.top-toast {
  position: fixed;
  top: 22%;
  left: 50%;
  transform: translate(-50%, -8rpx);
  z-index: 1000;
  background: rgba(26, 26, 26, 0.88);
  color: #fff;
  padding: 18rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease, transform 220ms ease;
}
.top-toast.is-show {
  opacity: 1;
  transform: translate(-50%, 0);
}
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: #FAF6EB;
}
.nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
}
.nav-btn {
  position: absolute;
  top: 50%;
  left: 22rpx;
  width: 76rpx;
  height: 76rpx;
  margin-top: -38rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-btn-active {
  background: rgba(26, 26, 26, 0.06);
}
.nav-chev {
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}
.content {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}
.year-head {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 34rpx;
}
.year-arrow {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #6B6356;
}
.year-arrow.is-disabled {
  opacity: 0.25;
}
.year-label {
  min-width: 180rpx;
  text-align: center;
  font-size: 52rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}
.seg {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  background: #EFE7D2;
  border-radius: 22rpx;
  padding: 6rpx;
}
.seg-item {
  height: 70rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B6356;
  font-size: 26rpx;
  font-weight: 700;
}
.seg-item.active {
  background: #FFFFFF;
  color: #1A1A1A;
}
.state-text,
.empty {
  padding: 110rpx 0;
  text-align: center;
  color: #A89E8C;
}
.empty-title {
  display: block;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 800;
}
.empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
}
.poster-wall {
  margin-top: 34rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx 14rpx;
  justify-content: center;
}
.wall-item {
  width: 108rpx;
  height: 152rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
}
.wall-poster {
  width: 100%;
  height: 100%;
}
.month-grid {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.month-card {
  background: #FFFFFF;
  border: 2rpx solid #E8E0CC;
  border-radius: 22rpx;
  padding: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.month-cover,
.month-empty-cover {
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 14rpx;
  background: #EFE7D2;
}
.month-empty-cover {
  border: 2rpx dashed #D9CFB9;
  box-sizing: border-box;
}
.month-name {
  margin-top: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
}
.month-count {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #A89E8C;
}
.review {
  margin-top: 34rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8E0CC;
  border-radius: 28rpx;
  padding: 28rpx;
}
.review-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
}
.review-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.review-item {
  background: #FAF6EB;
  border-radius: 20rpx;
  padding: 20rpx;
}
.review-label {
  display: block;
  font-size: 22rpx;
  color: #A89E8C;
  font-weight: 700;
}
.review-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 800;
}
.top-movie {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #FAF6EB;
  border-radius: 20rpx;
  padding: 18rpx;
}
.top-poster {
  width: 86rpx;
  height: 122rpx;
  border-radius: 10rpx;
  background: #EFE7D2;
}
.top-info {
  flex: 1;
  min-width: 0;
}
.top-label {
  display: block;
  font-size: 22rpx;
  color: #A89E8C;
  font-weight: 700;
}
.top-title {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.top-meta {
  display: block;
  margin-top: 8rpx;
  color: #8A6A00;
  font-size: 24rpx;
  font-weight: 700;
}
.director-line {
  margin-top: 18rpx;
  background: #FAF6EB;
  border-radius: 20rpx;
  padding: 20rpx;
}

/* pages/index/index.wxss */

.page {
  padding: 20rpx;
  background: #f7f7f7;
  min-height: 100vh;
}

.search-box {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.search-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 32rpx;
  outline: none;
}

.movie-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.movie-item {
  width: 47%;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  padding: 20rpx 10rpx 16rpx 10rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.movie-cover {
  width: 160rpx;
  height: 220rpx;
  object-fit: cover;
  border-radius: 8rpx;
}

.movie-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  color: #333;
  text-align: center;
  font-weight: 500;
}


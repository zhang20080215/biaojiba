<view class="container">

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
    <text class="empty-icon">🏋️</text>
    <text class="empty-text">还没有训练记录</text>
    <text class="empty-hint">去打卡你的第一次训练吧</text>
  </view>

  <!-- 记录列表 -->
  <view class="record-groups" wx:if="{{groupedRecords.length > 0}}">
    <view class="date-group" wx:for="{{groupedRecords}}" wx:key="date">
      <view class="date-header">
        <text class="date-label">{{item.dateLabel}}</text>
        <text class="date-count">{{item.items.length}}次训练</text>
      </view>
      <view class="record-list">
        <view
          class="record-item"
          wx:for="{{item.items}}"
          wx:for-item="record"
          wx:key="_id"
          bindtap="onRecordTap"
          data-record="{{record}}"
        >
          <view class="record-left">
            <view class="record-type-badge {{record.category}}">
              <text class="record-type-text">{{record.category === 'cardio' ? '有氧' : '力量'}}</text>
            </view>
            <view class="record-info">
              <text class="record-name">{{record.type}}</text>
              <text class="record-detail">
                <block wx:if="{{record.duration}}">{{record.duration}}分钟</block>
                <block wx:if="{{record.distance}}"> · {{record.distance}}{{record.distanceUnit || 'km'}}</block>
                <block wx:if="{{record.sets}}">{{record.sets}}组 × {{record.reps}}次</block>
                <block wx:if="{{record.weight}}"> · {{record.weight}}kg</block>
              </text>
            </view>
          </view>
          <view class="record-actions">
            <view class="share-icon-btn" catchtap="onRecordTap" data-record="{{record}}">
              <text class="share-icon-text">📤</text>
            </view>
            <view class="delete-icon-btn" catchtap="onDeleteRecord" data-id="{{record._id}}">
              <text class="delete-icon-text">🗑</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-more" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
  <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
    <text class="no-more-text">没有更多了</text>
  </view>

</view>

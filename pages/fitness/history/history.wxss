.container {
  min-height: 100vh;
  background: #f0f4f8;
  box-sizing: border-box;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #aaa;
}

/* ========== 日期分组 ========== */
.date-group {
  margin-bottom: 32rpx;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}

.date-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.date-count {
  font-size: 24rpx;
  color: #999;
}

/* ========== 记录卡片 ========== */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.record-item:active {
  background: #f8f9fc;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.record-type-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.record-type-badge.cardio {
  background: linear-gradient(135deg, #4A7FD4, #5B9BE6);
}

.record-type-badge.strength {
  background: linear-gradient(135deg, #F08C4A, #F0A86A);
}

.record-type-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-detail {
  font-size: 24rpx;
  color: #999;
}

/* ========== 操作按钮 ========== */
.record-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.share-icon-btn,
.delete-icon-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f6f8;
}

.share-icon-btn:active,
.delete-icon-btn:active {
  background: #e8eaee;
}

.share-icon-text,
.delete-icon-text {
  font-size: 28rpx;
}

/* ========== 加载状态 ========== */
.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.loading-text,
.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}

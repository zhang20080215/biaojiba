.container {
  min-height: 100vh;
  background: #0a0f1e;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 60rpx;
  box-sizing: border-box;
}

.canvas-wrapper {
  width: 90vw;
  height: calc(90vw * 1660 / 1242);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 60rpx rgba(0,0,0,0.5);
}

.poster-canvas {
  width: 100%;
  height: 100%;
}

.actions {
  display: flex;
  gap: 24rpx;
  padding: 40rpx 32rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.save-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A7FD4, #5B9BE6);
  border-radius: 44rpx;
  box-shadow: 0 6rpx 24rpx rgba(74,127,212,0.35);
}

.save-btn.disabled {
  opacity: 0.6;
}

.save-btn:active {
  transform: scale(0.98);
}

.save-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.share-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  border-radius: 44rpx;
  border: 2rpx solid rgba(255,255,255,0.15);
  padding: 0;
  margin: 0;
}

.share-btn::after { border: none; }

.share-btn:active {
  background: rgba(255,255,255,0.15);
}

.share-text {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
}

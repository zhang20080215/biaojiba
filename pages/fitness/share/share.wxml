<view class="container">

  <!-- Canvas 海报 -->
  <view class="canvas-wrapper">
    <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="savePoster">
      <text class="save-text">{{saving ? '保存中...' : '保存到相册'}}</text>
    </view>
    <button class="share-btn" open-type="share">
      <text class="share-text">分享给好友</text>
    </button>
  </view>

</view>
